# Archive
.archive/

# Environment files
.env
.env.*
!.env.example
!.env.*.example

# Editor settings
.vscode/
.idea/

# Temporary files
tmp/
temp/
*.pid
*.pid.lock
.harmony/output/reports/.tmp/
.harmony/capabilities/_ops/state/.tmp/

# Logs directory
logs/
*.log

# Runtime and service run records
runs/


# Additional local outputs
out/

# Harmony runtime state (local/cache/traces)
.harmony/runtime/_ops/state/
.harmony/runtime/_ops/state/**
!.harmony/runtime/_ops/state/
!.harmony/runtime/_ops/state/.gitkeep

# OS-specific files
.DS_Store
Thumbs.db
Desktop.ini
Icon?
._*
.AppleDouble

# Archives from packaging
*.tgz

# direnv / envrc
.direnv/
.envrc

# Editor swap/backup files
*~
*.swp
*.swo
.fleet/

# Rust build artifacts (Harmony runtime + wasm services)
.harmony/runtime/_ops/state/build/
.harmony/runtime/_ops/state/build/**
.harmony/capabilities/services/_ops/state/build/
.harmony/capabilities/services/_ops/state/build/**

# Direct cargo build artifact locations
.harmony/runtime/crates/target/
.harmony/capabilities/services/**/rust/target/

# Generated by cargo-component / wit-bindgen for guest services
.harmony/capabilities/services/**/rust/src/bindings.rs
