# Archive directories
.archive/
**/.archive/
**/archive/
!.octon/inputs/exploratory/proposals/
!.octon/inputs/exploratory/proposals/**

# Environment files
.env
.env.*
!.env.example
!.env.*.example

# Editor settings
.vscode/
.idea/
.codex/config.toml

# Temporary files
tmp/
temp/
*.pid
*.pid.lock
.octon/generated/.tmp/
.octon/capabilities/_ops/state/.tmp/

# Logs directory
logs/
*.log

# Runtime and service run records
runs/
!.octon/framework/orchestration/runtime/runs/
!.octon/framework/orchestration/runtime/runs/**
!.octon/state/evidence/runs/
.octon/state/evidence/runs/*
!.octon/state/evidence/runs/README.md


# Additional local outputs and proposal workspaces
out/

# Octon runtime state (local/cache/traces)
.octon/engine/_ops/state/
.octon/engine/_ops/state/**
!.octon/engine/_ops/state/
!.octon/engine/_ops/state/.gitkeep

# OS-specific files
.DS_Store
Thumbs.db
Desktop.ini
Icon?
._*
.AppleDouble

# Archives from packaging
*.tgz

# direnv / envrc
.direnv/
.envrc

# Editor swap/backup files
*~
*.swp
*.swo
.fleet/

# Rust build artifacts (Octon runtime + wasm services)
.octon/engine/runtime/_ops/state/build/
.octon/engine/runtime/_ops/state/build/**
.octon/framework/engine/runtime/_ops/state/build/
.octon/framework/engine/runtime/_ops/state/build/**
.octon/engine/_ops/state/build/
.octon/engine/_ops/state/build/**
.octon/framework/engine/_ops/state/build/
.octon/framework/engine/_ops/state/build/**
.octon/capabilities/runtime/services/_ops/state/build/
.octon/capabilities/runtime/services/_ops/state/build/**
.octon/framework/capabilities/runtime/services/_ops/state/build/
.octon/framework/capabilities/runtime/services/_ops/state/build/**

# Direct cargo build artifact locations
.octon/engine/runtime/crates/target/
.octon/framework/engine/runtime/crates/target/
.octon/capabilities/runtime/services/**/rust/target/
.octon/framework/capabilities/runtime/services/**/rust/target/

# Generated by cargo-component / wit-bindgen for guest services
.octon/capabilities/runtime/services/**/rust/src/bindings.rs

# Proposal artifacts are tracked, except archived proposal history.
!.octon/inputs/exploratory/proposals/**
.octon/inputs/exploratory/proposals/.archive/
.octon/inputs/exploratory/proposals/.archive/**
