# Keep Cursor agents in-check: require human checkpoints on risky changes
rules:
  - pattern: "**/*.yml"
    description: "CI changes require explicit human approval"
    requireApproval: true
  - pattern: "packages/contracts/**"
    description: "Changing API contracts requires ADR link and oasdiff passing"
    requireApproval: true
  - pattern: "apps/**"
    description: "Feature flags must be used for user-visible changes"
    requireApproval: false
