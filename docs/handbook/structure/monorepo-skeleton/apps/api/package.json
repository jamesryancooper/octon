{
  "name": "@coe/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --require ../../infra/otel/instrumentation.ts dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "pino": "^9.4.0",
    "@opentelemetry/api": "^1.8.0",
    "@domain/*": "*",
    "@adapters/*": "*"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^20.14.10",
    "tsx": "^4.16.5",
    "vitest": "^2.1.0",
    "eslint": "^9.11.0"
  }
}
