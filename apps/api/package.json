{
    "name": "@harmony/api",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "LOG_LEVEL=debug tsx watch src/server.ts",
        "build": "tsup src/server.ts --format esm --out-dir dist --sourcemap --clean",
        "start": "NODE_ENV=production node --enable-source-maps dist/server.js",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "lint": "sh -c 'mkdir -p reports && eslint . -f json -o reports/eslint-api.json'",
        "test": "node -e \"console.log('apps/api test placeholder')\""
    },
    "dependencies": {
        "@harmony/config": "workspace:*",
        "@fastify/cors": "^11.1.0",
        "@fastify/helmet": "^13.0.2",
        "@opentelemetry/api": "^1.9.0",
        "@opentelemetry/auto-instrumentations-node": "^0.66.0",
        "@opentelemetry/exporter-metrics-otlp-proto": "^0.207.0",
        "@opentelemetry/exporter-trace-otlp-proto": "^0.207.0",
        "@opentelemetry/sdk-metrics": "^2.2.0",
        "@opentelemetry/sdk-node": "^0.207.0",
        "fastify": "^5.6.1",
        "pino": "^10.1.0"
    },
    "devDependencies": {
        "pino-pretty": "^13.1.2",
        "tsup": "^8.5.0",
        "tsx": "^4.20.6"
    }
}
