{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/agency/governance/delegation-boundaries-v1.schema.json",
  "title": "Octon Delegation Boundaries v1",
  "description": "Machine-readable delegation boundary set for deterministic allow/escalate/block routing.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "boundary_set_id",
    "boundary_set_version",
    "owner",
    "approved_by",
    "boundaries"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "delegation-boundaries-v1"
    },
    "boundary_set_id": {
      "type": "string",
      "minLength": 1
    },
    "boundary_set_version": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    },
    "review_cadence_days": {
      "type": "integer",
      "minimum": 1
    },
    "boundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "boundary_id",
          "decision_class",
          "condition",
          "route",
          "severity",
          "escalation_target"
        ],
        "properties": {
          "boundary_id": {
            "type": "string",
            "minLength": 1
          },
          "decision_class": {
            "type": "string",
            "minLength": 1
          },
          "condition": {
            "type": "string",
            "minLength": 1
          },
          "route": {
            "type": "string",
            "enum": [
              "allow",
              "escalate",
              "block"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "escalation_target": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
