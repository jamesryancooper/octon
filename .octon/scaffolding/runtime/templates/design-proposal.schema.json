{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Design Proposal Manifest",
  "description": "Schema for standard-governed Octon design proposal subtype manifests.",
  "type": "object",
  "required": [
    "schema_version",
    "design_class",
    "selected_modules",
    "validation"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "design-proposal-v1"
    },
    "design_class": {
      "type": "string",
      "enum": ["domain-runtime", "experience-product"]
    },
    "selected_modules": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["contracts", "conformance", "reference", "history", "canonicalization"]
      }
    },
    "validation": {
      "type": "object",
      "required": [
        "default_audit_mode",
        "design_validator_path",
        "conformance_validator_path"
      ],
      "properties": {
        "default_audit_mode": {
          "type": "string",
          "enum": ["rigorous", "short"]
        },
        "design_validator_path": {
          "type": ["string", "null"]
        },
        "conformance_validator_path": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
