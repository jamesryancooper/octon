{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/authorized-effect-token-v2.schema.json",
  "title": "Octon Authorized Effect Token v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "token_id",
    "effect_kind",
    "request_id",
    "grant_id",
    "run_id",
    "run_control_root",
    "run_evidence_root",
    "support_target_tuple_ref",
    "allowed_capability_packs",
    "scope_ref",
    "issued_at",
    "single_use",
    "issuer_ref",
    "token_record_ref",
    "token_digest"
  ],
  "properties": {
    "schema_version": { "const": "authorized-effect-token-v2" },
    "token_id": { "type": "string", "minLength": 1 },
    "effect_kind": {
      "type": "string",
      "enum": [
        "repo-mutation",
        "generated-effective-publication",
        "state-control-mutation",
        "evidence-mutation",
        "executor-launch",
        "service-invocation",
        "protected-ci-check",
        "extension-activation",
        "capability-pack-activation",
        "network-egress",
        "model-invocation",
        "promotion-activation",
        "disclosure-publication"
      ]
    },
    "request_id": { "type": "string", "minLength": 1 },
    "grant_id": { "type": "string", "minLength": 1 },
    "decision_artifact_ref": { "type": ["string", "null"] },
    "authority_grant_bundle_ref": { "type": ["string", "null"] },
    "run_id": { "type": "string", "minLength": 1 },
    "run_control_root": { "type": "string", "minLength": 1 },
    "run_evidence_root": { "type": "string", "minLength": 1 },
    "support_target_tuple_ref": { "type": "string", "minLength": 1 },
    "allowed_capability_packs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "scope_ref": { "type": "string", "minLength": 1 },
    "scope_constraints": { "type": "object" },
    "issued_at": { "type": "string", "minLength": 1 },
    "expires_at": { "type": ["string", "null"] },
    "single_use": { "type": "boolean" },
    "issuer_ref": { "type": "string", "minLength": 1 },
    "revocation_ref": { "type": ["string", "null"] },
    "token_record_ref": { "type": "string", "minLength": 1 },
    "journal_ref": { "type": ["string", "null"] },
    "token_digest": { "type": "string", "minLength": 1 }
  }
}
