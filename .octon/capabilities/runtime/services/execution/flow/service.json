{
  "abi": "wasi-component@0.2",
  "capabilities_required": [
    "log.write",
    "fs.read",
    "fs.write",
    "net.http"
  ],
  "category": "execution",
  "docs": {
    "help": "Use for deterministic native flow execution and optional external flow runtime forwarding.",
    "summary": "Native-first flow runtime service with optional LangGraph HTTP adapter."
  },
  "entry": "service.wasm",
  "format_version": "service-manifest-v1",
  "integrity": {
    "wasm_sha256": "d7b090185c35c5f2ef13782e9d58755aeb6707ed784482d479e1120dfd6bf6eb"
  },
  "limits": {
    "max_concurrency": 4,
    "max_request_bytes": 1048576,
    "max_response_bytes": 8388608,
    "timeout_ms": 120000
  },
  "name": "flow",
  "ops": {
    "run": {
      "idempotent": true,
      "input_schema": {
        "$id": "https://octon.local/schemas/flowkit/flowkit.inputs.v1.json",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "description": "Input schema for FlowKit run requests",
        "properties": {
          "adapter": {
            "type": "string"
          },
          "config": {
            "description": "Flow configuration",
            "properties": {
              "canonicalPromptPath": {
                "description": "Absolute or repo-relative path to the canonical prompt",
                "type": "string"
              },
              "flowName": {
                "description": "Identifier for the flow to run (e.g., 'architecture_assessment')",
                "pattern": "^[a-z][a-z0-9_]*$",
                "type": "string"
              },
              "observability": {
                "description": "Observability configuration",
                "properties": {
                  "enableTracing": {
                    "description": "Enable trace propagation",
                    "type": "boolean"
                  },
                  "serviceName": {
                    "description": "Service name for telemetry",
                    "type": "string"
                  },
                  "spanPrefix": {
                    "description": "Prefix for span names",
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "workflowEntrypoint": {
                "description": "Optional workflow entrypoint id",
                "type": "string"
              },
              "workflowManifestPath": {
                "description": "Workflow manifest path (e.g., 'langgraph.json')",
                "type": "string"
              },
              "workspaceRoot": {
                "description": "Optional workspace root to resolve relative paths",
                "type": "string"
              }
            },
            "required": [
              "flowName",
              "canonicalPromptPath",
              "workflowManifestPath"
            ],
            "type": "object"
          },
          "dryRun": {
            "type": "boolean"
          },
          "params": {
            "additionalProperties": true,
            "description": "Optional parameters to seed the flow",
            "type": "object"
          }
        },
        "required": [
          "config"
        ],
        "title": "FlowKitInputs",
        "type": "object"
      },
      "output_schema": {
        "$id": "https://octon.local/schemas/flowkit/flowkit.outputs.v1.json",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "description": "Output schema for FlowKit run results",
        "properties": {
          "artifacts": {
            "description": "Paths to artifacts produced by the flow",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "metadata": {
            "additionalProperties": true,
            "description": "Metadata about the flow run",
            "properties": {
              "canonicalPromptPath": {
                "type": "string"
              },
              "flowName": {
                "type": "string"
              },
              "runnerEndpoint": {
                "type": "string"
              },
              "runtimeRunId": {
                "type": "string"
              },
              "spanPrefix": {
                "type": "string"
              },
              "workflowEntrypoint": {
                "type": "string"
              },
              "workflowManifestPath": {
                "type": "string"
              },
              "workspaceRoot": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "result": {
            "description": "Flow-specific result payload",
            "type": [
              "object",
              "array",
              "string",
              "number",
              "boolean",
              "null"
            ]
          },
          "runId": {
            "description": "Stable identifier for this run",
            "format": "uuid",
            "type": "string"
          }
        },
        "required": [
          "result",
          "runId"
        ],
        "title": "FlowKitOutputs",
        "type": "object"
      },
      "streaming": false
    }
  },
  "version": "1.0.0"
}