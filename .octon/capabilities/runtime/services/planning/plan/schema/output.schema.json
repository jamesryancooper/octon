{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/schemas/plan/output.schema.json",
  "title": "PlanServiceOutput",
  "type": "object",
  "required": ["status", "plan"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "error"]
    },
    "plan": {
      "type": "object",
      "required": ["goal", "steps"],
      "properties": {
        "goal": { "type": "string" },
        "steps": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
