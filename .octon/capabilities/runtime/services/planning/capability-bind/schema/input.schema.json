{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/schemas/planning-capability-bind/input.schema.json",
  "title": "CapabilityBindServiceInput",
  "type": "object",
  "required": ["command"],
  "properties": {
    "command": {
      "type": "string",
      "enum": ["bind", "validate"]
    },
    "planPath": {
      "type": "string",
      "minLength": 1
    },
    "plan": {
      "type": "object",
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "requires": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "requiredCapabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "availableCapabilities": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "type": "boolean" },
          { "type": "string" }
        ]
      }
    },
    "strategy": {
      "type": "string",
      "enum": ["prefer-native", "prefer-adapter", "prefer-available"]
    },
    "strict": { "type": "boolean" }
  },
  "allOf": [
    {
      "anyOf": [
        { "required": ["plan"] },
        { "required": ["planPath"] }
      ]
    }
  ],
  "additionalProperties": false
}
