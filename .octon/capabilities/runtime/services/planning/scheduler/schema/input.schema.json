{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/schemas/scheduler/input.schema.json",
  "title": "SchedulerServiceInput",
  "type": "object",
  "required": ["command", "plan"],
  "properties": {
    "command": { "type": "string", "enum": ["schedule"] },
    "planPath": { "type": "string", "minLength": 1 },
    "plan": { "type": "object", "additionalProperties": true },
    "maxParallel": { "type": "integer", "minimum": 0 },
    "prefer": {
      "type": "string",
      "enum": ["compact", "throughput"],
      "default": "compact"
    }
  },
  "allOf": [
    {
      "anyOf": [
        { "required": ["plan"] },
        { "required": ["planPath"] }
      ]
    }
  ],
  "additionalProperties": false
}
