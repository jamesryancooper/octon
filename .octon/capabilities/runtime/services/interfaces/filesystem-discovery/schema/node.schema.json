{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/schemas/filesystem-interfaces/node.v1.json",
  "title": "FilesystemGraphNode",
  "type": "object",
  "required": ["node_id", "type"],
  "additionalProperties": false,
  "properties": {
    "node_id": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "enum": ["file", "dir", "topic", "symbol", "snapshot"] },
    "path": { "type": "string" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "snapshot_id": { "type": "string", "pattern": "^snap-[a-f0-9]{8,64}$" },
    "properties": { "type": "object", "additionalProperties": true }
  }
}
