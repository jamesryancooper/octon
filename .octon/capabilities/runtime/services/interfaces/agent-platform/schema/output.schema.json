{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/schemas/agent-platform/output.v1.json",
  "title": "AgentPlatformOutput",
  "description": "Output schema for interop service operations.",
  "type": "object",
  "required": ["ok", "interop_contract_version", "mode", "result"],
  "properties": {
    "ok": { "type": "boolean" },
    "interop_contract_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "mode": {
      "type": "string",
      "enum": ["native", "adapter"]
    },
    "adapter_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "result": {
      "type": "object",
      "additionalProperties": true
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
