{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/capabilities/deny-by-default.v2.schema.json",
  "title": "Octon Deny-by-Default Policy v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "defaults",
    "developer_context_gate",
    "context_overhead_gate",
    "exceptions",
    "governance_overrides",
    "grants",
    "agent_only",
    "kill_switch",
    "profiles",
    "observability",
    "flags_metadata",
    "acp",
    "reversibility",
    "budgets",
    "quorum",
    "attestations",
    "circuit_breakers",
    "receipts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0"
    },
    "mode": {
      "type": "string",
      "enum": [
        "shadow",
        "soft-enforce",
        "hard-enforce"
      ]
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fail_closed",
        "deny_unknown_tokens",
        "deny_unscoped_bash",
        "deny_unscoped_write"
      ],
      "properties": {
        "fail_closed": {
          "type": "boolean"
        },
        "deny_unknown_tokens": {
          "type": "boolean"
        },
        "deny_unscoped_bash": {
          "type": "boolean"
        },
        "deny_unscoped_write": {
          "type": "boolean"
        }
      }
    },
    "developer_context_gate": {
      "$ref": "#/$defs/developerContextGate"
    },
    "context_overhead_gate": {
      "$ref": "#/$defs/contextOverheadGate"
    },
    "exceptions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_file",
        "require_owner",
        "require_reason",
        "require_created",
        "require_expires",
        "max_lease_days"
      ],
      "properties": {
        "state_file": {
          "type": "string",
          "minLength": 1
        },
        "require_owner": {
          "type": "boolean"
        },
        "require_reason": {
          "type": "boolean"
        },
        "require_created": {
          "type": "boolean"
        },
        "require_expires": {
          "type": "boolean"
        },
        "max_lease_days": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "governance_overrides": {
      "$ref": "#/$defs/governanceOverrides"
    },
    "grants": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_dir",
        "default_ttl_seconds",
        "max_ttl_seconds_by_tier",
        "allow_auto_grant_low",
        "allow_auto_grant_medium",
        "allow_auto_grant_high",
        "require_provenance"
      ],
      "properties": {
        "state_dir": {
          "type": "string",
          "minLength": 1
        },
        "default_ttl_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "max_ttl_seconds_by_tier": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "low",
            "medium",
            "high"
          ],
          "properties": {
            "low": {
              "type": "integer",
              "minimum": 1
            },
            "medium": {
              "type": "integer",
              "minimum": 1
            },
            "high": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "allow_auto_grant_low": {
          "type": "boolean"
        },
        "allow_auto_grant_medium": {
          "type": "boolean"
        },
        "allow_auto_grant_high": {
          "type": "boolean"
        },
        "require_provenance": {
          "type": "boolean"
        }
      }
    },
    "agent_only": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "risk_tiers"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "risk_tiers": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "low",
            "medium",
            "high"
          ],
          "properties": {
            "low": {
              "$ref": "#/$defs/riskTier"
            },
            "medium": {
              "$ref": "#/$defs/riskTier"
            },
            "high": {
              "$ref": "#/$defs/riskTier"
            }
          }
        }
      }
    },
    "kill_switch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_dir",
        "fail_closed"
      ],
      "properties": {
        "state_dir": {
          "type": "string",
          "minLength": 1
        },
        "fail_closed": {
          "type": "boolean"
        }
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/profile"
      },
      "required": [
        "refactor",
        "scaffold",
        "tests",
        "docs",
        "release-readiness"
      ],
      "properties": {
        "refactor": {
          "$ref": "#/$defs/profile"
        },
        "scaffold": {
          "$ref": "#/$defs/profile"
        },
        "tests": {
          "$ref": "#/$defs/profile"
        },
        "docs": {
          "$ref": "#/$defs/profile"
        },
        "release-readiness": {
          "$ref": "#/$defs/profile"
        }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_log_path",
        "friction_slo"
      ],
      "properties": {
        "decision_log_path": {
          "type": "string",
          "minLength": 1
        },
        "friction_slo": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "false_deny_rate_max",
            "median_deny_to_unblock_seconds_max",
            "auto_remediation_success_rate_min"
          ],
          "properties": {
            "false_deny_rate_max": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "median_deny_to_unblock_seconds_max": {
              "type": "integer",
              "minimum": 1
            },
            "auto_remediation_success_rate_min": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      }
    },
    "flags_metadata": {
      "$ref": "#/$defs/flagsMetadataContract"
    },
    "acp": {
      "$ref": "#/$defs/acp"
    },
    "reversibility": {
      "$ref": "#/$defs/reversibility"
    },
    "budgets": {
      "$ref": "#/$defs/budgets"
    },
    "quorum": {
      "$ref": "#/$defs/quorum"
    },
    "attestations": {
      "$ref": "#/$defs/attestations"
    },
    "circuit_breakers": {
      "$ref": "#/$defs/circuit_breakers"
    },
    "receipts": {
      "$ref": "#/$defs/receipts"
    }
  },
  "$defs": {
    "riskTier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_distinct_agents",
        "require_review",
        "require_quorum_token",
        "require_rollback_plan"
      ],
      "properties": {
        "min_distinct_agents": {
          "type": "integer",
          "minimum": 1
        },
        "require_review": {
          "type": "boolean"
        },
        "require_quorum_token": {
          "type": "boolean"
        },
        "require_rollback_plan": {
          "type": "boolean"
        }
      }
    },
    "developerContextGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "allowlist",
        "limits"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "warn-only",
            "soft-enforce",
            "hard-enforce"
          ]
        },
        "allowlist": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "artifact_paths",
            "allowed_sections"
          ],
          "properties": {
            "artifact_paths": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "allowed_sections": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "max_bytes",
            "max_sections"
          ],
          "properties": {
            "max_bytes": {
              "type": "integer",
              "minimum": 1
            },
            "max_sections": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "contextOverheadGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "thresholds",
        "required_receipt_fields"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "warn-only",
            "soft-enforce",
            "hard-enforce"
          ]
        },
        "thresholds": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "warn_ratio",
            "soft_fail_ratio",
            "hard_fail_ratio",
            "max_context_files_read",
            "max_context_acquisition_ms"
          ],
          "properties": {
            "warn_ratio": {
              "type": "number",
              "minimum": 0
            },
            "soft_fail_ratio": {
              "type": "number",
              "minimum": 0
            },
            "hard_fail_ratio": {
              "type": "number",
              "minimum": 0
            },
            "max_context_files_read": {
              "type": "integer",
              "minimum": 0
            },
            "max_context_acquisition_ms": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "required_receipt_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "auto_grant_tier",
        "tool_bundle",
        "write_scope_bundle",
        "service_allowlist",
        "deny_rules"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "auto_grant_tier": {
          "type": "string",
          "enum": [
            "none",
            "low",
            "medium"
          ]
        },
        "tool_bundle": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "write_scope_bundle": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "service_allowlist": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "deny_rules": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(DDB[0-9]{3}|ACP|RA)_[A-Z0-9_]+$"
          },
          "uniqueItems": true
        }
      }
    },
    "acpLevel": {
      "type": "string",
      "enum": [
        "ACP-0",
        "ACP-1",
        "ACP-2",
        "ACP-3",
        "ACP-4"
      ]
    },
    "acpDecision": {
      "type": "string",
      "enum": [
        "ALLOW",
        "STAGE_ONLY",
        "DENY",
        "ESCALATE"
      ]
    },
    "iso8601Duration": {
      "type": "string",
      "pattern": "^P(?!$)(\\d+Y)?(\\d+M)?(\\d+D)?(T(\\d+H)?(\\d+M)?(\\d+S)?)?$"
    },
    "operationClass": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      ]
    },
    "acp": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "levels",
        "risk_tier_mapping",
        "operating_modes",
        "evidence_contracts",
        "profile_mode_map",
        "profile_defaults",
        "rules"
      ],
      "properties": {
        "levels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/acpLevelDescriptor"
          }
        },
        "risk_tier_mapping": {
          "$ref": "#/$defs/riskTierAcpMapping"
        },
        "operating_modes": {
          "$ref": "#/$defs/acpOperatingModes"
        },
        "evidence_contracts": {
          "$ref": "#/$defs/acpEvidenceContracts"
        },
        "profile_mode_map": {
          "$ref": "#/$defs/acpProfileModeMap"
        },
        "docs_gate": {
          "$ref": "#/$defs/acpDocsGate"
        },
        "materiality": {
          "$ref": "#/$defs/acpMateriality"
        },
        "telemetry_gate": {
          "$ref": "#/$defs/acpTelemetryGate"
        },
        "flag_metadata_gate": {
          "$ref": "#/$defs/acpFlagMetadataGate"
        },
        "profile_defaults": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/acpProfileDefault"
          }
        },
        "stage_only_behavior": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "emit_receipt": {
              "type": "boolean"
            },
            "preserve_artifacts": {
              "type": "boolean"
            },
            "notify": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "threshold_acp": {
                  "$ref": "#/$defs/acpLevel"
                },
                "channels": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "uniqueItems": true
                }
              }
            }
          }
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/acpRule"
          }
        }
      }
    },
    "acpLevelDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/acpLevel"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "acpProfileDefault": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ceiling",
        "allow_stage_only_fallback"
      ],
      "properties": {
        "ceiling": {
          "$ref": "#/$defs/acpLevel"
        },
        "allow_stage_only_fallback": {
          "type": "boolean"
        },
        "break_glass_required": {
          "type": "boolean"
        }
      }
    },
    "acpModeName": {
      "type": "string",
      "enum": [
        "observe",
        "iterate",
        "operate",
        "emergency"
      ]
    },
    "acpOperatingMode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acp_ceiling",
        "required_evidence_contract",
        "escalation_path"
      ],
      "properties": {
        "acp_ceiling": {
          "$ref": "#/$defs/acpLevel"
        },
        "required_evidence_contract": {
          "type": "string",
          "minLength": 1
        },
        "escalation_path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "acpOperatingModes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observe",
        "iterate",
        "operate",
        "emergency"
      ],
      "properties": {
        "observe": {
          "$ref": "#/$defs/acpOperatingMode"
        },
        "iterate": {
          "$ref": "#/$defs/acpOperatingMode"
        },
        "operate": {
          "$ref": "#/$defs/acpOperatingMode"
        },
        "emergency": {
          "$ref": "#/$defs/acpOperatingMode"
        }
      }
    },
    "acpEvidenceContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_evidence",
        "remediation"
      ],
      "properties": {
        "required_evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "remediation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "acpEvidenceContracts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/acpEvidenceContract"
      }
    },
    "acpProfileModeMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/acpModeName"
      },
      "required": [
        "refactor",
        "scaffold",
        "tests",
        "docs",
        "release-readiness",
        "observe",
        "iterate",
        "operate",
        "emergency"
      ]
    },
    "riskTierAcpMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "low",
        "medium",
        "high"
      ],
      "properties": {
        "low": {
          "$ref": "#/$defs/acpLevel"
        },
        "medium": {
          "$ref": "#/$defs/acpLevel"
        },
        "high": {
          "$ref": "#/$defs/acpLevel"
        }
      }
    },
    "acpDocsGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enforce_on_phase",
        "evidence_types",
        "missing_action_by_acp"
      ],
      "properties": {
        "enforce_on_phase": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "stage",
              "promote",
              "finalize"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "evidence_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "reason_code": {
          "type": "string",
          "pattern": "^ACP_[A-Z0-9_]+$"
        },
        "missing_action_by_acp": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/acpDecision"
          },
          "minProperties": 1,
          "propertyNames": {
            "pattern": "^ACP-[0-4]$"
          }
        }
      }
    },
    "acpMateriality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "predicate_name",
        "aliases",
        "target_fields",
        "enforce_on_phase",
        "default_for_phase"
      ],
      "properties": {
        "predicate_name": {
          "type": "string",
          "const": "material_side_effect"
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "target_fields": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "canonical",
            "aliases"
          ],
          "properties": {
            "canonical": {
              "type": "string",
              "const": "material_side_effect"
            },
            "aliases": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          }
        },
        "enforce_on_phase": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "stage",
              "promote",
              "finalize"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "default_for_phase": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "promote",
            "finalize"
          ],
          "properties": {
            "promote": {
              "type": "boolean"
            },
            "finalize": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "acpTelemetryGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enforce_on_phase",
        "required_for_acp_at_or_above",
        "target_field",
        "allowed_by_acp",
        "reason_codes",
        "missing_action_by_acp"
      ],
      "properties": {
        "enforce_on_phase": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "stage",
              "promote",
              "finalize"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "required_for_acp_at_or_above": {
          "$ref": "#/$defs/acpLevel"
        },
        "target_field": {
          "type": "string",
          "minLength": 1
        },
        "allowed_by_acp": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "pattern": "^ACP-[0-4]$"
          },
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "minimal",
                "sampled",
                "full"
              ]
            },
            "minItems": 1,
            "uniqueItems": true
          }
        },
        "reason_codes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "missing",
            "invalid"
          ],
          "properties": {
            "missing": {
              "type": "string",
              "pattern": "^ACP_[A-Z0-9_]+$"
            },
            "invalid": {
              "type": "string",
              "pattern": "^ACP_[A-Z0-9_]+$"
            }
          }
        },
        "missing_action_by_acp": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/acpDecision"
          },
          "minProperties": 1,
          "propertyNames": {
            "pattern": "^ACP-[0-4]$"
          }
        }
      }
    },
    "acpFlagMetadataGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enforce_on_phase",
        "required_when_target_flags",
        "metadata_valid_field",
        "evidence_type",
        "reason_codes",
        "missing_action_by_acp"
      ],
      "properties": {
        "enforce_on_phase": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "stage",
              "promote",
              "finalize"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "required_when_target_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "metadata_valid_field": {
          "type": "string",
          "minLength": 1
        },
        "evidence_type": {
          "type": "string",
          "minLength": 1
        },
        "reason_codes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "missing_evidence",
            "invalid"
          ],
          "properties": {
            "missing_evidence": {
              "type": "string",
              "pattern": "^ACP_[A-Z0-9_]+$"
            },
            "invalid": {
              "type": "string",
              "pattern": "^ACP_[A-Z0-9_]+$"
            }
          }
        },
        "missing_action_by_acp": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/acpDecision"
          },
          "minProperties": 1,
          "propertyNames": {
            "pattern": "^ACP-[0-4]$"
          }
        }
      }
    },
    "governanceOverrides": {
