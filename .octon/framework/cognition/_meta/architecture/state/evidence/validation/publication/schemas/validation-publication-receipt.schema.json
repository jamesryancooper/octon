{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.dev/schemas/validation-publication-receipt.schema.json",
  "title": "Octon Validation Publication Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "publication_family",
    "generation_id",
    "result",
    "validated_at",
    "validator_version",
    "contract_refs",
    "source_digests",
    "blocked_reasons",
    "quarantined_subjects",
    "published_paths",
    "required_inputs"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-validation-publication-receipt-v1"
    },
    "receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "publication_family": {
      "type": "string",
      "enum": [
        "locality",
        "extensions",
        "capabilities"
      ]
    },
    "generation_id": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "string",
      "enum": [
        "published",
        "published_with_quarantine",
        "withdrawn",
        "blocked"
      ]
    },
    "validated_at": {
      "type": "string",
      "minLength": 1
    },
    "validator_version": {
      "type": "string",
      "minLength": 1
    },
    "contract_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_digests": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      }
    },
    "blocked_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "quarantined_subjects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "subject_kind",
          "subject_id",
          "reason_code"
        ],
        "properties": {
          "subject_kind": {
            "type": "string",
            "enum": [
              "scope",
              "pack",
              "dependent",
              "repo"
            ]
          },
          "subject_id": {
            "type": "string",
            "minLength": 1
          },
          "reason_code": {
            "type": "string",
            "minLength": 1
          },
          "manifest_path": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "published_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_inputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
