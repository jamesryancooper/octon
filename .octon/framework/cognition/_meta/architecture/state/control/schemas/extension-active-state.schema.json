{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.dev/schemas/extension-active-state.schema.json",
  "title": "Octon Extension Active State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "desired_config_revision",
    "desired_selected_packs",
    "published_active_packs",
    "dependency_closure",
    "generation_id",
    "published_effective_catalog",
    "published_artifact_map",
    "published_generation_lock",
    "publication_receipt_path",
    "publication_receipt_sha256",
    "compatibility_status",
    "compatibility_receipt_path",
    "compatibility_receipt_sha256",
    "invalidation_conditions",
    "required_inputs",
    "validation_timestamp",
    "status"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-extension-active-state-v4"
    },
    "desired_config_revision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "desired_selected_packs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/packRef"
      }
    },
    "published_active_packs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/packRef"
      }
    },
    "dependency_closure": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/closureEntry"
      }
    },
    "generation_id": {
      "type": "string",
      "minLength": 1
    },
    "published_effective_catalog": {
      "type": "string",
      "minLength": 1
    },
    "published_artifact_map": {
      "type": "string",
      "minLength": 1
    },
    "published_generation_lock": {
      "type": "string",
      "minLength": 1
    },
    "publication_receipt_path": {
      "type": "string",
      "minLength": 1
    },
    "publication_receipt_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "compatibility_status": {
      "type": "string",
      "enum": [
        "compatible",
        "degraded",
        "incompatible"
      ]
    },
    "compatibility_receipt_path": {
      "type": "string",
      "minLength": 1
    },
    "compatibility_receipt_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "invalidation_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_inputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_timestamp": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "published",
        "published_with_quarantine",
        "withdrawn"
      ]
    }
  },
  "$defs": {
    "packRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pack_id",
        "source_id"
      ],
      "properties": {
        "pack_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "source_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        }
      }
    },
    "closureEntry": {
      "allOf": [
        {
          "$ref": "#/$defs/packRef"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "version",
            "origin_class",
            "manifest_path"
          ],
          "properties": {
            "version": {
              "type": "string",
              "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
            },
            "origin_class": {
              "type": "string",
              "enum": [
                "first_party_bundled",
                "first_party_external",
                "third_party"
              ]
            },
            "manifest_path": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    }
  }
}
