{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.dev/schemas/extension-quarantine-state.schema.json",
  "title": "Octon Extension Quarantine State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "updated_at",
    "records"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-extension-quarantine-state-v3"
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pack_id",
          "source_id",
          "reason_code",
          "affected_dependents",
          "timestamp"
        ],
        "properties": {
          "pack_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "source_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "reason_code": {
            "type": "string",
            "minLength": 1
          },
          "affected_dependents": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9-]*$"
            }
          },
          "timestamp": {
            "type": "string",
            "minLength": 1
          },
          "acknowledgement_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "publication_blocking": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
