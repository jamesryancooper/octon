{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/instance/locality/scope.schema.json",
  "title": "Octon Locality Scope Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scope_id",
    "display_name",
    "root_path",
    "owner",
    "status",
    "tech_tags",
    "language_tags"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "octon-locality-scope-v1"
    },
    "scope_id": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "root_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "tech_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "language_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "include_globs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "exclude_globs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "routing_hints": {
      "type": "object"
    },
    "mission_defaults": {
      "type": "object"
    }
  }
}
