{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.dev/schemas/extension-lifecycle-contract.schema.json",
  "title": "Octon Extension Lifecycle Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "lifecycle_id",
    "owner_extension",
    "version",
    "target",
    "states",
    "terminal_outcomes",
    "routes",
    "receipts"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-extension-lifecycle-contract-v1"
    },
    "lifecycle_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "owner_extension": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input", "manifest_path", "status_field", "allowed_statuses"],
      "properties": {
        "input": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "manifest_path": {
          "type": "string",
          "minLength": 1
        },
        "status_field": {
          "type": "string",
          "minLength": 1
        },
        "allowed_statuses": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "states": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["state_id"],
        "properties": {
          "state_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "summary": {
            "type": "string"
          }
        }
      },
      "minItems": 1
    },
    "terminal_outcomes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conditionedOutcome"
      },
      "minItems": 1
    },
    "validators": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validator"
      }
    },
    "gates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gate"
      }
    },
    "receipts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/receipt"
      },
      "minItems": 1
    },
    "input_bindings": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/inputBinding"
      }
    },
    "loops": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/loop"
      }
    },
    "program": {
      "$ref": "#/$defs/program"
    },
    "routes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/route"
      },
      "minItems": 1
    }
  },
  "$defs": {
    "argv": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "inputBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source"],
      "properties": {
        "source": {
          "type": "string",
          "pattern": "^(lifecycle\\.target|run\\.input\\.[A-Za-z0-9_-]+)$"
        }
      }
    },
    "conditionedOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome_id"],
      "properties": {
        "outcome_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "when": {
          "$ref": "#/$defs/conditionSet"
        }
      }
    },
    "conditionSet": {
      "type": "object",
      "additionalProperties": true
    },
    "program": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "child_registry_path",
        "supported_execution_modes",
        "recovery_policy",
        "authority_boundaries"
      ],
      "properties": {
        "child_registry_path": {
          "type": "string",
          "minLength": 1
        },
        "child_lifecycle_id_default": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "supported_execution_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "sequential",
              "gated-parallel",
              "approval-gated",
              "parallel-independent",
              "program-atomic"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "atomic_policy": {
          "$ref": "#/$defs/programAtomicPolicy"
        },
        "dependency_graph": {
          "type": "object",
          "additionalProperties": true
        },
        "recovery_policy": {
          "$ref": "#/$defs/programRecoveryPolicy"
        },
        "closeout_policy": {
          "$ref": "#/$defs/programCloseoutPolicy"
        },
        "authority_boundaries": {
          "$ref": "#/$defs/programAuthorityBoundaries"
        }
      }
    },
    "programAtomicPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eligibility"],
      "properties": {
        "eligibility": {
          "const": "explicit-route-opt-in"
        },
        "require_declared_write_scopes": {
          "type": "boolean"
        }
      }
    },
    "programRecoveryPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_recovery_attempts", "serialize_write_scope_conflicts"],
      "properties": {
        "max_recovery_attempts": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "serialize_write_scope_conflicts": {
          "type": "boolean"
        },
        "handlers": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/programRecoveryHandler"
          }
        },
        "recipes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/programRecoveryRecipe"
          },
          "uniqueItems": true
        }
      }
    },
    "programRecoveryHandler": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "recovery_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "max_attempts": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "replan_after_attempt": {
          "type": "boolean"
        },
        "approval_required": {
          "type": "boolean"
        }
      }
    },
    "programRecoveryRecipe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blocker_class",
        "idempotency_class",
        "approval_required",
        "retry_budget",
        "dependent_handling",
        "post_attempt_validation",
        "replan_behavior"
      ],
      "properties": {
        "blocker_class": {
          "type": "string",
          "enum": [
            "approval-required",
            "stale-receipt",
            "target-drift",
            "validation-failed",
            "dependency-blocked",
            "missing-evidence",
            "executor-failed",
            "write-scope-conflict",
            "unsafe-resume",
            "unsupported-mode",
            "authority-boundary-ambiguous"
          ]
        },
        "recovery_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "preconditions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "idempotency_class": {
          "type": "string",
          "enum": [
            "inspect-only",
            "idempotent",
            "idempotent-rerun",
            "bounded-retry",
            "approval-gated-mutation",
            "non-idempotent",
            "unsafe",
            "non-recoverable"
          ]
        },
        "approval_required": {
          "type": "boolean"
        },
        "retry_budget": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "dependent_handling": {
          "type": "string",
          "enum": [
            "continue-independent",
            "block-dependents",
            "pause-dependent",
            "pause-phase",
            "pause-barrier",
            "fail-closed"
          ]
        },
        "post_attempt_validation": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "replay-verify",
              "replan-live-state",
              "receipt-fresh",
              "receipt-freshness",
              "blocker-cleared",
              "authority-boundary-check",
              "aggregate-closeout-check"
            ]
          },
          "uniqueItems": true
        },
        "replan_behavior": {
          "type": "string",
          "enum": [
            "none",
            "after-attempt",
            "always"
          ]
        }
      }
    },
    "programCloseoutPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_child_terminal_outcomes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "uniqueItems": true
        },
        "require_child_receipts_fresh": {
          "type": "boolean"
        },
        "require_aggregate_evidence": {
          "type": "boolean"
        },
        "enforce_authority_boundaries": {
          "type": "boolean"
        }
      }
    },
    "programAuthorityBoundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parent_coordinates_only",
        "child_receipts_remain_child_owned",
        "child_promotion_targets_remain_child_owned"
      ],
      "properties": {
        "parent_coordinates_only": {
          "const": true
        },
        "child_receipts_remain_child_owned": {
          "const": true
        },
        "child_promotion_targets_remain_child_owned": {
          "const": true
        }
      }
    },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "argv"],
      "properties": {
        "validator_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "argv": {
          "$ref": "#/$defs/argv"
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate_id", "validator_id", "required_before_routes"],
      "properties": {
        "gate_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "validator_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "required_before_routes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "minItems": 1
        },
        "on_fail_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        }
      }
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["receipt_id", "path"],
      "properties": {
        "receipt_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "required_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "verdict_field": {
          "type": "string",
          "minLength": 1
        },
        "freshness": {
          "type": "object",
          "additionalProperties": false,
          "required": ["digest_command", "digest_field"],
          "properties": {
            "digest_command": {
              "$ref": "#/$defs/argv"
            },
            "digest_field": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "loop": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "loop_id",
        "receipt_id",
        "verdict_field",
        "repeat_values",
        "repeat_route_id",
        "terminal_values",
        "max_iterations"
      ],
      "properties": {
        "loop_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "receipt_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "verdict_field": {
          "type": "string",
          "minLength": 1
        },
        "repeat_values": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "repeat_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "terminal_values": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "max_iterations": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["route_id", "route_type"],
      "properties": {
        "route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "route_type": {
          "type": "string",
          "enum": ["extension", "workflow"]
        },
        "command_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "skill_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "prompt_set_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "required_inputs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]+$"
          }
        },
        "enter_when": {
          "$ref": "#/$defs/conditionSet"
        },
        "idempotency": {
          "type": "object",
          "additionalProperties": true
        },
        "approval": {
          "$ref": "#/$defs/routeApproval"
        },
        "completion": {
          "$ref": "#/$defs/routeCompletion"
        },
        "atomic": {
          "$ref": "#/$defs/routeAtomic"
        }
      }
    },
    "routeAtomic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage_route_id", "commit_route_id"],
      "properties": {
        "stage_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "commit_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "rollback_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "compensation_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        }
      },
      "anyOf": [
        { "required": ["rollback_route_id"] },
        { "required": ["compensation_route_id"] }
      ]
    },
    "routeApproval": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_by_default": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "routeCompletion": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "expected_receipts": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          }
        },
        "expected_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expected_manifest_status": {
          "type": "string",
          "minLength": 1
        },
        "expected_target_change": {
          "type": "boolean"
        },
        "replan_required": {
          "type": "boolean"
        }
      }
    }
  }
}
