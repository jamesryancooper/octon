{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.dev/schemas/extension-lifecycle-contract.schema.json",
  "title": "Octon Extension Lifecycle Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "lifecycle_id",
    "owner_extension",
    "version",
    "target",
    "states",
    "terminal_outcomes",
    "routes",
    "receipts"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-extension-lifecycle-contract-v1"
    },
    "lifecycle_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "owner_extension": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "execution_strategy": {
      "type": "string",
      "enum": [
        "route-progression",
        "orchestrated-replan-loop"
      ]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input", "manifest_path", "status_field", "allowed_statuses"],
      "properties": {
        "input": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "manifest_path": {
          "type": "string",
          "minLength": 1
        },
        "status_field": {
          "type": "string",
          "minLength": 1
        },
        "allowed_statuses": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "states": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["state_id"],
        "properties": {
          "state_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "summary": {
            "type": "string"
          }
        }
      },
      "minItems": 1
    },
    "terminal_outcomes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conditionedOutcome"
      },
      "minItems": 1
    },
    "validators": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validator"
      }
    },
    "gates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gate"
      }
    },
    "receipts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/receipt"
      },
      "minItems": 1
    },
    "input_bindings": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/inputBinding"
      }
    },
    "loops": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/loop"
      }
    },
    "program": {
      "$ref": "#/$defs/program"
    },
    "routes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/route"
      },
      "minItems": 1
    }
  },
  "$defs": {
    "argv": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "inputBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source"],
      "properties": {
        "source": {
          "type": "string",
          "pattern": "^(lifecycle\\.target|run\\.input\\.[A-Za-z0-9_-]+|receipt\\.[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+)$"
        }
      }
    },
    "conditionedOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome_id"],
      "properties": {
        "outcome_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "when": {
          "$ref": "#/$defs/conditionSet"
        }
      }
    },
    "conditionSet": {
      "type": "object",
      "additionalProperties": true
    },
    "program": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "child_registry_path",
        "supported_execution_modes",
        "recovery_policy",
        "authority_boundaries"
      ],
      "properties": {
        "child_registry_path": {
          "type": "string",
          "minLength": 1
        },
        "child_lifecycle_id_default": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "supported_execution_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "sequential",
              "gated-parallel",
              "approval-gated",
              "parallel-independent",
              "program-atomic"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "atomic_policy": {
          "$ref": "#/$defs/programAtomicPolicy"
        },
        "dependency_graph": {
          "type": "object",
          "additionalProperties": true
        },
        "recovery_policy": {
          "$ref": "#/$defs/programRecoveryPolicy"
        },
        "closeout_policy": {
          "$ref": "#/$defs/programCloseoutPolicy"
        },
        "authority_boundaries": {
          "$ref": "#/$defs/programAuthorityBoundaries"
        }
      }
    },
    "programAtomicPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eligibility"],
      "properties": {
        "eligibility": {
          "const": "explicit-route-opt-in"
        },
        "require_declared_write_scopes": {
          "type": "boolean"
        }
      }
    },
    "programRecoveryPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_recovery_attempts", "serialize_write_scope_conflicts"],
      "properties": {
        "max_recovery_attempts": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "serialize_write_scope_conflicts": {
          "type": "boolean"
        },
        "handlers": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/programRecoveryHandler"
          }
        },
        "recipes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/programRecoveryRecipe"
          },
          "uniqueItems": true
        }
      }
    },
    "programRecoveryHandler": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "recovery_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "max_attempts": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "replan_after_attempt": {
          "type": "boolean"
        },
        "human_required": {
          "type": "boolean"
        }
      }
    },
    "programRecoveryRecipe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blocker_class",
        "idempotency_class",
        "human_required",
        "retry_budget",
        "dependent_handling",
        "post_attempt_validation",
        "replan_behavior"
      ],
      "properties": {
        "blocker_class": {
          "type": "string",
          "enum": [
            "authority-ambiguity",
            "stale-receipt",
            "target-drift",
            "validation-failed",
            "dependency-blocked",
            "missing-evidence",
            "publication-drift",
            "executor-failed",
            "executor-timed-out",
            "executor-preflight-blocked",
            "step-budget-exhausted-continuable",
            "write-scope-conflict",
            "atomic-write-scope-conflict",
            "noncritical-artifact-cleanup",
            "lifecycle-residue-cleanup-needed",
            "critical-artifact-cleanup-required",
            "artifact-cleanup-required",
            "artifact-ownership-unclear",
            "recovery-route-unavailable",
            "receipt-recovery-unavailable",
            "finding-binding-unavailable",
            "deferred-evidence-missing",
            "aggregate-closeout-readiness-missing",
            "recovery-budget-override-required",
            "recovery-integrity-risk",
            "authority-zone-denied",
            "authority-zone-ambiguous",
            "self-authorization-attempt",
            "scope-expansion",
            "protected-artifact-authority-ambiguity",
            "unsafe-resume",
            "unsupported-mode",
            "unsupported-mode-config",
            "authority-boundary-ambiguous"
          ]
        },
        "recovery_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "recovery_action_id": {
          "type": "string",
          "enum": [
            "refresh-publication-projections",
            "rebaseline-checkpoint",
            "cleanup-current-run-artifacts"
          ]
        },
        "preconditions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "live-state-readable",
              "selected-route-present",
              "receipt-stale",
              "missing-evidence",
              "target-path-unchanged",
              "write-scope-unchanged",
              "current-run-child-owned-drift-evidence",
              "authority-zone-allowed",
              "artifact-ownership-known",
              "declared-write-scope-contained",
              "run-bound-current",
              "source-authority-digest-unchanged",
              "generated-non-authority"
            ]
          },
          "uniqueItems": true
        },
        "idempotency_class": {
          "type": "string",
          "enum": [
            "inspect-only",
            "idempotent",
            "idempotent-rerun",
            "bounded-retry",
            "approval-gated-mutation",
            "non-idempotent",
            "unsafe",
            "non-recoverable"
          ]
        },
        "human_required": {
          "type": "boolean"
        },
        "retry_budget": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "dependent_handling": {
          "type": "string",
          "enum": [
            "continue-independent",
            "block-dependents",
            "pause-dependent",
            "pause-phase",
            "pause-barrier",
            "fail-closed"
          ]
        },
        "post_attempt_validation": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "replay-verify",
              "replan-live-state",
              "receipt-fresh",
              "receipt-freshness",
              "blocker-cleared",
              "authority-boundary-check",
              "aggregate-closeout-check",
              "publication-freshness-cleared"
            ]
          },
          "uniqueItems": true
        },
        "replan_behavior": {
          "type": "string",
          "enum": [
            "none",
            "after-attempt",
            "always"
          ]
        },
        "allowed_authority_zones": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/authorityZone"
          },
          "uniqueItems": true
        },
        "allowed_artifact_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/authorityArtifactClass"
          },
          "uniqueItems": true
        },
        "operation_class": {
          "$ref": "#/$defs/authorityOperationClass"
        },
        "requires_run_binding": {
          "type": "boolean"
        },
        "requires_declared_write_scope": {
          "type": "boolean"
        },
        "requires_zone_evidence": {
          "type": "boolean"
        },
        "human_required_for_zones": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/authorityZone"
          },
          "uniqueItems": true
        }
      }
    },
    "authorityZone": {
      "type": "string",
      "enum": [
        "octon-run-bound",
        "octon-generated-derived",
        "octon-authored-governance",
        "workspace-declared",
        "current-run-agent-artifact",
        "protected-or-external"
      ]
    },
    "authorityArtifactClass": {
      "type": "string",
      "enum": [
        "run-control",
        "run-evidence",
        "generated-derived",
        "authored-governance",
        "workspace-source",
        "current-run-generated",
        "protected-human-or-external",
        "unknown"
      ]
    },
    "authorityOperationClass": {
      "type": "string",
      "enum": [
        "inspect",
        "append-run-evidence",
        "update-run-control",
        "refresh-generated-projection",
        "cleanup-current-run-artifact",
        "retry-child-route",
        "execute-child-route",
        "program-recovery-action",
        "closeout-readiness",
        "durable-authority-mutation",
        "protected-artifact-mutation"
      ]
    },
    "programCloseoutPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_child_terminal_outcomes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "uniqueItems": true
        },
        "require_child_receipts_fresh": {
          "type": "boolean"
        },
        "require_aggregate_evidence": {
          "type": "boolean"
        },
        "enforce_authority_boundaries": {
          "type": "boolean"
        }
      }
    },
    "programAuthorityBoundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parent_coordinates_only",
        "child_receipts_remain_child_owned",
        "child_promotion_targets_remain_child_owned"
      ],
      "properties": {
        "parent_coordinates_only": {
          "const": true
        },
        "child_receipts_remain_child_owned": {
          "const": true
        },
        "child_promotion_targets_remain_child_owned": {
          "const": true
        }
      }
    },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "argv"],
      "properties": {
        "validator_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "argv": {
          "$ref": "#/$defs/argv"
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate_id", "validator_id", "required_before_routes"],
      "properties": {
        "gate_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "validator_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "required_before_routes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "minItems": 1
        },
        "on_fail_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        }
      }
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["receipt_id", "path"],
      "properties": {
        "receipt_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "required_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "verdict_field": {
          "type": "string",
          "minLength": 1
        },
        "freshness": {
          "type": "object",
          "additionalProperties": false,
          "required": ["digest_command", "digest_field"],
          "properties": {
            "digest_command": {
              "$ref": "#/$defs/argv"
            },
            "digest_field": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "loop": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "loop_id",
        "receipt_id",
        "verdict_field",
        "repeat_values",
        "repeat_route_id",
        "terminal_values",
        "max_iterations"
      ],
      "properties": {
        "loop_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "receipt_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "verdict_field": {
          "type": "string",
          "minLength": 1
        },
        "repeat_values": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "repeat_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "terminal_values": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "max_iterations": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["route_id", "route_type", "delegation_contract"],
      "properties": {
        "route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "route_type": {
          "type": "string",
          "enum": ["extension", "workflow"]
        },
        "command_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "skill_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "prompt_set_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "required_inputs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]+$"
          }
        },
        "enter_when": {
          "$ref": "#/$defs/conditionSet"
        },
        "delegation_contract": {
          "$ref": "#/$defs/routeDelegationContract"
        },
        "completion": {
          "$ref": "#/$defs/routeCompletion"
        },
        "atomic": {
          "$ref": "#/$defs/routeAtomic"
        }
      }
    },
    "routeAtomic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage_route_id", "commit_route_id"],
      "properties": {
        "stage_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "commit_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "rollback_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "compensation_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        }
      },
      "anyOf": [
        { "required": ["rollback_route_id"] },
        { "required": ["compensation_route_id"] }
      ]
    },
    "routeDelegationContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_class",
        "safe_delegation",
        "authority_zones_allowed",
        "declared_write_scope_source",
        "required_evidence_gates",
        "required_receipts_before_dispatch",
        "required_receipts_before_completion",
        "replay_class",
        "automated_recovery_policy",
        "human_only_boundaries"
      ],
      "properties": {
        "decision_class": {
          "type": "string",
          "enum": ["delegated-execution", "new-governance-decision"]
        },
        "safe_delegation": {
          "type": "boolean"
        },
        "authority_zones_allowed": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/authorityZone"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "declared_write_scope_source": {
          "type": "string",
          "enum": [
            "target",
            "route-completion-and-target",
            "workflow-scope",
            "program-child-registry",
            "program-mutation-envelope",
            "run-bound-artifacts"
          ]
        },
        "required_evidence_gates": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "uniqueItems": true
        },
        "required_receipts_before_dispatch": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "uniqueItems": true
        },
        "required_receipts_before_completion": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "uniqueItems": true
        },
        "replay_class": {
          "type": "string",
          "enum": [
            "inspect-only",
            "idempotent",
            "idempotent-rerun",
            "bounded-retry",
            "no-op-safe",
            "non-replay-safe"
          ]
        },
        "automated_recovery_policy": {
          "type": "string",
          "minLength": 1
        },
        "human_only_boundaries": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "scope-expansion",
              "policy-override",
              "unresolved-risk-acceptance",
              "governance-mutation",
              "contradictory-evidence-resolution",
              "stale-evidence-acceptance",
              "authority-ambiguity",
              "unsafe-resume",
              "external-irreversible-effect"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "routeCompletion": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "expected_receipts": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          }
        },
        "expected_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expected_manifest_status": {
          "type": "string",
          "minLength": 1
        },
        "expected_target_change": {
          "type": "boolean"
        },
        "replan_required": {
          "type": "boolean"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "program",
          "execution_strategy"
        ]
      },
      "then": {
        "properties": {
          "execution_strategy": {
            "const": "orchestrated-replan-loop"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "execution_strategy": {
            "const": "orchestrated-replan-loop"
          }
        },
        "required": [
          "execution_strategy"
        ]
      },
      "then": {
        "required": [
          "program"
        ]
      }
    }
  ]
}
