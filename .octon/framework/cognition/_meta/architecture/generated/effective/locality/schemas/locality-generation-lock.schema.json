{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Effective Locality Generation Lock",
  "type": "object",
  "required": [
    "schema_version",
    "generator_version",
    "generation_id",
    "published_at",
    "publication_status",
    "publication_receipt_path",
    "publication_receipt_sha256",
    "locality_manifest_sha256",
    "locality_registry_sha256",
    "quarantine_sha256",
    "published_files",
    "required_inputs",
    "invalidation_conditions",
    "scope_manifest_digests"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-locality-generation-lock-v2"
    },
    "generator_version": {
      "type": "string",
      "minLength": 1
    },
    "generation_id": {
      "type": "string",
      "minLength": 1
    },
    "published_at": {
      "type": "string",
      "minLength": 1
    },
    "publication_status": {
      "type": "string",
      "enum": [
        "published",
        "published_with_quarantine"
      ]
    },
    "publication_receipt_path": {
      "type": "string",
      "minLength": 1
    },
    "publication_receipt_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "published_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "required_inputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "invalidation_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scope_manifest_digests": {
      "type": "array"
    }
  }
}
