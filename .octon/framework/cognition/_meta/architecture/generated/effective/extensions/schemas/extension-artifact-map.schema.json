{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.dev/schemas/extension-artifact-map.schema.json",
  "title": "Octon Extension Artifact Map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generator_version",
    "generation_id",
    "published_at",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-extension-artifact-map-v4"
    },
    "generator_version": {
      "type": "string",
      "minLength": 1
    },
    "generation_id": {
      "type": "string",
      "minLength": 1
    },
    "published_at": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pack_id",
          "source_id",
          "bucket",
          "relative_path",
          "source_path",
          "sha256"
        ],
        "properties": {
          "pack_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "source_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "bucket": {
            "type": "string",
            "enum": [
              "manifest",
              "documentation",
              "skills",
              "commands",
              "templates",
              "prompts",
              "context",
              "validation"
            ]
          },
          "relative_path": {
            "type": "string",
            "minLength": 1
          },
          "source_path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}
