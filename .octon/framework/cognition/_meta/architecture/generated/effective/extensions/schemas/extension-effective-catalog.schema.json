{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.dev/schemas/extension-effective-catalog.schema.json",
  "title": "Octon Extension Effective Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generator_version",
    "generation_id",
    "published_at",
    "publication_status",
    "publication_receipt_path",
    "compatibility_status",
    "compatibility_receipt_path",
    "compatibility_receipt_sha256",
    "invalidation_conditions",
    "desired_selected_packs",
    "published_active_packs",
    "dependency_closure",
    "packs",
    "source"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-extension-effective-catalog-v6"
    },
    "generator_version": {
      "type": "string",
      "minLength": 1
    },
    "generation_id": {
      "type": "string",
      "minLength": 1
    },
    "published_at": {
      "type": "string",
      "minLength": 1
    },
    "publication_status": {
      "type": "string",
      "enum": [
        "published",
        "published_with_quarantine",
        "withdrawn"
      ]
    },
    "publication_receipt_path": {
      "type": "string",
      "minLength": 1
    },
    "compatibility_status": {
      "type": "string",
      "enum": [
        "compatible",
        "degraded",
        "incompatible"
      ]
    },
    "compatibility_receipt_path": {
      "type": "string",
      "minLength": 1
    },
    "compatibility_receipt_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "invalidation_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "desired_selected_packs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/packRef"
      }
    },
    "published_active_packs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/packRef"
      }
    },
    "dependency_closure": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/closureEntry"
      }
    },
    "packs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/catalogPack"
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "desired_config_path",
        "desired_config_sha256",
        "root_manifest_path",
        "root_manifest_sha256"
      ],
      "properties": {
        "desired_config_path": {
          "type": "string",
          "minLength": 1
        },
        "desired_config_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "root_manifest_path": {
          "type": "string",
          "minLength": 1
        },
        "root_manifest_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  },
  "$defs": {
    "packRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pack_id",
        "source_id"
      ],
      "properties": {
        "pack_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "source_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        }
      }
    },
    "closureEntry": {
      "allOf": [
        {
          "$ref": "#/$defs/packRef"
        },
        {
          "type": "object",
          "required": [
            "version",
            "origin_class",
            "manifest_path"
          ],
          "properties": {
            "version": {
              "type": "string",
              "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
            },
            "origin_class": {
              "type": "string",
              "enum": [
                "first_party_bundled",
                "first_party_external",
                "third_party"
              ]
            },
            "manifest_path": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "catalogPack": {
      "allOf": [
        {
          "$ref": "#/$defs/closureEntry"
        },
        {
          "type": "object",
          "required": [
            "trust_decision",
            "publication_status",
            "compatibility_status",
            "compatibility_profile_path",
            "routing_exports"
          ],
          "properties": {
            "trust_decision": {
              "type": "string",
              "enum": [
                "allow",
                "require_acknowledgement",
                "deny"
              ]
            },
            "publication_status": {
              "type": "string",
              "enum": [
                "published",
                "published_with_quarantine",
                "withdrawn"
              ]
            },
            "compatibility_status": {
              "type": "string",
              "enum": [
                "compatible",
                "degraded",
                "incompatible"
              ]
            },
            "compatibility_profile_path": {
              "type": "string",
              "minLength": 1
            },
            "route_dispatchers": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/routeDispatcher"
              }
            },
            "prompt_bundles": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/promptBundle"
              }
            },
            "routing_exports": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "commands",
                "skills"
              ],
              "properties": {
                "commands": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/routingExportCommand"
                  }
                },
                "skills": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/routingExportSkill"
                  }
                }
              }
            }
          }
        }
      ]
    },
    "selectors": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "include",
        "exclude"
      ],
      "properties": {
        "include": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "fingerprints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tech_tags",
        "language_tags"
      ],
      "properties": {
        "tech_tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "language_tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "routingExportBase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability_id",
        "display_name",
        "summary",
        "status",
        "manifest_fragment_path",
        "projection_source_path",
        "host_adapters",
        "selectors",
        "fingerprints"
      ],
      "properties": {
        "capability_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "manifest_fragment_path": {
          "type": "string",
          "minLength": 1
        },
        "projection_source_path": {
          "type": "string",
          "minLength": 1
        },
        "host_adapters": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "claude",
              "cursor",
              "codex"
            ]
          }
        },
        "selectors": {
          "$ref": "#/$defs/selectors"
        },
        "fingerprints": {
          "$ref": "#/$defs/fingerprints"
        }
      }
    },
    "routingExportCommand": {
      "allOf": [
        {
          "$ref": "#/$defs/routingExportBase"
        },
        {
          "type": "object",
          "required": [
            "path",
            "access"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "access": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "routingExportSkill": {
      "allOf": [
        {
          "$ref": "#/$defs/routingExportBase"
        },
        {
          "type": "object",
          "required": [
            "path"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "promptBundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_set_id",
        "schema_version",
        "manifest_path",
        "manifest_sha256",
        "bundle_sha256",
        "publication_status",
        "alignment_status",
        "alignment_receipt_path",
        "default_alignment_mode",
        "skip_mode_policy",
        "invalidation_conditions",
        "required_repo_anchors",
        "prompt_assets",
        "reference_assets",
        "shared_reference_assets"
      ],
      "properties": {
        "prompt_set_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "schema_version": {
          "type": "string",
          "const": "octon-extension-prompt-set-v1"
        },
        "manifest_path": {
          "type": "string",
          "minLength": 1
        },
        "manifest_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "bundle_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "publication_status": {
          "type": "string",
          "enum": [
            "published",
            "published_with_quarantine",
            "withdrawn"
          ]
        },
        "alignment_status": {
          "type": "string",
          "minLength": 1
        },
        "alignment_receipt_path": {
          "type": "string",
          "minLength": 1
        },
        "default_alignment_mode": {
          "type": "string",
          "minLength": 1
        },
        "skip_mode_policy": {
          "type": "string",
          "minLength": 1
        },
        "invalidation_conditions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_repo_anchors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pathDigest"
          }
        },
        "prompt_assets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/promptAsset"
          }
        },
        "reference_assets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/referenceAsset"
          }
        },
        "shared_reference_assets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/referenceAsset"
          }
        }
      }
    },
    "pathDigest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "promptAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_id",
        "role_class",
        "path",
        "sha256",
        "projection_source_path"
      ],
      "properties": {
        "prompt_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "role_class": {
          "type": "string",
          "enum": [
            "stage",
            "maintenance-companion",
            "prompt-generation-companion"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "projection_source_path": {
          "type": "string",
          "minLength": 1
        },
        "stage_order": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "referenceAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "path",
        "sha256",
        "projection_source_path"
      ],
      "properties": {
        "ref_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "projection_source_path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "routeDispatcher": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dispatcher_id",
        "default_route_id",
        "accepted_inputs",
        "disambiguators",
        "precedence",
        "routes",
        "execution_bindings"
      ],
      "properties": {
        "dispatcher_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "default_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "accepted_inputs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        },
        "disambiguators": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/routeDisambiguator"
          }
        },
        "precedence": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          }
        },
        "routes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/routeDefinition"
          }
        },
        "execution_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/routeExecutionBinding"
          }
        },
        "reroute_policy": {
          "$ref": "#/$defs/routeReroutePolicy"
        }
      }
    },
    "routeDisambiguator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_name",
        "kind",
        "allowed_values"
      ],
      "properties": {
        "input_name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "enum",
            "route-id"
          ]
        },
        "allowed_values": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "routeDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_id",
        "status",
        "matchers"
      ],
      "properties": {
        "route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "status": {
          "type": "string",
          "enum": [
            "resolved",
            "escalate",
            "deny",
            "blocked"
          ]
        },
        "execution_binding_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "matchers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/routeMatcher"
          }
        }
      }
    },
    "routeMatcher": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "matcher_id",
        "reason_codes",
        "all_of"
      ],
      "properties": {
        "matcher_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          }
        },
        "all_of": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/routeMatcherCondition"
          }
        }
      }
    },
    "routeMatcherCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_name",
        "predicate"
      ],
      "properties": {
        "input_name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "predicate": {
          "type": "string",
          "enum": [
            "present",
            "absent",
            "equals",
            "one_of",
            "not_one_of"
          ]
        },
        "value": {},
        "values": {
          "type": "array",
          "items": {}
        }
      }
    },
    "routeExecutionBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_id",
        "route_id"
      ],
      "properties": {
        "binding_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "command_capability_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "skill_capability_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "prompt_set_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        }
      },
      "anyOf": [
        {
          "required": [
            "command_capability_id"
          ]
        },
        {
          "required": [
            "skill_capability_id"
          ]
        },
        {
          "required": [
            "prompt_set_id"
          ]
        }
      ]
    },
    "routeReroutePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_reroutes",
        "reroute_to_route_id",
        "allowed_source_route_ids",
        "trigger_reason_codes"
      ],
      "properties": {
        "max_reroutes": {
          "type": "integer",
          "minimum": 0
        },
        "reroute_to_route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "allowed_source_route_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          }
        },
        "trigger_reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          }
        }
      }
    }
  }
}
