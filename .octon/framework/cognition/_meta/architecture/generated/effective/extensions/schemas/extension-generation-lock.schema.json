{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.dev/schemas/extension-generation-lock.schema.json",
  "title": "Octon Extension Generation Lock",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generator_version",
    "generation_id",
    "published_at",
    "publication_status",
    "publication_receipt_path",
    "publication_receipt_sha256",
    "desired_config_sha256",
    "root_manifest_sha256",
    "published_files",
    "required_inputs",
    "invalidation_conditions",
    "pack_payload_digests"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-extension-generation-lock-v4"
    },
    "generator_version": {
      "type": "string",
      "minLength": 1
    },
    "generation_id": {
      "type": "string",
      "minLength": 1
    },
    "published_at": {
      "type": "string",
      "minLength": 1
    },
    "publication_status": {
      "type": "string",
      "enum": [
        "published",
        "published_with_quarantine",
        "withdrawn"
      ]
    },
    "publication_receipt_path": {
      "type": "string",
      "minLength": 1
    },
    "publication_receipt_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "desired_config_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "root_manifest_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "published_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "required_inputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "invalidation_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "pack_payload_digests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pack_id",
          "source_id",
          "manifest_path",
          "origin_class",
          "version",
          "payload_sha256",
          "files"
        ],
        "properties": {
          "pack_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "source_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "manifest_path": {
            "type": "string",
            "minLength": 1
          },
          "origin_class": {
            "type": "string",
            "enum": [
              "first_party_bundled",
              "first_party_external",
              "third_party"
            ]
          },
          "version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
          },
          "payload_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "path",
                "sha256"
              ],
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "sha256": {
                  "type": "string",
                  "pattern": "^[a-f0-9]{64}$"
                }
              }
            }
          }
        }
      }
    }
  }
}
