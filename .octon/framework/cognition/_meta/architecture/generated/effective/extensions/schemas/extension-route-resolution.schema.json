{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.dev/schemas/extension-route-resolution.schema.json",
  "title": "Octon Extension Route Resolution",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "source_id",
    "dispatcher_id",
    "status",
    "safe_to_run",
    "selected_route_id",
    "selected_execution_binding",
    "reason_codes",
    "precedence_trace",
    "normalized_input_facts",
    "alternatives_considered"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-extension-route-resolution-v1"
    },
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "source_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "dispatcher_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "status": {
      "type": "string",
      "enum": [
        "resolved",
        "escalate",
        "deny",
        "blocked"
      ]
    },
    "safe_to_run": {
      "type": "boolean"
    },
    "selected_route_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "selected_execution_binding": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "binding_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "route_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "command_capability_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "skill_capability_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "prompt_set_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        }
      }
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      }
    },
    "precedence_trace": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "matcher_id",
          "route_id",
          "matched"
        ],
        "properties": {
          "matcher_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "route_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "matched": {
            "type": "boolean"
          }
        }
      }
    },
    "normalized_input_facts": {
      "type": "object"
    },
    "alternatives_considered": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "matcher_id",
          "route_id",
          "reason_codes"
        ],
        "properties": {
          "matcher_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "route_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "reason_codes": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9-]*$"
            }
          }
        }
      }
    }
  }
}
