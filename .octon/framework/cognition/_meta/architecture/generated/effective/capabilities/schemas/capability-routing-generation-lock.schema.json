{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Effective Capability Routing Generation Lock",
  "type": "object",
  "required": [
    "schema_version",
    "generator_version",
    "generation_id",
    "published_at",
    "publication_status",
    "publication_receipt_path",
    "publication_receipt_sha256",
    "root_manifest_sha256",
    "extensions_catalog_sha256",
    "extensions_generation_lock_sha256",
    "extensions_generation_id",
    "locality_scopes_sha256",
    "locality_generation_lock_sha256",
    "locality_generation_id",
    "published_files",
    "required_inputs",
    "invalidation_conditions"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-capability-routing-generation-lock-v3"
    },
    "generator_version": {
      "type": "string",
      "minLength": 1
    },
    "generation_id": {
      "type": "string",
      "minLength": 1
    },
    "published_at": {
      "type": "string",
      "minLength": 1
    },
    "publication_status": {
      "type": "string",
      "enum": [
        "published",
        "published_with_quarantine"
      ]
    },
    "publication_receipt_path": {
      "type": "string",
      "minLength": 1
    },
    "publication_receipt_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "published_files": {
      "type": "array"
    },
    "required_inputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "invalidation_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
