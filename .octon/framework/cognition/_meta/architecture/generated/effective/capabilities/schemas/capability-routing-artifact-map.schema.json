{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Effective Capability Routing Artifact Map",
  "type": "object",
  "required": [
    "schema_version",
    "generator_version",
    "generation_id",
    "published_at",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-capability-routing-artifact-map-v3"
    },
    "generator_version": {
      "type": "string",
      "minLength": 1
    },
    "generation_id": {
      "type": "string",
      "minLength": 1
    },
    "published_at": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "artifact_map_id",
          "effective_id",
          "origin_class",
          "capability_kind",
          "capability_id",
          "source_kind",
          "source_manifest_path",
          "source_manifest_sha256",
          "source_path",
          "source_sha256"
        ]
      }
    }
  }
}
