{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/support-targets.schema.json",
  "title": "Octon Support Target Matrix",
  "description": "Schema for .octon/instance/governance/support-targets.yml with a bounded admitted support universe, dossier-backed tuple admissions, runtime projections, and adapter-conformance criteria.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "owner",
    "default_route",
    "governance_exclusions_ref",
    "support_claim_mode",
    "tiers",
    "compatibility_matrix",
    "adapter_conformance_criteria",
    "host_adapters",
    "model_adapters"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-support-targets-v1"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "default_route": {
      "type": "string",
      "enum": ["deny", "escalate"]
    },
    "review_cadence": {
      "type": "string",
      "minLength": 1
    },
    "support_claim_mode": {
      "type": "string",
      "enum": ["bounded-admitted-finite", "global-complete-finite"]
    },
    "governance_exclusions_ref": {
      "type": "string",
      "minLength": 1
    },
    "generated_projection_ref": {
      "type": "string",
      "minLength": 1
    },
    "pack_registry_ref": {
      "type": "string",
      "minLength": 1
    },
    "admission_review_contract_ref": {
      "type": "string",
      "minLength": 1
    },
    "live_support_universe": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model_classes": { "$ref": "#/$defs/string_array" },
        "workload_classes": { "$ref": "#/$defs/string_array" },
        "context_classes": { "$ref": "#/$defs/string_array" },
        "locale_classes": { "$ref": "#/$defs/string_array" },
        "host_adapters": { "$ref": "#/$defs/string_array" },
        "model_adapters": { "$ref": "#/$defs/string_array" },
        "capability_packs": { "$ref": "#/$defs/string_array" }
      }
    },
    "non_admitted_or_stage_only_surfaces": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model_classes": { "$ref": "#/$defs/string_array" },
        "workload_classes": { "$ref": "#/$defs/string_array" },
        "context_classes": { "$ref": "#/$defs/string_array" },
        "locale_classes": { "$ref": "#/$defs/string_array" },
        "host_adapters": { "$ref": "#/$defs/string_array" },
        "model_adapters": { "$ref": "#/$defs/string_array" },
        "capability_packs": { "$ref": "#/$defs/string_array" }
      }
    },
    "tiers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "workload",
        "language_resource",
        "locale"
      ],
      "properties": {
        "model": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/model_tier"
          }
        },
        "workload": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/workload_tier"
          }
        },
        "language_resource": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/language_resource_tier"
          }
        },
        "locale": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/locale_tier"
          }
        }
      }
    },
    "compatibility_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/matrix_entry"
      }
    },
    "tuple_admissions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/tuple_admission"
      }
    },
    "adapter_conformance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/adapter_conformance_criterion"
      }
    },
    "host_adapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/adapter_declaration"
      }
    },
    "model_adapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/adapter_declaration"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "retired_surfaces": {
      "$ref": "#/$defs/string_array"
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "model_tier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "default_autonomy", "description"],
      "properties": {
        "id": {
          "type": "string",
          "enum": ["frontier-governed", "repo-local-governed"]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "default_autonomy": {
          "type": "string",
          "enum": ["full", "bounded", "read_only"]
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workload_tier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "default_route", "description"],
      "properties": {
        "id": {
          "type": "string",
          "enum": ["observe-and-read", "repo-consequential", "boundary-sensitive"]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "default_route": {
          "type": "string",
          "enum": ["allow", "escalate"]
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "language_resource_tier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "description"],
      "properties": {
        "id": {
          "type": "string",
          "enum": ["reference-owned", "extended-governed"]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "locale_tier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "description"],
      "properties": {
        "id": {
          "type": "string",
          "enum": ["english-primary", "spanish-secondary"]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "matrix_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_tier",
        "workload_tier",
        "language_resource_tier",
        "locale_tier",
        "support_status",
        "default_route",
        "requires_mission",
        "allowed_capability_packs",
        "required_evidence"
      ],
      "properties": {
        "model_tier": {
          "type": "string",
          "enum": ["frontier-governed", "repo-local-governed"]
        },
        "workload_tier": {
          "type": "string",
          "enum": ["observe-and-read", "repo-consequential", "boundary-sensitive"]
        },
        "language_resource_tier": {
          "type": "string",
          "enum": ["reference-owned", "extended-governed"]
        },
        "locale_tier": {
          "type": "string",
          "enum": ["english-primary", "spanish-secondary"]
        },
        "support_status": {
          "type": "string",
          "enum": ["supported"]
        },
        "default_route": {
          "type": "string",
          "enum": ["allow"]
        },
        "requires_mission": {
          "type": "boolean"
        },
        "allowed_capability_packs": {
          "$ref": "#/$defs/string_array"
        },
        "required_evidence": {
          "$ref": "#/$defs/string_array"
        }
      }
    },
    "tuple_admission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "admission_id",
        "support_status",
        "tuple",
        "requires_mission",
        "consequence_class",
        "reversibility_class",
        "execution_horizon",
        "recurrence_class",
        "allowed_capability_packs",
        "required_proof_planes",
        "required_authority_artifacts",
        "admission_dossier_ref",
        "review_date"
      ],
      "properties": {
        "admission_id": {
          "type": "string",
          "minLength": 1
        },
        "support_status": {
          "type": "string",
          "enum": ["supported", "stage_only", "unsupported", "deprecated"]
        },
        "tuple": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "model_tier",
            "workload_tier",
            "language_resource_tier",
            "locale_tier",
            "host_adapter",
            "model_adapter"
          ],
          "properties": {
            "model_tier": {
              "type": "string",
              "minLength": 1
            },
            "workload_tier": {
              "type": "string",
              "minLength": 1
            },
            "language_resource_tier": {
              "type": "string",
              "minLength": 1
            },
            "locale_tier": {
              "type": "string",
              "minLength": 1
            },
            "host_adapter": {
              "type": "string",
              "minLength": 1
            },
            "model_adapter": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "requires_mission": {
          "type": "boolean"
        },
        "consequence_class": {
          "type": "string",
          "minLength": 1
        },
        "reversibility_class": {
          "type": "string",
          "minLength": 1
        },
        "execution_horizon": {
          "type": "string",
          "minLength": 1
        },
        "recurrence_class": {
          "type": "string",
          "minLength": 1
        },
        "protected_zone_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowed_capability_packs": {
          "$ref": "#/$defs/string_array"
        },
        "required_proof_planes": {
          "$ref": "#/$defs/string_array"
        },
        "required_authority_artifacts": {
          "$ref": "#/$defs/string_array"
        },
        "admission_dossier_ref": {
          "type": "string",
          "minLength": 1
        },
        "review_date": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "adapter_conformance_criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "criterion_id",
        "adapter_kind",
        "description"
      ],
      "properties": {
        "criterion_id": {
          "type": "string",
          "minLength": 1
        },
        "adapter_kind": {
          "type": "string",
          "enum": ["host", "model"]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "required_evidence": {
          "$ref": "#/$defs/string_array"
        }
      }
    },
    "adapter_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter_id",
        "contract_ref",
        "authority_mode",
        "replaceable",
        "support_status",
        "default_route",
        "criteria_refs",
        "allowed_model_tiers",
        "allowed_workload_tiers",
        "allowed_language_resource_tiers",
        "allowed_locale_tiers",
        "required_evidence"
      ],
      "properties": {
        "adapter_id": {
          "type": "string",
          "minLength": 1
        },
        "contract_ref": {
          "type": "string",
          "minLength": 1
        },
        "authority_mode": {
          "type": "string",
          "minLength": 1
        },
        "replaceable": {
          "type": "boolean"
        },
        "support_status": {
          "type": "string",
          "enum": ["supported", "stage_only", "unsupported", "deprecated", "retired"]
        },
        "default_route": {
          "type": "string",
          "enum": ["allow", "escalate", "deny"]
        },
        "criteria_refs": {
          "$ref": "#/$defs/string_array"
        },
        "allowed_model_tiers": {
          "$ref": "#/$defs/string_array"
        },
        "allowed_workload_tiers": {
          "$ref": "#/$defs/string_array"
        },
        "allowed_language_resource_tiers": {
          "$ref": "#/$defs/string_array"
        },
        "allowed_locale_tiers": {
          "$ref": "#/$defs/string_array"
        },
        "required_evidence": {
          "$ref": "#/$defs/string_array"
        }
      }
    }
  }
}
