{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/connector-trust-dossier-v1.schema.json",
  "title": "Connector Trust Dossier v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "connector_id",
    "operation_id",
    "status",
    "claim_effect",
    "connector_admission_ref",
    "operation_contract_ref",
    "support_target_tuple",
    "support_target_refs",
    "capability_pack_refs",
    "side_effect_class",
    "material_effect_class",
    "credential_class",
    "egress_requirements",
    "replayability",
    "rollback_compensation_posture",
    "required_evidence",
    "retained_admission_evidence",
    "failure_mode_tests",
    "security_review",
    "drift_quarantine_state",
    "freshness",
    "sufficiency",
    "trust_dossier_authorizes_execution",
    "dossier_authorizes_execution"
  ],
  "properties": {
    "schema_version": { "const": "connector-trust-dossier-v1" },
    "connector_id": { "type": "string", "minLength": 1 },
    "operation_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["observe_only", "read_only", "stage_only", "live_effectful", "quarantined", "retired", "denied", "blocked"] },
    "claim_effect": { "type": "string", "minLength": 1 },
    "connector_admission_ref": { "type": "string", "minLength": 1 },
    "connector_registry_ref": { "type": "string", "minLength": 1 },
    "connector_posture_policy_ref": { "type": "string", "minLength": 1 },
    "operation_contract_ref": { "type": "string", "minLength": 1 },
    "support_target_tuple": { "type": "string", "minLength": 1 },
    "support_target_refs": { "type": "array", "items": { "type": "string" } },
    "capability_pack_refs": { "type": "array", "items": { "type": "string" } },
    "side_effect_class": { "type": "string", "minLength": 1 },
    "material_effect_class": { "type": "string", "minLength": 1 },
    "credential_class": { "type": "string", "minLength": 1 },
    "egress_requirements": { "type": "array" },
    "redaction_metadata_ref": { "type": ["string", "null"] },
    "replayability": { "type": "string", "minLength": 1 },
    "rollback_compensation_posture": { "type": "string", "minLength": 1 },
    "context_pack_inclusion_required": { "const": true },
    "authorization_grant_required_for_material_effects": { "const": true },
    "effect_token_verification_required_for_material_operations": { "const": true },
    "retained_receipts_required": { "const": true },
    "required_evidence": { "type": "object" },
    "retained_admission_evidence": { "type": "array", "items": { "type": "string" } },
    "failure_mode_tests": { "type": "array", "items": { "type": "string" } },
    "security_review": { "type": "object" },
    "drift_quarantine_state": { "type": "object" },
    "freshness": { "type": "object" },
    "sufficiency": { "type": "object" },
    "known_exclusions": { "type": "array" },
    "notes": { "type": "array" },
    "trust_dossier_authorizes_execution": { "const": false },
    "dossier_authorizes_execution": { "const": false },
    "live_effectful_requires_human_approval": { "const": true },
    "current_admission_status": { "type": "string", "minLength": 1 }
  }
}
