{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/connector-admission-v1.schema.json",
  "title": "Connector Admission v1",
  "description": "Operation-level connector admission record. Admission never authorizes execution by itself.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "connector_id",
    "operation_id",
    "admission_state",
    "admission_mode",
    "live_effects_authorized",
    "connector_availability_is_authority",
    "admission_authorizes_execution",
    "allowed_modes",
    "operation_contract_ref",
    "connector_dossier_ref",
    "support_proof_map_ref",
    "capability_map_ref",
    "input_schema_ref",
    "output_schema_ref",
    "side_effect_class",
    "material_effect_class",
    "capability_packs_consumed",
    "credential_class",
    "egress_requirements",
    "replayability",
    "rollback_compensation_posture",
    "evidence_obligations",
    "timeout_budget_class",
    "support_posture",
    "policy_ref",
    "connector_registry_ref",
    "support_target_ref",
    "capability_pack_registry_ref",
    "context_pack_inclusion_required",
    "authorization_grant_required_for_material_effects",
    "effect_token_verification_required_for_material_operations",
    "retained_receipts_required",
    "broad_effectful_connector_autonomy",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "const": "connector-admission-v1" },
    "connector_id": { "type": "string", "minLength": 1 },
    "operation_id": { "type": "string", "minLength": 1 },
    "admission_state": {
      "type": "string",
      "enum": ["observe_only", "read_only", "stage_only", "live_effectful", "live_observe_read", "blocked", "quarantined", "retired", "denied", "revoked"]
    },
    "admission_mode": {
      "type": "string",
      "enum": ["observe_only", "read_only", "stage_only", "live_effectful", "quarantined", "retired", "denied"]
    },
    "live_effects_authorized": { "const": false },
    "connector_availability_is_authority": { "const": false },
    "admission_authorizes_execution": { "const": false },
    "allowed_modes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "operation_contract_ref": { "type": "string", "minLength": 1 },
    "connector_dossier_ref": { "type": "string", "minLength": 1 },
    "support_proof_map_ref": { "type": "string", "minLength": 1 },
    "capability_map_ref": { "type": "string", "minLength": 1 },
    "input_schema_ref": { "type": "string", "minLength": 1 },
    "output_schema_ref": { "type": "string", "minLength": 1 },
    "side_effect_class": {
      "type": "string",
      "enum": ["none", "observe_read", "repo_local", "external_effect", "destructive"]
    },
    "material_effect_class": { "type": "string", "minLength": 1 },
    "capability_packs_consumed": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "credential_class": { "type": "string", "minLength": 1 },
    "egress_requirements": { "type": "array" },
    "replayability": { "type": "string", "minLength": 1 },
    "rollback_compensation_posture": { "type": "string", "minLength": 1 },
    "evidence_obligations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "timeout_budget_class": { "type": "string", "minLength": 1 },
    "support_posture": { "type": "string", "minLength": 1 },
    "policy_ref": { "type": "string", "minLength": 1 },
    "connector_registry_ref": { "type": "string", "minLength": 1 },
    "support_target_ref": { "type": "string", "minLength": 1 },
    "capability_pack_registry_ref": { "type": "string", "minLength": 1 },
    "context_pack_inclusion_required": { "const": true },
    "authorization_grant_required_for_material_effects": { "const": true },
    "effect_token_verification_required_for_material_operations": { "const": true },
    "retained_receipts_required": { "const": true },
    "broad_effectful_connector_autonomy": {
      "type": "string",
      "enum": ["deferred", "denied"]
    },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 }
  }
}
