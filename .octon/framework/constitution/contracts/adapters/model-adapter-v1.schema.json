{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/adapters/model-adapter-v1.schema.json",
  "title": "Octon Model Adapter Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "adapter_id",
    "display_name",
    "replaceable",
    "authority_mode",
    "runtime_surface",
    "support_target_ref",
    "support_tier_declarations",
    "conformance_criteria_refs",
    "conformance_suite_refs",
    "contamination_reset_policy",
    "known_limitations",
    "non_authoritative_boundaries"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-model-adapter-v1"
    },
    "adapter_id": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "replaceable": {
      "const": true
    },
    "authority_mode": {
      "type": "string",
      "enum": [
        "non_authoritative"
      ]
    },
    "runtime_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "interface_ref",
        "integration_class"
      ],
      "properties": {
        "interface_ref": {
          "type": "string",
          "minLength": 1
        },
        "integration_class": {
          "type": "string",
          "enum": [
            "native-planning",
            "provider-bridge",
            "local-model",
            "other"
          ]
        }
      }
    },
    "tier_hints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "support_target_ref": {
      "type": "string",
      "minLength": 1
    },
    "support_tier_declarations": {
      "$ref": "#/$defs/support_tier_declarations"
    },
    "conformance_criteria_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "conformance_suite_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "contamination_reset_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clean_checkpoint_required",
        "hard_reset_on_signature",
        "contamination_signal_ref",
        "evidence_log_ref"
      ],
      "properties": {
        "clean_checkpoint_required": {
          "type": "boolean"
        },
        "hard_reset_on_signature": {
          "type": "boolean"
        },
        "contamination_signal_ref": {
          "type": "string",
          "minLength": 1
        },
        "evidence_log_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "known_limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_authoritative_boundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "support_tier_declarations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_tiers",
        "workload_tiers",
        "language_resource_tiers",
        "locale_tiers"
      ],
      "properties": {
        "model_tiers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "workload_tiers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "language_resource_tiers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "locale_tiers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
