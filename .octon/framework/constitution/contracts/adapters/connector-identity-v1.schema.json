{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/connector-identity-v1.schema.json",
  "title": "Connector Identity v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "connector_id",
    "connector_kind",
    "owner",
    "description",
    "supported_operation_refs",
    "credential_posture_ref",
    "egress_posture_ref",
    "default_admission_mode",
    "support_posture",
    "trust_dossier_refs",
    "retirement_quarantine_posture",
    "connector_identity_authorizes_execution"
  ],
  "properties": {
    "schema_version": { "const": "connector-identity-v1" },
    "connector_id": { "type": "string", "minLength": 1 },
    "connector_kind": { "type": "string", "enum": ["mcp", "api", "browser", "service", "local_tool", "ci", "release", "other"] },
    "owner": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "supported_operation_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "credential_posture_ref": { "type": "string", "minLength": 1 },
    "egress_posture_ref": { "type": "string", "minLength": 1 },
    "default_admission_mode": { "type": "string", "enum": ["observe_only", "read_only", "stage_only", "live_effectful", "quarantined", "retired", "denied"] },
    "support_posture": { "type": "string", "minLength": 1 },
    "trust_dossier_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "retirement_quarantine_posture": { "type": "object" },
    "connector_identity_authorizes_execution": { "const": false }
  }
}
