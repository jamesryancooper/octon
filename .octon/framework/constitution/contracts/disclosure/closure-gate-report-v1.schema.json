{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/disclosure/closure-gate-report-v1.schema.json",
  "title": "Octon Closure Gate Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_id",
    "generated_at",
    "gates"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-closure-gate-report-v1"
    },
    "release_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "gates": {
      "type": "array",
      "minItems": 1
    }
  }
}

