{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/retention/evidence-classification-v1.schema.json",
  "title": "Octon Run Evidence Classification v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "artifacts",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "run-evidence-classification-v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "artifact_ref",
          "evidence_class",
          "storage_class"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "artifact_ref": {
            "type": "string",
            "minLength": 1
          },
          "evidence_class": {
            "type": "string",
            "enum": [
              "A",
              "B",
              "C"
            ]
          },
          "storage_class": {
            "type": "string",
            "enum": [
              "git-inline",
              "git-pointer",
              "external-immutable"
            ]
          },
          "external_index_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "content_digest": {
            "type": [
              "string",
              "null"
            ]
          },
          "retention_window": {
            "type": [
              "string",
              "null"
            ]
          },
          "disclosure_relevance": {
            "type": [
              "string",
              "null"
            ]
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
