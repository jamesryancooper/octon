{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/retention/evidence-retention-contract-v1.schema.json",
  "title": "Octon Evidence Retention Contract v1",
  "description": "Canonical top-level contract for evidence classing, storage, retention, and retrieval.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "owner",
    "status",
    "classification_rules",
    "storage_location_rules",
    "retention_rules",
    "integrity_rules",
    "retrieval_rules",
    "support_claim_dependency_rules"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "evidence-retention-contract-v1"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active"
      ]
    },
    "classification_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "storage_location_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "retention_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "integrity_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "retrieval_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "support_claim_dependency_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
