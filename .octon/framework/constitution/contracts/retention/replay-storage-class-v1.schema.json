{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/retention/replay-storage-class-v1.schema.json",
  "title": "Octon Replay Storage Class v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "storage_class",
    "description"
  ],
  "properties": {
    "schema_version": {
      "const": "replay-storage-class-v1"
    },
    "storage_class": {
      "type": "string",
      "enum": [
        "git-inline",
        "git-pointer",
        "external-immutable"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    }
  }
}
