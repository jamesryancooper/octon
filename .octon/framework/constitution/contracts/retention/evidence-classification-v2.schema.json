{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/retention/evidence-classification-v2.schema.json",
  "title": "Octon Evidence Classification v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "generated_at",
    "class_a",
    "class_b",
    "class_c",
    "coverage_status",
    "retention_policy_ref",
    "external_index_ref",
    "missing_artifacts",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-evidence-classification-v2"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "class_a": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "class_b": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "class_c": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "coverage_status": {
      "type": "string",
      "enum": [
        "complete",
        "partial",
        "missing"
      ]
    },
    "retention_policy_ref": {
      "type": "string",
      "minLength": 1
    },
    "external_index_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "missing_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}

