{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/authority/prohibited-action-class-v1.schema.json",
  "title": "Octon Prohibited Action Class v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action_class_id",
    "route",
    "rationale",
    "required_authority",
    "required_evidence"
  ],
  "properties": {
    "action_class_id": { "type": "string", "minLength": 1 },
    "prior_support_surface": { "type": "string", "minLength": 1 },
    "route": { "type": "string", "enum": ["deny"] },
    "rationale": { "type": "string", "minLength": 1 },
    "required_authority": { "type": "string", "minLength": 1 },
    "required_evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
