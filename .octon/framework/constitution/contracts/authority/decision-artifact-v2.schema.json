{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/authority/decision-artifact-v2.schema.json",
  "title": "Octon Decision Artifact v2",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "decision_id",
    "request_id",
    "run_id",
    "route_outcome",
    "policy_refs",
    "authority_refs",
    "support_target_tuple",
    "generated_at"
  ],
  "properties": {
    "schema_version": { "const": "authority-decision-artifact-v2" },
    "decision_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "route_outcome": { "type": "string", "enum": ["allow", "stage_only", "escalate", "deny"] },
    "policy_refs": { "type": "array" },
    "authority_refs": { "type": "object" },
    "support_target_tuple": { "type": "object" },
    "generated_at": { "type": "string", "minLength": 1 }
  }
}
