{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/authority/budget-ledger-v1.schema.json",
  "title": "Octon Budget Ledger v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_id",
    "budget_dimensions",
    "current_usage",
    "thresholds",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "const": "budget-ledger-v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "budget_dimensions": { "type": "array" },
    "current_usage": { "type": "object" },
    "thresholds": { "type": "object" },
    "updated_at": { "type": "string", "minLength": 1 }
  }
}
