{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/authority/approval-request-v1.schema.json",
  "title": "Octon Approval Request v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "run_id",
    "status",
    "target_id",
    "action_type",
    "workflow_mode",
    "support_tier",
    "reason_codes",
    "required_evidence",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "authority-approval-request-v1"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["pending", "granted", "staged", "denied", "expired"]
    },
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "action_type": {
      "type": "string",
      "minLength": 1
    },
    "workflow_mode": {
      "type": "string",
      "enum": ["autonomous", "agent-augmented", "human-only"]
    },
    "support_tier": {
      "type": "string",
      "minLength": 1
    },
    "ownership_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reversibility_class": {
      "type": ["string", "null"]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "projection_sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/projection_source"
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "projection_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ref"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
