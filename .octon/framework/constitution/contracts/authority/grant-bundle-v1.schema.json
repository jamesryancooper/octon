{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/authority/grant-bundle-v1.schema.json",
  "title": "Octon Authority Grant Bundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "grant_id",
    "request_id",
    "run_id",
    "workflow_mode",
    "support_tier",
    "requested_capability_packs",
    "decision_artifact_ref",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "authority-grant-bundle-v1"
    },
    "grant_id": {
      "type": "string",
      "minLength": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_mode": {
      "type": "string",
      "enum": ["autonomous", "role-mediated", "human-only"]
    },
    "support_tier": {
      "type": ["string", "null"]
    },
    "support_target": {
      "type": ["object", "null"]
    },
    "requested_capability_packs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "quorum_policy_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "approval_request_ref": {
      "type": ["string", "null"]
    },
    "approval_grant_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "exception_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "revocation_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decision_artifact_ref": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
