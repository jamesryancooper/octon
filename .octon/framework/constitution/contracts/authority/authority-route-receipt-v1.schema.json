{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/authority/authority-route-receipt-v1.schema.json",
  "title": "Octon Authority Route Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "run_id",
    "support_target_ref",
    "decision",
    "recorded_at"
  ],
  "properties": {
    "schema_version": { "const": "authority-route-receipt-v1" },
    "receipt_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "support_target_ref": { "type": "string", "minLength": 1 },
    "decision": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "minLength": 1 }
  }
}
