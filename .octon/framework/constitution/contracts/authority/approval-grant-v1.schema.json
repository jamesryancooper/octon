{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/authority/approval-grant-v1.schema.json",
  "title": "Octon Approval Grant v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "grant_id",
    "request_id",
    "run_id",
    "state",
    "issued_by",
    "issued_at"
  ],
  "properties": {
    "schema_version": {
      "const": "authority-approval-grant-v1"
    },
    "grant_id": {
      "type": "string",
      "minLength": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "enum": ["active", "revoked", "expired"]
    },
    "issued_by": {
      "type": "string",
      "minLength": 1
    },
    "issued_at": {
      "type": "string",
      "minLength": 1
    },
    "expires_at": {
      "type": ["string", "null"]
    },
    "projection_sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/projection_source"
      }
    },
    "review_metadata": {
      "type": "object"
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "projection_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ref"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
