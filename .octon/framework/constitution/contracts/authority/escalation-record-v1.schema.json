{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/authority/escalation-record-v1.schema.json",
  "title": "Octon Escalation Record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "run_id",
    "reason",
    "route",
    "recorded_at"
  ],
  "properties": {
    "schema_version": { "const": "escalation-record-v1" },
    "record_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 1 },
    "route": { "type": "string", "enum": ["deny", "escalate"] },
    "recorded_at": { "type": "string", "minLength": 1 }
  }
}
