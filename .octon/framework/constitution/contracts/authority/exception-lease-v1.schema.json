{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/authority/exception-lease-v1.schema.json",
  "title": "Octon Exception Lease v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "state",
    "lease_kind",
    "owner",
    "issued_by",
    "issued_at",
    "expires_at",
    "reason",
    "rollback_posture",
    "retirement_trigger"
  ],
  "properties": {
    "schema_version": {
      "const": "authority-exception-lease-v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "enum": ["active", "revoked", "expired"]
    },
    "lease_kind": {
      "type": "string",
      "minLength": 1
    },
    "request_id": {
      "type": ["string", "null"]
    },
    "run_id": {
      "type": ["string", "null"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "issued_by": {
      "type": "string",
      "minLength": 1
    },
    "issued_at": {
      "type": "string",
      "minLength": 1
    },
    "expires_at": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "rollback_posture": {
      "type": "string",
      "minLength": 1
    },
    "retirement_trigger": {
      "type": "string",
      "minLength": 1
    }
  }
}
