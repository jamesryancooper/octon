{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/authority/grant-bundle-v2.schema.json",
  "title": "Octon Grant Bundle v2",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_id",
    "request_id",
    "route_outcome",
    "budget_ledger_ref",
    "support_target",
    "generated_at"
  ],
  "properties": {
    "schema_version": { "const": "authority-grant-bundle-v2" },
    "run_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "route_outcome": { "type": "string", "enum": ["allow", "stage_only", "escalate", "deny"] },
    "budget_ledger_ref": { "type": "string", "minLength": 1 },
    "support_target": { "type": "object" },
    "generated_at": { "type": "string", "minLength": 1 }
  }
}
