{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/runtime/replay-manifest-v2.schema.json",
  "title": "Octon Replay Manifest v2",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_id",
    "environment_topology",
    "class_b_refs",
    "class_c_refs",
    "recorded_at"
  ],
  "properties": {
    "schema_version": { "const": "replay-manifest-v2" },
    "run_id": { "type": "string", "minLength": 1 },
    "environment_topology": { "type": "object" },
    "class_b_refs": { "type": "array" },
    "class_c_refs": { "type": "array" },
    "recorded_at": { "type": "string", "minLength": 1 }
  }
}
