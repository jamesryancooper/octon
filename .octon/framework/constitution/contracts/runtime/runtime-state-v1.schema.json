{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/runtime/runtime-state-v1.schema.json",
  "title": "Octon Run Runtime State v1",
  "description": "Canonical mutable runtime lifecycle state for one bound run root.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "status",
    "workflow_mode",
    "run_contract_ref",
    "stage_attempt_root",
    "control_checkpoint_root",
    "evidence_root",
    "receipt_root",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "run-runtime-state-v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "bound",
        "authorizing",
        "authorized",
        "stage_only",
        "denied",
        "running",
        "succeeded",
        "failed",
        "cancelled"
      ]
    },
    "workflow_mode": {
      "type": "string",
      "enum": [
        "autonomous",
        "agent-augmented",
        "human-only"
      ]
    },
    "decision_state": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "pending",
        "allow",
        "stage_only",
        "deny",
        "escalate",
        null
      ]
    },
    "run_contract_ref": {
      "type": "string",
      "minLength": 1
    },
    "stage_attempt_root": {
      "type": "string",
      "minLength": 1
    },
    "control_checkpoint_root": {
      "type": "string",
      "minLength": 1
    },
    "evidence_root": {
      "type": "string",
      "minLength": 1
    },
    "receipt_root": {
      "type": "string",
      "minLength": 1
    },
    "current_stage_attempt_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_checkpoint_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_receipt_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "mission_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "parent_run_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
