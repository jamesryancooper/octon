{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/constitution/contracts/runtime/stewardship-campaign-coordination-hook-v1.schema.json",
  "title": "Stewardship Campaign Coordination Hook v1",
  "description": "Non-executing optional campaign candidate hook. Campaigns remain deferred unless existing promotion criteria are met.",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "program_id", "campaign_candidate_id", "promotion_criteria_ref", "standing_decision", "authority_boundary"],
  "properties": {
    "schema_version": { "const": "stewardship-campaign-coordination-hook-v1" },
    "standing_decision": { "const": "deferred_by_default" },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "campaign_is_execution_container",
        "campaign_launches_workflows",
        "campaign_claims_queue_items",
        "campaign_owns_runs",
        "campaign_owns_incidents",
        "campaign_replaces_missions",
        "campaign_replaces_stewardship",
        "campaign_required_for_normal_stewardship"
      ],
      "properties": {
        "campaign_is_execution_container": { "const": false },
        "campaign_launches_workflows": { "const": false },
        "campaign_claims_queue_items": { "const": false },
        "campaign_owns_runs": { "const": false },
        "campaign_owns_incidents": { "const": false },
        "campaign_replaces_missions": { "const": false },
        "campaign_replaces_stewardship": { "const": false },
        "campaign_required_for_normal_stewardship": { "const": false }
      }
    }
  }
}
