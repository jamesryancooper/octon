{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/runtime/instruction-layer-manifest-v2.schema.json",
  "title": "Octon Instruction Layer Manifest v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "run_mode",
    "workspace_charter_refs",
    "run_contract_ref",
    "support_target_tuple_id",
    "authority_refs",
    "precedence_stack",
    "adapter_projection_refs",
    "generated_at",
    "source_digests"
  ],
  "properties": {
    "schema_version": {
      "const": "instruction-layer-manifest-v2"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "mission_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "run_mode": {
      "type": "string",
      "enum": [
        "mission-bound",
        "run-only"
      ]
    },
    "workspace_charter_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "mission_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "run_contract_ref": {
      "type": "string",
      "minLength": 1
    },
    "support_target_tuple_id": {
      "type": "string",
      "minLength": 1
    },
    "context_pack_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "context_pack_receipt_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "model_visible_context_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "model_visible_context_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "context_policy_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "context_compaction_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "context_rebuild_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "authority_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "precedence_stack": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "adapter_projection_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "generated_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_digests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "dependentRequired": {
      "context_pack_ref": [
        "context_pack_receipt_ref",
        "model_visible_context_ref",
        "model_visible_context_sha256",
        "context_policy_ref"
      ],
      "context_pack_receipt_ref": [
        "context_pack_ref",
        "model_visible_context_ref",
        "model_visible_context_sha256",
        "context_policy_ref"
      ],
      "model_visible_context_ref": [
        "context_pack_ref",
        "context_pack_receipt_ref",
        "model_visible_context_sha256",
        "context_policy_ref"
      ],
      "model_visible_context_sha256": [
        "context_pack_ref",
        "context_pack_receipt_ref",
        "model_visible_context_ref",
        "context_policy_ref"
      ],
    "context_policy_ref": [
      "context_pack_ref",
      "context_pack_receipt_ref",
      "model_visible_context_sha256"
    ]
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[A-Fa-f0-9]{64}$|^[A-Fa-f0-9]{64}$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "run_mode": {
            "const": "mission-bound"
          }
        }
      },
      "then": {
        "required": [
          "mission_id"
        ],
        "properties": {
          "mission_id": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "context_pack_ref"
        ]
      },
      "then": {
        "required": [
          "context_pack_receipt_ref",
          "model_visible_context_ref",
          "model_visible_context_sha256",
          "context_policy_ref"
        ]
      }
    }
  ]
}
