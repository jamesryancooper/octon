{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/runtime/run-contract-v2.schema.json",
  "title": "Octon Run Contract v2",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_id",
    "status",
    "workflow_mode",
    "support_target_ref",
    "support_target",
    "authority_bundle_ref",
    "run_manifest_ref",
    "runtime_state_ref"
  ],
  "properties": {
    "schema_version": { "const": "run-contract-v2" },
    "run_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["bound", "active", "closed"] },
    "workflow_mode": { "type": "string", "minLength": 1 },
    "support_target_ref": { "type": "string", "minLength": 1 },
    "support_target": { "type": "object" },
    "authority_bundle_ref": { "type": "string", "minLength": 1 },
    "run_manifest_ref": { "type": "string", "minLength": 1 },
    "runtime_state_ref": { "type": "string", "minLength": 1 }
  }
}
