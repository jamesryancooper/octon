{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/runtime/run-manifest-v2.schema.json",
  "title": "Octon Run Manifest v2",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_id",
    "run_contract_ref",
    "authority_bundle_ref",
    "support_target_ref",
    "support_target",
    "runtime_state_ref",
    "run_card_ref"
  ],
  "properties": {
    "schema_version": { "const": "run-manifest-v2" },
    "run_id": { "type": "string", "minLength": 1 },
    "run_contract_ref": { "type": "string", "minLength": 1 },
    "authority_bundle_ref": { "type": "string", "minLength": 1 },
    "support_target_ref": { "type": "string", "minLength": 1 },
    "support_target": { "type": "object" },
    "runtime_state_ref": { "type": "string", "minLength": 1 },
    "run_card_ref": { "type": "string", "minLength": 1 }
  }
}
