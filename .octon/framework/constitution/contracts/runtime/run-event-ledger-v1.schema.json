{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/runtime/run-event-ledger-v1.schema.json",
  "title": "Octon Run Event Ledger v1",
  "description": "Manifest for the canonical append-only run event ledger.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "ledger_ref",
    "event_schema_ref",
    "event_count",
    "first_event_id",
    "last_event_id",
    "governing_event_refs",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "run-event-ledger-v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "ledger_ref": {
      "type": "string",
      "minLength": 1
    },
    "event_schema_ref": {
      "type": "string",
      "minLength": 1
    },
    "event_count": {
      "type": "integer",
      "minimum": 1
    },
    "first_event_id": {
      "type": "string",
      "minLength": 1
    },
    "last_event_id": {
      "type": "string",
      "minLength": 1
    },
    "governing_event_refs": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
