{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/runtime/compensation-record-v1.schema.json",
  "title": "Octon Compensation Record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "record_id",
    "status",
    "recorded_at"
  ],
  "properties": {
    "schema_version": { "const": "compensation-record-v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "record_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "minLength": 1 },
    "notes": { "type": "string" }
  }
}
