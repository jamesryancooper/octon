{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/runtime/engagement-v1.schema.json",
  "title": "Octon Constitutional Engagement v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "engagement_id",
    "repo_root",
    "status",
    "stage",
    "seed_intent_ref",
    "adoption_classification_ref",
    "authority_binding",
    "evidence_roots",
    "continuity_ref",
    "generated_projection_policy",
    "decision_request_refs",
    "closeout_state",
    "created_at",
    "updated_at"
  ],
  "allOf": [
    {
      "$ref": "../../../engine/runtime/spec/engagement-v1.schema.json"
    }
  ],
  "properties": {
    "schema_version": {
      "const": "engagement-v1"
    },
    "engagement_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "preflight_complete",
        "profiled",
        "planned",
        "armed",
        "requires_decision",
        "stage_only",
        "blocked",
        "denied",
        "closed"
      ]
    }
  }
}
