{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/runtime/run-continuity-v1.schema.json",
  "title": "Octon Run Continuity v1",
  "description": "Mutable resumability and handoff state for one bound run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "status",
    "run_contract_ref",
    "run_manifest_ref",
    "retained_evidence_ref",
    "replay_pointers_ref",
    "evidence_classification_ref",
    "last_checkpoint_ref",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "run-continuity-v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "authorizing",
        "authorized",
        "stage_only",
        "denied",
        "running",
        "paused",
        "succeeded",
        "failed",
        "cancelled"
      ]
    },
    "run_contract_ref": {
      "type": "string",
      "minLength": 1
    },
    "run_manifest_ref": {
      "type": "string",
      "minLength": 1
    },
    "retained_evidence_ref": {
      "type": "string",
      "minLength": 1
    },
    "replay_pointers_ref": {
      "type": "string",
      "minLength": 1
    },
    "evidence_classification_ref": {
      "type": "string",
      "minLength": 1
    },
    "last_receipt_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_checkpoint_ref": {
      "type": "string",
      "minLength": 1
    },
    "resume_from_stage_attempt_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "mission_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "parent_run_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "next_action": {
      "type": [
        "string",
        "null"
      ]
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
