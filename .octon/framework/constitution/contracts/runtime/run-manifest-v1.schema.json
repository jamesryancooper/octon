{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/runtime/run-manifest-v1.schema.json",
  "title": "Octon Run Manifest v1",
  "description": "Canonical bound run-topology manifest for one consequential run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "run_contract_ref",
    "intent_ref",
    "execution_role_ref",
    "support_tier",
    "support_target",
    "support_target_ref",
    "requested_capability_packs",
    "decision_artifact_ref",
    "authority_grant_bundle_ref",
    "host_adapter_ref",
    "model_adapter_ref",
    "runtime_state_ref",
    "run_continuity_ref",
    "stage_attempt_root",
    "control_checkpoint_root",
    "rollback_posture_ref",
    "evidence_root",
    "receipt_root",
    "assurance_root",
    "measurement_root",
    "intervention_root",
    "disclosure_root",
    "retained_evidence_ref",
    "replay_pointers_ref",
    "trace_pointers_ref",
    "evidence_classification_ref",
    "run_card_ref",
    "external_replay_index_ref",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "run-manifest-v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_contract_ref": {
      "type": "string",
      "minLength": 1
    },
    "intent_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "execution_role_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "support_tier": {
      "type": "string",
      "minLength": 1
    },
    "support_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_tier",
        "workload_tier",
        "language_resource_tier",
        "locale_tier",
        "host_adapter",
        "model_adapter"
      ],
      "properties": {
        "model_tier": { "type": "string", "minLength": 1 },
        "workload_tier": { "type": "string", "minLength": 1 },
        "language_resource_tier": { "type": "string", "minLength": 1 },
        "locale_tier": { "type": "string", "minLength": 1 },
        "host_adapter": { "type": "string", "minLength": 1 },
        "model_adapter": { "type": "string", "minLength": 1 }
      }
    },
    "support_target_ref": {
      "type": "string",
      "minLength": 1
    },
    "requested_capability_packs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decision_artifact_ref": {
      "type": "string",
      "minLength": 1
    },
    "authority_grant_bundle_ref": {
      "type": "string",
      "minLength": 1
    },
    "approval_request_ref": {
      "type": ["string", "null"]
    },
    "approval_grant_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "host_adapter_ref": {
      "type": "string",
      "minLength": 1
    },
    "model_adapter_ref": {
      "type": "string",
      "minLength": 1
    },
    "runtime_state_ref": {
      "type": "string",
      "minLength": 1
    },
    "run_continuity_ref": {
      "type": "string",
      "minLength": 1
    },
    "stage_attempt_root": {
      "type": "string",
      "minLength": 1
    },
    "control_checkpoint_root": {
      "type": "string",
      "minLength": 1
    },
    "rollback_posture_ref": {
      "type": "string",
      "minLength": 1
    },
    "evidence_root": {
      "type": "string",
      "minLength": 1
    },
    "receipt_root": {
      "type": "string",
      "minLength": 1
    },
    "assurance_root": {
      "type": "string",
      "minLength": 1
    },
    "measurement_root": {
      "type": "string",
      "minLength": 1
    },
    "intervention_root": {
      "type": "string",
      "minLength": 1
    },
    "disclosure_root": {
      "type": "string",
      "minLength": 1
    },
    "retained_evidence_ref": {
      "type": "string",
      "minLength": 1
    },
    "replay_pointers_ref": {
      "type": "string",
      "minLength": 1
    },
    "trace_pointers_ref": {
      "type": "string",
      "minLength": 1
    },
    "evidence_classification_ref": {
      "type": "string",
      "minLength": 1
    },
    "run_card_ref": {
      "type": "string",
      "minLength": 1
    },
    "external_replay_index_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "mission_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "parent_run_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
