{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/runtime/execution-receipt-v2.schema.json",
  "title": "Octon Execution Receipt v2",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "request_id",
    "action_type",
    "decision",
    "timestamps",
    "evidence_links"
  ],
  "properties": {
    "schema_version": { "const": "execution-receipt-v2" },
    "request_id": { "type": "string", "minLength": 1 },
    "action_type": { "type": "string", "minLength": 1 },
    "decision": { "type": "string", "minLength": 1 },
    "timestamps": { "type": "object" },
    "evidence_links": { "type": "object" }
  }
}
