{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/connector-execution-receipt-v1.schema.json",
  "title": "Connector Execution Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "connector_id",
    "operation_id",
    "run_id",
    "run_contract_ref",
    "context_pack_ref",
    "context_pack_receipt_ref",
    "connector_admission_ref",
    "execution_authorization_ref",
    "authorized_effect_token_ref",
    "verified_effect_ref",
    "execution_receipt_ref",
    "run_journal_event_ref",
    "receipt_emitted_at",
    "connector_receipt_replaces_run_evidence"
  ],
  "properties": {
    "schema_version": { "const": "connector-execution-receipt-v1" },
    "connector_id": { "type": "string", "minLength": 1 },
    "operation_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "run_contract_ref": { "type": "string", "minLength": 1 },
    "context_pack_ref": { "type": "string", "minLength": 1 },
    "context_pack_receipt_ref": { "type": "string", "minLength": 1 },
    "connector_admission_ref": { "type": "string", "minLength": 1 },
    "execution_authorization_ref": { "type": "string", "minLength": 1 },
    "authorized_effect_token_ref": { "type": "string", "minLength": 1 },
    "verified_effect_ref": { "type": "string", "minLength": 1 },
    "execution_receipt_ref": { "type": "string", "minLength": 1 },
    "run_journal_event_ref": { "type": "string", "minLength": 1 },
    "request_trace_refs": { "type": "array" },
    "response_trace_refs": { "type": "array" },
    "egress_record_refs": { "type": "array" },
    "redaction_refs": { "type": "array" },
    "rollback_compensation_refs": { "type": "array" },
    "receipt_emitted_at": { "type": "string", "minLength": 1 },
    "connector_receipt_replaces_run_evidence": { "const": false }
  }
}
