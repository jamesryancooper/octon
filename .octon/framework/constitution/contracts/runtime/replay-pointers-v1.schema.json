{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/runtime/replay-pointers-v1.schema.json",
  "title": "Octon Run Replay Pointers v1",
  "description": "Canonical replay and retained evidence pointers for one bound run root.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "replay_manifest_refs",
    "receipt_refs",
    "checkpoint_refs",
    "trace_refs",
    "external_index_refs",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "run-replay-pointers-v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "replay_manifest_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "receipt_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checkpoint_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "trace_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "external_index_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
