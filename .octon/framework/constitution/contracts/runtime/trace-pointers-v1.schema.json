{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/runtime/trace-pointers-v1.schema.json",
  "title": "Octon Run Trace Pointers v1",
  "description": "Canonical trace and action-log pointers for one bound run root.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "trace_id",
    "trace_refs",
    "external_index_refs",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "run-trace-pointers-v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "external_index_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
