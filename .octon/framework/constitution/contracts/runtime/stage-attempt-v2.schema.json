{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/runtime/stage-attempt-v2.schema.json",
  "title": "Octon Stage Attempt v2",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_id",
    "stage_attempt_id",
    "stage_ref",
    "attempt_kind",
    "status",
    "objective_ref",
    "retry_class",
    "completion_status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "stage-attempt-v2"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "stage_attempt_id": {
      "type": "string",
      "minLength": 1
    },
    "stage_ref": {
      "type": "string",
      "minLength": 1
    },
    "attempt_kind": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "objective_ref": {
      "type": "string",
      "minLength": 1
    },
    "retry_class": {
      "type": "string",
      "minLength": 1
    },
    "completion_status": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}

