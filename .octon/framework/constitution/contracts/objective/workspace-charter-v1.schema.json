{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/objective/workspace-charter-v1.schema.json",
  "title": "Octon Workspace Charter v1",
  "description": "Machine-readable workspace charter bound to the live workspace objective layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workspace_charter_id",
    "version",
    "objective_layer",
    "constitutional_role",
    "constitutional_objective_ref",
    "release_state",
    "change_profile",
    "profile_selection_receipt_ref",
    "objective_signals",
    "authorized_actions",
    "hard_boundaries",
    "owner",
    "approved_by",
    "execution_binding"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "workspace-charter-v1"
    },
    "workspace_charter_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "legacy_intent_lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intent_id",
        "version"
      ],
      "properties": {
        "intent_id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "objective_layer": {
      "type": "string",
      "const": "workspace-charter-pair"
    },
    "constitutional_role": {
      "type": "string",
      "const": "workspace-charter-machine"
    },
    "constitutional_objective_ref": {
      "type": "string",
      "minLength": 1
    },
    "release_state": {
      "type": "string",
      "enum": [
        "pre-1.0",
        "stable"
      ]
    },
    "change_profile": {
      "type": "string",
      "enum": [
        "atomic",
        "transitional"
      ]
    },
    "profile_selection_receipt_ref": {
      "type": "string",
      "minLength": 1
    },
    "objective_signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          }
        }
      }
    },
    "authorized_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "hard_boundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "boundary_id",
          "rule",
          "on_violation"
        ],
        "properties": {
          "boundary_id": {
            "type": "string",
            "minLength": 1
          },
          "rule": {
            "type": "string",
            "minLength": 1
          },
          "on_violation": {
            "type": "string",
            "enum": [
              "deny",
              "escalate"
            ]
          }
        }
      }
    },
    "tradeoff_hierarchy": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "review_by": {
      "type": "string",
      "minLength": 1
    },
    "execution_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_objective_ref",
        "run_contract_control_root",
        "run_contract_schema_ref",
        "stage_attempt_schema_ref",
        "mission_authority_root",
        "mission_required_for",
        "run_only_autonomy_requires_declared_support_tier",
        "silent_missionless_fallback"
      ],
      "properties": {
        "workspace_objective_ref": {
          "type": "string",
          "minLength": 1
        },
        "run_contract_control_root": {
          "type": "string",
          "minLength": 1
        },
        "run_contract_schema_ref": {
          "type": "string",
          "minLength": 1
        },
        "stage_attempt_schema_ref": {
          "type": "string",
          "minLength": 1
        },
        "mission_authority_root": {
          "type": "string",
          "minLength": 1
        },
        "mission_required_for": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "run_only_autonomy_requires_declared_support_tier": {
          "type": "boolean"
        },
        "silent_missionless_fallback": {
          "type": "string",
          "enum": [
            "deny"
          ]
        }
      }
    }
  }
}
