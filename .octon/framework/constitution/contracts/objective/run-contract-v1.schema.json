{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/objective/run-contract-v1.schema.json",
  "title": "Octon Run Contract v1",
  "description": "Constitutional per-run objective contract for consequential execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "objective_refs",
    "mission_mode",
    "objective_summary",
    "scope_in",
    "scope_out",
    "exclusions",
    "done_when",
    "acceptance_criteria",
    "materiality",
    "protected_zones",
    "requested_capabilities",
    "requested_capability_packs",
    "risk_class",
    "intent_ref",
    "actor_ref",
    "reversibility_class",
    "support_tier",
    "support_target",
    "support_target_ref",
    "required_approvals",
    "required_evidence",
    "start_conditions",
    "stop_conditions",
    "retry_class",
    "closure_conditions",
    "disclosure_expectations",
    "stage_attempt_root",
    "run_manifest_ref",
    "decision_artifact_ref",
    "authority_grant_bundle_ref",
    "run_card_ref",
    "contract_version",
    "issued_at",
    "expires_at",
    "status",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "run-contract-v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "mission_mode": {
      "type": "string",
      "enum": [
        "required",
        "optional",
        "none"
      ]
    },
    "objective_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_objective_ref",
        "workspace_intent_ref"
      ],
      "properties": {
        "workspace_objective_ref": {
          "type": "string",
          "minLength": 1
        },
        "workspace_intent_ref": {
          "type": "string",
          "minLength": 1
        },
        "mission_ref": {
          "type": "string",
          "minLength": 1
        },
        "mission_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "objective_summary": {
      "type": "string",
      "minLength": 1
    },
    "scope_in": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scope_out": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(?!/Users/)(?!/home/).+"
      }
    },
    "exclusions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "done_when": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "materiality": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "protected_zones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requested_capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requested_capability_packs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risk_class": {
      "type": "string",
      "minLength": 1
    },
    "intent_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "actor_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "reversibility_class": {
      "type": "string",
      "minLength": 1
    },
    "support_tier": {
      "type": "string",
      "minLength": 1
    },
    "support_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_tier",
        "workload_tier",
        "language_resource_tier",
        "locale_tier",
        "host_adapter",
        "model_adapter"
      ],
      "properties": {
        "model_tier": { "type": "string", "minLength": 1 },
        "workload_tier": { "type": "string", "minLength": 1 },
        "language_resource_tier": { "type": "string", "minLength": 1 },
        "locale_tier": { "type": "string", "minLength": 1 },
        "host_adapter": { "type": "string", "minLength": 1 },
        "model_adapter": { "type": "string", "minLength": 1 }
      }
    },
    "support_target_ref": {
      "type": "string",
      "minLength": 1
    },
    "required_approvals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "start_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "retry_class": {
      "type": "string",
      "enum": [
        "retryable_transient",
        "retryable_validation",
        "retryable_environment",
        "rollback_then_retry",
        "manual_review_required",
        "non_retryable_contract_violation",
        "contamination_reset_required"
      ]
    },
    "closure_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "disclosure_expectations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "stage_attempt_root": {
      "type": "string",
      "minLength": 1
    },
    "run_manifest_ref": {
      "type": "string",
      "minLength": 1
    },
    "decision_artifact_ref": {
      "type": "string",
      "minLength": 1
    },
    "authority_grant_bundle_ref": {
      "type": "string",
      "minLength": 1
    },
    "run_card_ref": {
      "type": "string",
      "minLength": 1
    },
    "host_adapter_ref": {
      "type": "string",
      "minLength": 1
    },
    "model_adapter_ref": {
      "type": "string",
      "minLength": 1
    },
    "external_replay_index_ref": {
      "type": "string",
      "minLength": 1
    },
    "control_checkpoint_root": {
      "type": "string",
      "minLength": 1
    },
    "runtime_state_ref": {
      "type": "string",
      "minLength": 1
    },
    "rollback_posture_ref": {
      "type": "string",
      "minLength": 1
    },
    "evidence_root": {
      "type": "string",
      "minLength": 1
    },
    "receipt_root": {
      "type": "string",
      "minLength": 1
    },
    "assurance_root": {
      "type": "string",
      "minLength": 1
    },
    "measurement_root": {
      "type": "string",
      "minLength": 1
    },
    "intervention_root": {
      "type": "string",
      "minLength": 1
    },
    "disclosure_root": {
      "type": "string",
      "minLength": 1
    },
    "run_card_ref": {
      "type": "string",
      "minLength": 1
    },
    "replay_pointers_ref": {
      "type": "string",
      "minLength": 1
    },
    "rollback_or_compensation_expectation": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "bound",
        "running",
        "staged",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "contract_version": {
      "type": "string",
      "minLength": 1
    },
    "issued_at": {
      "type": "string",
      "minLength": 1
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "notes_ref": {
      "type": "string",
      "minLength": 1
    }
  }
}
