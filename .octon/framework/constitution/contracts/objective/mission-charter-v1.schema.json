{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/objective/mission-charter-v1.schema.json",
  "title": "Octon Mission Charter v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "mission_id",
    "version",
    "mission_class",
    "owner_ref",
    "workspace_refs",
    "allowed_run_classes",
    "default_support_tiers",
    "autonomy_class",
    "protected_zones",
    "scope_refs",
    "approval_policy_ref",
    "quorum_policy_ref",
    "revocation_policy_ref",
    "continuity_root_ref",
    "retention_expectations",
    "retirement_triggers"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-mission-charter-v1"
    },
    "mission_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "mission_class": {
      "type": "string",
      "minLength": 1
    },
    "owner_ref": {
      "type": "string",
      "minLength": 1
    },
    "workspace_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_run_classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "default_support_tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "autonomy_class": {
      "type": "string",
      "minLength": 1
    },
    "protected_zones": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scope_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "approval_policy_ref": {
      "type": "string",
      "minLength": 1
    },
    "quorum_policy_ref": {
      "type": "string",
      "minLength": 1
    },
    "revocation_policy_ref": {
      "type": "string",
      "minLength": 1
    },
    "continuity_root_ref": {
      "type": "string",
      "minLength": 1
    },
    "retention_expectations": {
      "type": "object"
    },
    "retirement_triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}

