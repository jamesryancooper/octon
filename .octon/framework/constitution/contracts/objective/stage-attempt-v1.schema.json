{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/objective/stage-attempt-v1.schema.json",
  "title": "Octon Stage Attempt v1",
  "description": "Constitutional stage-attempt contract under a bound run root.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "stage_attempt_id",
    "stage_ref",
    "attempt_kind",
    "status",
    "objective_ref",
    "requested_capabilities",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "stage-attempt-v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "stage_attempt_id": {
      "type": "string",
      "minLength": 1
    },
    "stage_ref": {
      "type": "string",
      "minLength": 1
    },
    "attempt_kind": {
      "type": "string",
      "enum": [
        "initial",
        "retry",
        "stage-only",
        "rollback",
        "resume"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "running",
        "staged",
        "succeeded",
        "failed",
        "cancelled"
      ]
    },
    "objective_ref": {
      "type": "string",
      "minLength": 1
    },
    "requested_capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rollback_candidate": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
