{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/objective/stage-attempt-v1.schema.json",
  "title": "Octon Stage Attempt v1",
  "description": "Constitutional stage-attempt contract under a bound run root.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "stage_attempt_id",
    "stage_ref",
    "attempt_kind",
    "status",
    "objective_ref",
    "objective_slice",
    "entry_criteria",
    "exit_criteria",
    "requested_capabilities",
    "allowed_capabilities",
    "allowed_zones",
    "retry_class",
    "predecessor_refs",
    "successor_refs",
    "completion_status",
    "rollback_notes",
    "issued_by",
    "validated_by",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "stage-attempt-v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "stage_attempt_id": {
      "type": "string",
      "minLength": 1
    },
    "stage_ref": {
      "type": "string",
      "minLength": 1
    },
    "attempt_kind": {
      "type": "string",
      "enum": [
        "initial",
        "retry",
        "stage-only",
        "rollback",
        "resume"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "running",
        "staged",
        "succeeded",
        "failed",
        "cancelled"
      ]
    },
    "objective_ref": {
      "type": "string",
      "minLength": 1
    },
    "objective_slice": {
      "type": "string",
      "minLength": 1
    },
    "stage_name": {
      "type": "string",
      "minLength": 1
    },
    "entry_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "exit_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "done_when": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requested_capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_zones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "retry_class": {
      "type": "string",
      "enum": [
        "retryable_transient",
        "retryable_validation",
        "retryable_environment",
        "rollback_then_retry",
        "manual_review_required",
        "non_retryable_contract_violation",
        "contamination_reset_required"
      ]
    },
    "predecessor_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "successor_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checkpoint_expectation": {
      "type": "string",
      "enum": ["required", "optional", "none"]
    },
    "contamination_state": {
      "type": "string",
      "enum": ["clean", "suspected", "confirmed", "reset_required"]
    },
    "protected_zone_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rollback_posture_ref": {
      "type": "string",
      "minLength": 1
    },
    "completion_status": {
      "type": "string",
      "enum": [
        "criteria-pending",
        "criteria-met",
        "criteria-failed",
        "manual-review-required"
      ]
    },
    "rollback_candidate": {
      "type": "boolean"
    },
    "rollback_notes": {
      "type": "string",
      "minLength": 1
    },
    "issued_by": {
      "type": "string",
      "minLength": 1
    },
    "validated_by": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
