{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/assurance/review-finding-v1.schema.json",
  "title": "Octon Review Finding v1",
  "description": "Canonical retained finding record for evaluator or reviewer findings that require durable traceability beyond free-form comments.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "finding_id",
    "subject_ref",
    "review_ref",
    "category",
    "severity",
    "summary",
    "evidence_refs",
    "recorded_at"
  ],
  "properties": {
    "schema_version": {
      "const": "review-finding-v1"
    },
    "finding_id": {
      "type": "string",
      "minLength": 1
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "review_ref": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": [
        "note",
        "warning",
        "major",
        "critical"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "details": {
      "type": "string"
    },
    "blocking_recommended": {
      "type": "boolean"
    },
    "suggested_action": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recorded_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
