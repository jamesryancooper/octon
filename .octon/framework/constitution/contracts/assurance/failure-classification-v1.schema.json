{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/assurance/failure-classification-v1.schema.json",
  "title": "Octon Failure Classification v1",
  "description": "Canonical normalized recurring failure class used for proposal-gated hardening recommendations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "class_id",
    "failure_kind",
    "subject_ref",
    "recurrence_window",
    "signal_count",
    "summary",
    "source_evidence_refs",
    "recorded_at"
  ],
  "properties": {
    "schema_version": {
      "const": "failure-classification-v1"
    },
    "class_id": {
      "type": "string",
      "minLength": 1
    },
    "failure_kind": {
      "type": "string",
      "enum": [
        "validation",
        "policy",
        "runtime",
        "adapter",
        "workflow",
        "evidence",
        "governance"
      ]
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "recurrence_window": {
      "type": "string",
      "minLength": 1
    },
    "signal_count": {
      "type": "integer",
      "minimum": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "source_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recorded_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
