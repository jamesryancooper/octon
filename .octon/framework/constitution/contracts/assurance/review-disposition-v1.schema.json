{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/assurance/review-disposition-v1.schema.json",
  "title": "Octon Review Disposition v1",
  "description": "Canonical disposition record that turns retained findings into explicit run-control gating semantics.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "finding_id",
    "subject_ref",
    "disposition",
    "blocking",
    "rationale",
    "evidence_refs",
    "decided_at",
    "decided_by"
  ],
  "properties": {
    "schema_version": {
      "const": "review-disposition-v1"
    },
    "finding_id": {
      "type": "string",
      "minLength": 1
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "disposition": {
      "type": "string",
      "enum": [
        "accepted",
        "deferred",
        "blocked",
        "rejected",
        "backlog"
      ]
    },
    "blocking": {
      "type": "boolean"
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "follow_up_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decided_at": {
      "type": "string",
      "minLength": 1
    },
    "decided_by": {
      "type": "string",
      "minLength": 1
    }
  }
}
