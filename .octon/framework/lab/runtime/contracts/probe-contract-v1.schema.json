{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/lab/runtime/contracts/probe-contract-v1.schema.json",
  "title": "Octon Probe Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "probe_id", "purpose", "collection_mode", "expected_outputs"],
  "properties": {
    "schema_version": { "const": "probe-contract-v1" },
    "probe_id": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "collection_mode": { "type": "string", "enum": ["bounded", "sampling", "diagnostic"] },
    "expected_outputs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  }
}
