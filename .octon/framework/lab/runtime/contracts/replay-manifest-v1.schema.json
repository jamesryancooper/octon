{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/lab/runtime/contracts/replay-manifest-v1.schema.json",
  "title": "Octon Replay Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "entrypoint",
    "replay_payload_class",
    "receipt_refs",
    "checkpoint_refs",
    "reproduction_steps",
    "recorded_at"
  ],
  "properties": {
    "schema_version": {
      "const": "run-replay-manifest-v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "entrypoint": {
      "type": "string",
      "minLength": 1
    },
    "replay_payload_class": {
      "type": "string",
      "enum": [
        "git-inline",
        "external-immutable"
      ]
    },
    "receipt_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checkpoint_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "trace_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "external_index_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reproduction_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recorded_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
