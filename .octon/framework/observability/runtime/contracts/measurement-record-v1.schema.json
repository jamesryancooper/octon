{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/observability/runtime/contracts/measurement-record-v1.schema.json",
  "title": "Octon Measurement Record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "subject_kind",
    "subject_ref",
    "metric_id",
    "label",
    "value",
    "unit",
    "recorded_at"
  ],
  "properties": {
    "schema_version": {
      "const": "measurement-record-v1"
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "subject_kind": {
      "type": "string",
      "enum": [
        "run",
        "harness"
      ]
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "metric_id": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "value": {
      "type": "number"
    },
    "unit": {
      "type": "string",
      "minLength": 1
    },
    "method": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "recorded_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
