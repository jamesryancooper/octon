{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/observability/runtime/contracts/intervention-record-v1.schema.json",
  "title": "Octon Intervention Record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "subject_kind",
    "subject_ref",
    "kind",
    "disclosed",
    "recorded_at"
  ],
  "properties": {
    "schema_version": {
      "const": "intervention-record-v1"
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "subject_kind": {
      "type": "string",
      "enum": [
        "run",
        "harness"
      ]
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "disclosed": {
      "type": "boolean"
    },
    "execution_role_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "details": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recorded_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
