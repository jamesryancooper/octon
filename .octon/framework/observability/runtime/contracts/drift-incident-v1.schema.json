{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/observability/runtime/contracts/drift-incident-v1.schema.json",
  "title": "Octon Drift Incident v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "incident_id",
    "drift_class",
    "status",
    "summary",
    "evidence_refs",
    "recorded_at"
  ],
  "properties": {
    "schema_version": {
      "const": "drift-incident-v1"
    },
    "incident_id": {
      "type": "string",
      "minLength": 1
    },
    "drift_class": {
      "type": "string",
      "enum": [
        "documentation-drift",
        "generated-view-drift",
        "governance-drift",
        "support-target-drift",
        "runtime-disclosure-mismatch-drift"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "mitigated",
        "closed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "remediation_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recorded_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
