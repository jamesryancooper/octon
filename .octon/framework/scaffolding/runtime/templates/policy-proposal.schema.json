{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Policy Proposal Manifest",
  "description": "Schema for Octon policy proposal subtype manifests.",
  "type": "object",
  "required": ["schema_version", "policy_area", "change_type"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "policy-proposal-v1"
    },
    "policy_area": {
      "type": "string",
      "minLength": 1
    },
    "change_type": {
      "type": "string",
      "enum": ["new-policy", "policy-update", "policy-removal"]
    }
  },
  "additionalProperties": false
}
