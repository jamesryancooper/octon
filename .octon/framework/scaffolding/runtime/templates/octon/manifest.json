{
  "$schema": "../manifest.schema.json",
  "name": "octon",
  "description": "Base .octon/ template for all harnesses, including init objective packs.",
  "goal_alignment": "Enable reliable agent execution that is deterministic enough to trust, observable enough to debug, and flexible enough to evolve.",
  "inherits": null,
  "files": {
    "required": [
      "README.md",
      "AGENTS.md",
      "octon.yml",
      "framework/manifest.yml",
      "instance/manifest.yml"
    ],
    "directories": {
      "required": [
        "framework",
        "instance",
        "inputs",
        "state",
        "generated"
      ],
      "standard": [
        "framework/scaffolding/runtime/bootstrap",
        "framework/scaffolding/runtime/templates",
        "framework/capabilities/runtime/commands",
        "framework/orchestration/runtime/workflows",
        "instance/bootstrap",
        "instance/ingress",
        "instance/locality",
        "instance/locality/scopes",
        "instance/cognition",
        "instance/cognition/context/scopes",
        "instance/capabilities/runtime/commands",
        "instance/orchestration/missions",
        "instance/governance/policies",
        "instance/governance/contracts",
        "instance/agency/runtime",
        "instance/assurance/runtime",
        "state/continuity/repo",
        "state/continuity/scopes",
        "state/evidence",
        "state/evidence/decisions/scopes",
        "state/control",
        "state/control/extensions",
        "state/control/locality",
        "generated/effective/locality",
        "generated/proposals"
      ]
    }
  },
  "contents": {
    "README.md": "Super-root overview",
    "AGENTS.md": "Projected ingress surface; repo-root adapters must point to this file only",
    "octon.yml": "Root super-root manifest",
    "framework/manifest.yml": "Portable framework manifest",
    "instance/manifest.yml": "Repo instance manifest plus enabled overlay points",
    "instance/bootstrap/START.md": "Boot sequence and orientation",
    "instance/bootstrap/OBJECTIVE.md": "Workspace objective",
    "instance/bootstrap/scope.md": "Boundaries and responsibilities",
    "instance/bootstrap/conventions.md": "Style and formatting rules",
    "instance/bootstrap/catalog.md": "Index of commands and workflows",
    "instance/bootstrap/init.sh": "Repo-local super-root health check",
    "instance/locality/README.md": "Repo-local locality authority overview",
    "instance/locality/manifest.yml": "Repo-local locality manifest",
    "instance/locality/registry.yml": "Repo-local scope registry",
    "instance/locality/scopes/_scaffold/template/scope.yml": "Example scope manifest template",
    "instance/capabilities/runtime/commands/README.md": "Repo-native command capability surface",
    "instance/orchestration/missions/registry.yml": "Repo-native mission registry",
    "instance/ingress/AGENTS.md": "Canonical internal ingress",
    "state/continuity/README.md": "Canonical continuity subdomain overview",
    "state/control/locality/quarantine.yml": "Mutable locality quarantine state",
    "state/control/extensions/active.yml": "Actual active extension publication state",
    "state/control/extensions/quarantine.yml": "Extension quarantine state",
    "state/control/README.md": "Canonical control-state overview",
    "state/evidence/README.md": "Canonical retained evidence overview",
    "state/evidence/decisions/scopes/README.md": "Canonical scope decision-evidence root",
    "generated/effective/locality/scopes.effective.yml": "Compiled effective scope map",
    "generated/effective/locality/artifact-map.yml": "Compiled locality artifact provenance map",
    "generated/effective/locality/generation.lock.yml": "Compiled locality freshness receipt",
    "state/continuity/repo/log.md": "Append-only session history",
    "state/continuity/repo/tasks.json": "Structured task list with goal",
    "state/continuity/repo/entities.json": "Entity state tracking",
    "state/continuity/repo/next.md": "Immediate actionable steps",
    "state/continuity/scopes/README.md": "Scope continuity root; declared scopes get continuity scaffolds during locality publication",
