{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Migration Proposal Manifest",
  "description": "Schema for Octon migration proposal subtype manifests.",
  "type": "object",
  "required": ["schema_version", "change_profile", "release_state"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "migration-proposal-v1"
    },
    "change_profile": {
      "type": "string",
      "enum": ["atomic", "transitional"]
    },
    "release_state": {
      "type": "string",
      "enum": ["pre-1.0", "stable"]
    }
  },
  "additionalProperties": false
}
