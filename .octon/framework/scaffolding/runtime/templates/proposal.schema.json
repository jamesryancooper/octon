{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Proposal Manifest",
  "description": "Schema for standard-governed Octon proposal manifests.",
  "type": "object",
  "required": [
    "schema_version",
    "proposal_id",
    "title",
    "summary",
    "proposal_kind",
    "promotion_scope",
    "promotion_targets",
    "status",
    "lifecycle",
    "related_proposals"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "proposal-v1"
    },
    "proposal_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "proposal_kind": {
      "type": "string",
      "enum": ["design", "migration", "policy", "architecture"]
    },
    "promotion_scope": {
      "type": "string",
      "enum": ["octon-internal", "repo-local"]
    },
    "promotion_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "in-review", "accepted", "implemented", "rejected", "archived"]
    },
    "archive": {
      "type": "object",
      "required": [
        "archived_at",
        "archived_from_status",
        "disposition",
        "original_path",
        "promotion_evidence"
      ],
      "properties": {
        "archived_at": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "archived_from_status": {
          "type": "string",
          "enum": ["draft", "in-review", "accepted", "implemented", "rejected", "legacy-unknown"]
        },
        "disposition": {
          "type": "string",
          "enum": ["implemented", "rejected", "historical", "superseded"]
        },
        "original_path": {
          "type": "string",
          "minLength": 1
        },
        "promotion_evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "lifecycle": {
      "type": "object",
      "required": ["temporary", "exit_expectation"],
      "properties": {
        "temporary": {
          "type": "boolean",
          "const": true
        },
        "exit_expectation": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "related_proposals": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      }
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "archived"
          }
        }
      },
      "then": {
        "required": ["archive"]
      },
      "else": {
        "not": {
          "required": ["archive"]
        }
      }
    },
    {
      "not": {
        "required": ["exit_expectation"]
      }
    }
  ]
}
