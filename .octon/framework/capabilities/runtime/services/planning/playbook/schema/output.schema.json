{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/schemas/playbook/output.schema.json",
  "title": "PlaybookServiceOutput",
  "type": "object",
  "required": ["status", "playbook"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "error"]
    },
    "playbook": {
      "type": "object",
      "additionalProperties": true
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
