{
  "id": "flow-edge-live-run",
  "description": "Live run includes params and runtime metadata passthrough.",
  "request": {
    "config": {
      "flowName": "architecture_assessment",
      "canonicalPromptPath": "flow-assets/architecture_assessment/00-overview.md",
      "workflowManifestPath": "flow-assets/architecture_assessment/manifest.yaml",
      "workflowEntrypoint": "architecture-inventory"
    },
    "params": {
      "targetPath": "src"
    }
  },
  "expect": {
    "hasMetadataFields": ["flowName", "workflowManifestPath", "runnerEndpoint"],
    "hasKeys": ["result", "runId", "context_acquisition", "context_overhead_ratio", "metadata"],
    "contextAcquisitionRequired": [
      "file_reads",
      "search_queries",
      "commands",
      "subagent_spawns",
      "duration_ms"
    ],
    "overheadClass": "warn-tier"
  }
}
