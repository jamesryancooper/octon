{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/schemas/agent/output.schema.json",
  "title": "AgentServiceOutput",
  "type": "object",
  "required": ["status", "runId", "result", "context_acquisition", "context_overhead_ratio"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "partial", "error"]
    },
    "runId": { "type": "string" },
    "result": { "type": "object", "additionalProperties": true },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "checkpoint": {
      "type": "object",
      "additionalProperties": true
    },
    "context_acquisition": {
      "type": "object",
      "required": ["file_reads", "search_queries", "commands", "subagent_spawns", "duration_ms"],
      "properties": {
        "file_reads": { "type": "integer", "minimum": 0 },
        "search_queries": { "type": "integer", "minimum": 0 },
        "commands": { "type": "integer", "minimum": 0 },
        "subagent_spawns": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "context_overhead_ratio": {
      "type": "number",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
