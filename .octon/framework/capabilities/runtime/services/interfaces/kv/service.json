{
  "abi": "wasi-component@0.2",
  "capabilities_required": [
    "storage.local",
    "log.write"
  ],
  "category": "interfaces",
  "docs": {
    "help": "Use for durable state under .octon/state/control/engine/kv/. Keys are strings; values are UTF-8 strings in v1.",
    "summary": "Local key/value storage for Octon runtime state."
  },
  "entry": "service.wasm",
  "format_version": "service-manifest-v1",
  "integrity": {
    "wasm_sha256": "94f2e8768b89b21b96dd27a4796a2d761773321f3686b6b691aa2f5374c6c4ba"
  },
  "limits": {
    "max_concurrency": 4,
    "max_request_bytes": 1048576,
    "max_response_bytes": 1048576,
    "timeout_ms": 30000
  },
  "name": "kv",
  "ops": {
    "del": {
      "idempotent": true,
      "input_schema": {
        "additionalProperties": false,
        "properties": {
          "key": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "key"
        ],
        "type": "object"
      },
      "output_schema": {
        "additionalProperties": false,
        "properties": {
          "ok": {
            "type": "boolean"
          }
        },
        "required": [
          "ok"
        ],
        "type": "object"
      },
      "streaming": false
    },
    "get": {
      "idempotent": true,
      "input_schema": {
        "additionalProperties": false,
        "properties": {
          "key": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "key"
        ],
        "type": "object"
      },
      "output_schema": {
        "additionalProperties": false,
        "properties": {
          "value": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "value"
        ],
        "type": "object"
      },
      "streaming": false
    },
    "put": {
      "idempotent": true,
      "input_schema": {
        "additionalProperties": false,
        "properties": {
          "key": {
            "minLength": 1,
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        },
        "required": [
          "key",
          "value"
        ],
        "type": "object"
      },
      "output_schema": {
        "additionalProperties": false,
        "properties": {
          "ok": {
            "type": "boolean"
          }
        },
        "required": [
          "ok"
        ],
        "type": "object"
      },
      "streaming": false
    }
  },
  "version": "1.0.0"
}