{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/schemas/filesystem-interfaces/edge.v1.json",
  "title": "FilesystemGraphEdge",
  "type": "object",
  "required": ["src", "dst", "type"],
  "additionalProperties": false,
  "properties": {
    "src": { "type": "string", "minLength": 1 },
    "dst": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": ["CONTAINS", "REFERENCES", "MENTIONS_TOPIC", "DERIVED_FROM", "DEPENDS_ON"]
    },
    "snapshot_id": { "type": "string", "pattern": "^snap-[a-f0-9]{8,64}$" },
    "weight": { "type": "number" },
    "properties": { "type": "object", "additionalProperties": true }
  }
}
