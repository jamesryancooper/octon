{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/schemas/filesystem-watch/output.v1.json",
  "title": "FilesystemWatchOutput",
  "type": "object",
  "required": [
    "ok",
    "filesystem_watch_contract_version"
  ],
  "additionalProperties": false,
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "filesystem_watch_contract_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "cursor": {
      "type": "string"
    },
    "state_key": {
      "type": "string"
    },
    "scanned_at_ms": {
      "type": "integer",
      "minimum": 0
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "added": {
          "type": "integer",
          "minimum": 0
        },
        "removed": {
          "type": "integer",
          "minimum": 0
        },
        "changed": {
          "type": "integer",
          "minimum": 0
        },
        "total_files": {
          "type": "integer",
          "minimum": 0
        },
        "truncated": {
          "type": "boolean"
        },
        "sample_size": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "added",
        "changed",
        "removed",
        "sample_size",
        "total_files",
        "truncated"
      ]
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string"
          },
          "change": {
            "type": "string",
            "enum": [
              "added",
              "removed",
              "changed"
            ]
          }
        },
        "required": [
          "path",
          "change"
        ]
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "ok": {
            "const": true
          }
        }
      },
      "then": {
        "required": [
          "ok",
          "filesystem_watch_contract_version",
          "cursor",
          "state_key",
          "scanned_at_ms",
          "summary",
          "events"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "ok": {
            "const": false
          }
        }
      },
      "then": {
        "required": [
          "ok",
          "filesystem_watch_contract_version",
          "error"
        ]
      }
    }
  ]
}
