{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/schemas/promptkit/promptkit.outputs.v1.json",
  "title": "PromptKitOutputs",
  "description": "Output schema for PromptKit compiled prompts",
  "type": "object",
  "required": ["promptId", "content", "messages"],
  "properties": {
    "promptId": {
      "type": "string",
      "description": "Identifier of the compiled prompt"
    },
    "variant": {
      "type": "string",
      "description": "Variant that was used"
    },
    "content": {
      "type": "string",
      "description": "Full compiled prompt content"
    },
    "messages": {
      "type": "array",
      "description": "Prompt as message array",
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant"]
          },
          "content": { "type": "string" }
        }
      }
    },
    "tokens": {
      "type": "object",
      "description": "Token estimates",
      "properties": {
        "estimated": {
          "type": "integer",
          "description": "Estimated token count"
        },
        "model": {
          "type": "string",
          "description": "Model used for estimation"
        }
      }
    },
    "hash": {
      "type": "string",
      "description": "Content hash for determinism tracking"
    },
    "metadata": {
      "type": "object",
      "description": "Prompt metadata",
      "properties": {
        "version": { "type": "string" },
        "author": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "model": { "type": "string" },
        "temperature": { "type": "number" },
        "compiledAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}

