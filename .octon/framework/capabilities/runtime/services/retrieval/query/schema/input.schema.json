{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/schemas/query/query.inputs.v1.json",
  "title": "QueryInputs",
  "description": "Input schema for query ask/retrieve/explain operations",
  "type": "object",
  "required": ["command", "query", "index", "strategy"],
  "additionalProperties": false,
  "properties": {
    "command": {
      "type": "string",
      "enum": ["ask", "retrieve", "explain"],
      "description": "Query operation mode."
    },
    "query": {
      "type": "string",
      "minLength": 1,
      "description": "Natural-language query text."
    },
    "index": {
      "type": "object",
      "required": ["snapshot"],
      "additionalProperties": false,
      "properties": {
        "snapshot": {
          "type": "string",
          "minLength": 1,
          "description": "Snapshot ID or path for retrieval artifacts."
        }
      }
    },
    "strategy": {
      "type": "object",
      "required": ["use", "fuse", "top_k"],
      "additionalProperties": false,
      "properties": {
        "use": {
          "type": "array",
          "description": "Signals enabled for this request.",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["keyword", "semantic", "graph"]
          }
        },
        "required_signals": {
          "type": "array",
          "description": "Subset of `use` that must succeed or request fails.",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["keyword", "semantic", "graph"]
          }
        },
        "fuse": {
          "type": "string",
          "enum": ["rrf", "weighted"],
          "description": "Fusion strategy."
        },
        "route": {
          "type": "string",
          "enum": ["flat", "hierarchical", "graph_global"],
          "default": "flat",
          "description": "Optional advanced retrieval route."
        },
        "top_k": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200,
          "description": "Number of fused candidates to keep."
        },
        "weights": {
          "type": "object",
          "description": "Signal weights used when `fuse=weighted`.",
          "additionalProperties": false,
          "properties": {
            "keyword": { "type": "number", "minimum": 0 },
            "semantic": { "type": "number", "minimum": 0 },
            "graph": { "type": "number", "minimum": 0 }
          }
        }
      }
    },
    "filters": {
      "type": "object",
      "description": "Optional metadata filters to apply to candidates.",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "type": "number" },
          { "type": "boolean" },
          {
            "type": "array",
            "items": {
              "oneOf": [
                { "type": "string" },
                { "type": "number" },
                { "type": "boolean" }
              ]
            }
          }
        ]
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_excerpts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "default": 8,
          "description": "Maximum excerpts in evidence output."
        },
        "max_chars_per_excerpt": {
          "type": "integer",
          "minimum": 32,
          "maximum": 2000,
          "default": 320,
          "description": "Maximum chars per evidence excerpt."
        }
      }
    },
    "memory": {
      "type": "object",
      "description": "Optional memory-clue pre-retrieval configuration.",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "max_clues": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8,
          "default": 3
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "strategy": {
            "properties": {
              "route": {
                "enum": ["hierarchical", "graph_global"]
              }
            },
            "required": ["route"]
          }
        }
      },
      "then": {
        "properties": {
          "strategy": {
            "properties": {
              "use": {
                "contains": {
                  "const": "graph"
                }
              }
            }
          }
        }
      }
    }
  ]
}
