{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/schemas/retrieval-parse/input.schema.json",
  "title": "ParseServiceInput",
  "type": "object",
  "required": ["input"],
  "properties": {
    "input": {
      "type": "string",
      "minLength": 1
    },
    "outDir": {
      "type": "string",
      "default": "docs_out/parsed"
    },
    "includeAssets": {
      "type": "boolean",
      "default": true
    },
    "dryRun": {
      "type": "boolean",
      "default": false
    }
  },
  "additionalProperties": false
}
