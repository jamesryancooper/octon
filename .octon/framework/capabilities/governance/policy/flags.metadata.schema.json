{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/schemas/flags.metadata.schema.json",
  "title": "Octon Flags Metadata Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "flags"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "flags": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/flagMetadata"
      }
    }
  },
  "$defs": {
    "flagMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "flag_id",
        "owner",
        "created",
        "expires",
        "cleanup_by",
        "default",
        "description",
        "risk",
        "links"
      ],
      "properties": {
        "flag_id": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "created": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "expires": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "cleanup_by": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "default": {
          "type": "boolean"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "risk": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "links": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
