{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/run-lifecycle-transition-v1.schema.json",
  "title": "Octon Run Lifecycle Transition v1",
  "description": "Machine-readable request, decision, and provenance contract for one run lifecycle transition. The canonical run journal remains the transition authority; this record binds the transition attempt to journal heads, required control/evidence refs, and reconstruction provenance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "transition_id",
    "run_id",
    "actor",
    "operation_id",
    "current_state_ref",
    "requested_transition",
    "required_refs",
    "journal_head_before",
    "outcome",
    "journal_event_ref",
    "fail_closed_reason_codes",
    "state_rebuild_provenance",
    "replay_provenance",
    "disclosure_provenance",
    "control_evidence_boundary",
    "recorded_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "run-lifecycle-transition-v1"
    },
    "transition_id": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "run_id": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "actor": {
      "$ref": "#/$defs/actor"
    },
    "operation_id": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "current_state_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reconstruction_ref",
        "reconstructed_state",
        "runtime_state_ref",
        "runtime_state_match"
      ],
      "properties": {
        "reconstruction_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "reconstructed_state": {
          "$ref": "#/$defs/lifecycleState"
        },
        "runtime_state_ref": {
          "$ref": "#/$defs/nullableString"
        },
        "runtime_state_match": {
          "type": "boolean"
        },
        "drift_ref": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "requested_transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_state",
        "to_state",
        "transition_family"
      ],
      "properties": {
        "from_state": {
          "$ref": "#/$defs/lifecycleState"
        },
        "to_state": {
          "$ref": "#/$defs/lifecycleState"
        },
        "transition_family": {
          "type": "string",
          "enum": [
            "bind",
            "authorize",
            "start",
            "pause",
            "resume",
            "stage",
            "revoke",
            "fail",
            "rollback",
            "succeed",
            "deny",
            "close"
          ]
        },
        "effect_envelope_ref": {
          "$ref": "#/$defs/nullableString"
        },
        "transition_reason": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "required_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control_refs",
        "authority_refs",
        "rollback_refs",
        "context_refs",
        "support_refs",
        "effect_token_refs",
        "evidence_refs",
        "replay_refs",
        "disclosure_refs"
      ],
      "properties": {
        "control_refs": {
          "$ref": "#/$defs/refArray"
        },
        "authority_refs": {
          "$ref": "#/$defs/refArray"
        },
        "rollback_refs": {
          "$ref": "#/$defs/refArray"
        },
        "context_refs": {
          "$ref": "#/$defs/refArray"
        },
        "support_refs": {
          "$ref": "#/$defs/refArray"
        },
        "effect_token_refs": {
          "$ref": "#/$defs/refArray"
        },
        "evidence_refs": {
          "$ref": "#/$defs/refArray"
        },
        "replay_refs": {
          "$ref": "#/$defs/refArray"
        },
        "disclosure_refs": {
          "$ref": "#/$defs/refArray"
        }
      }
    },
    "journal_head_before": {
      "$ref": "#/$defs/eventRefOrNull"
    },
    "journal_head_after": {
      "$ref": "#/$defs/eventRefOrNull"
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "state_after"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "accepted",
            "rejected",
            "blocked",
            "failed-closed"
          ]
        },
        "state_after": {
          "$ref": "#/$defs/lifecycleState"
        },
        "outcome_ref": {
          "$ref": "#/$defs/nullableString"
        },
        "drift_ref": {
          "$ref": "#/$defs/nullableString"
        },
        "unappended_reason": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "journal_event_ref": {
      "$ref": "#/$defs/eventRefOrNull"
    },
    "fail_closed_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^FCR-[0-9]{3}$"
      },
      "uniqueItems": true
    },
    "state_rebuild_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reconstruction_ref",
        "source_event_refs",
        "side_artifact_refs"
      ],
      "properties": {
        "reconstruction_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "source_event_refs": {
          "$ref": "#/$defs/eventRefArray"
        },
        "side_artifact_refs": {
          "$ref": "#/$defs/refArray"
        },
        "runtime_state_materialization_ref": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "replay_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "replay_event_refs",
        "replay_pointer_refs",
        "live_replay_requires_fresh_authorization"
      ],
      "properties": {
        "replay_event_refs": {
          "$ref": "#/$defs/eventRefArray"
        },
        "replay_pointer_refs": {
          "$ref": "#/$defs/refArray"
        },
        "live_replay_requires_fresh_authorization": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "disclosure_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "disclosure_event_refs",
        "evidence_snapshot_refs",
        "run_card_refs"
      ],
      "properties": {
        "disclosure_event_refs": {
          "$ref": "#/$defs/eventRefArray"
        },
        "evidence_snapshot_refs": {
          "$ref": "#/$defs/refArray"
        },
        "run_card_refs": {
          "$ref": "#/$defs/refArray"
        }
      }
    },
    "control_evidence_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control_plane_authority",
        "evidence_plane_role",
        "generated_view_role"
      ],
      "properties": {
        "control_plane_authority": {
          "type": "string",
          "const": "state/control canonical run journal"
        },
        "evidence_plane_role": {
          "type": "string",
          "const": "retained evidence and closeout mirror only"
        },
        "generated_view_role": {
          "type": "string",
          "const": "derived-only non-authority"
        }
      }
    },
    "recorded_at": {
      "$ref": "#/$defs/nonEmptyString"
    }
  },
  "$defs": {
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor_class",
        "actor_ref"
      ],
      "properties": {
        "actor_class": {
          "type": "string",
          "enum": [
            "runtime",
            "authority-engine",
            "policy-engine",
            "validator",
            "operator",
            "model-adapter",
            "capability-adapter",
            "replay-service"
          ]
        },
        "actor_ref": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "eventRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "sequence",
        "event_hash",
        "event_type"
      ],
      "properties": {
        "event_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "event_hash": {
          "$ref": "#/$defs/hash"
        },
        "event_type": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "ledger_ref": {
          "$ref": "#/$defs/nullableString"
        },
        "manifest_ref": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "eventRefArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/eventRef"
      },
      "uniqueItems": true
    },
    "eventRefOrNull": {
      "oneOf": [
        {
          "$ref": "#/$defs/eventRef"
        },
        {
          "type": "null"
        }
      ]
    },
    "hash": {
      "type": "string",
      "pattern": "^sha256:[A-Fa-f0-9]{64}$"
    },
    "lifecycleState": {
      "type": "string",
      "enum": [
        "draft",
        "bound",
        "authorized",
        "running",
        "paused",
        "staged",
        "revoked",
        "failed",
        "rolled_back",
        "succeeded",
        "denied",
        "closed"
      ]
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nullableString": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "refArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": {
            "properties": {
              "decision": {
                "const": "accepted"
              }
            },
            "required": [
              "decision"
            ]
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "properties": {
          "journal_event_ref": {
            "$ref": "#/$defs/eventRef"
          },
          "journal_head_after": {
            "$ref": "#/$defs/eventRef"
          }
        },
        "required": [
          "journal_head_after"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "properties": {
              "decision": {
                "enum": [
                  "rejected",
                  "blocked",
                  "failed-closed"
                ]
              }
            },
            "required": [
              "decision"
            ]
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "properties": {
          "fail_closed_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "current_state_ref": {
            "properties": {
              "runtime_state_match": {
                "const": false
              }
            },
            "required": [
              "runtime_state_match"
            ]
          }
        },
        "required": [
          "current_state_ref"
        ]
      },
      "then": {
        "properties": {
          "current_state_ref": {
            "required": [
              "drift_ref"
            ],
            "properties": {
              "drift_ref": {
                "$ref": "#/$defs/nonEmptyString"
              }
            }
          },
          "outcome": {
            "properties": {
              "decision": {
                "enum": [
                  "blocked",
                  "failed-closed"
                ]
              }
            }
          }
        }
      }
    }
  ]
}
