{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/engine/runtime/spec/support-envelope-reconciliation-result-v1.schema.json",
  "title": "Octon Support Envelope Reconciliation Result v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "status",
    "generated_at",
    "non_authority_classification",
    "freshness",
    "source_refs",
    "source_digests",
    "tuples"
  ],
  "properties": {
    "schema_version": {
      "const": "support-envelope-reconciliation-result-v1"
    },
    "status": {
      "enum": ["reconciled", "failed"]
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "generation_id": {
      "type": "string",
      "minLength": 1
    },
    "non_authority_classification": {
      "const": "derived-runtime-handle"
    },
    "freshness": {
      "type": "object",
      "additionalProperties": true,
      "required": ["mode", "invalidation_conditions"],
      "properties": {
        "mode": {
          "enum": ["digest_bound"]
        },
        "invalidation_conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "allowed_consumers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_consumers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_digests": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "tuples": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "tuple_ref",
          "declared",
          "admitted",
          "proof",
          "route",
          "pack_route",
          "generated_matrix",
          "disclosure",
          "effective",
          "diagnostics"
        ],
        "properties": {
          "tuple_ref": {
            "type": "string",
            "minLength": 1
          },
          "declared": {
            "enum": ["live", "stage_only", "unsupported", "excluded", "unknown"]
          },
          "admitted": {
            "enum": ["live", "stage_only", "unadmitted", "unknown"]
          },
          "proof": {
            "enum": ["fresh", "stale", "missing", "insufficient"]
          },
          "route": {
            "enum": ["allow", "stage_only", "deny", "unknown"]
          },
          "pack_route": {
            "enum": ["allow", "stage_only", "deny", "mixed", "unknown"]
          },
          "generated_matrix": {
            "enum": ["supported", "not_supported", "unknown"]
          },
          "disclosure": {
            "enum": ["matches", "overclaims", "missing", "unknown"]
          },
          "effective": {
            "enum": ["live", "stage_only", "unsupported", "blocked"]
          },
          "diagnostics": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
