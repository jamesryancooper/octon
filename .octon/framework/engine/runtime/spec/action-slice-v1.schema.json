{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/action-slice-v1.schema.json",
  "title": "Action Slice v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "slice_ref",
    "intent_ref",
    "action_class",
    "target_ref",
    "rationale",
    "status",
    "predicted_acp",
    "planned_reversibility_class",
    "safe_interrupt_boundary_id",
    "boundary_class",
    "expected_blast_radius",
    "expected_budget_impact",
    "required_authorize_updates",
    "rollback_plan_ref",
    "compensation_plan_ref",
    "finalize_policy_ref",
    "earliest_start_at",
    "feedback_deadline_at",
    "default_on_silence"
  ],
  "properties": {
    "slice_ref": { "type": "object" },
    "intent_ref": { "type": "object" },
    "action_class": { "type": "string", "minLength": 1 },
    "target_ref": { "type": "object" },
    "rationale": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "predicted_acp": { "type": "string", "pattern": "^ACP-[0-4]$" },
    "planned_reversibility_class": { "type": "string", "enum": ["reversible", "compensable", "irreversible"] },
    "safe_interrupt_boundary_id": { "type": "string", "minLength": 1 },
    "boundary_class": { "type": "string", "minLength": 1 },
    "expected_blast_radius": { "type": "string", "minLength": 1 },
    "expected_budget_impact": { "type": "object" },
    "required_authorize_updates": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "rollback_plan_ref": { "type": ["string", "null"] },
    "compensation_plan_ref": { "type": ["string", "null"] },
    "finalize_policy_ref": { "type": ["string", "null"] },
    "earliest_start_at": { "type": "string", "minLength": 1 },
    "feedback_deadline_at": { "type": "string", "minLength": 1 },
    "default_on_silence": { "type": "string", "minLength": 1 }
  }
}
