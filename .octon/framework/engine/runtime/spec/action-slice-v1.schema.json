{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/action-slice-v1.schema.json",
  "title": "Action Slice v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "slice_id",
    "mission_id",
    "title",
    "action_class",
    "scope_ids",
    "predicted_acp",
    "reversibility_class",
    "safe_interrupt_boundary_class",
    "expected_blast_radius",
    "expected_externality_class",
    "executor_profile",
    "approval_required",
    "owner_attestation_required",
    "rationale",
    "created_at",
    "updated_at"
  ],
  "anyOf": [
    { "required": ["rollback_primitive"] },
    { "required": ["compensation_primitive"] }
  ],
  "properties": {
    "schema_version": { "const": "action-slice-v1" },
    "slice_id": { "type": "string", "minLength": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "action_class": { "type": "string", "minLength": 1 },
    "scope_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "predicted_acp": { "type": "string", "pattern": "^ACP-[0-4]$" },
    "reversibility_class": {
      "type": "string",
      "enum": ["reversible", "compensable", "irreversible"]
    },
    "rollback_primitive": { "type": "string", "minLength": 1 },
    "compensation_primitive": { "type": "string", "minLength": 1 },
    "safe_interrupt_boundary_class": {
      "type": "string",
      "enum": [
        "immediate",
        "task_boundary",
        "batch_boundary",
        "checkpoint_boundary",
        "rollout_boundary",
        "stage_boundary",
        "finalize_boundary"
      ]
    },
    "expected_blast_radius": { "type": "string", "minLength": 1 },
    "expected_externality_class": { "type": "string", "minLength": 1 },
    "executor_profile": { "type": "string", "minLength": 1 },
    "approval_required": { "type": "boolean" },
    "owner_attestation_required": { "type": "boolean" },
    "rationale": { "type": "string", "minLength": 1 },
    "earliest_start": { "type": "string", "minLength": 1 },
    "feedback_deadline": { "type": ["string", "null"] },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 }
  }
}
