{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/authorization-boundary-coverage-v1.schema.json",
  "title": "Octon Authorization Boundary Coverage v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "paths"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "authorization-boundary-coverage-v1"
    },
    "paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "path_id",
          "entrypoint",
          "side_effect_class",
          "authorize_execution_ref",
          "request_builder",
          "grant_artifact_ref",
          "receipt_artifact_ref"
        ],
        "properties": {
          "path_id": { "type": "string", "minLength": 1 },
          "entrypoint": { "type": "string", "minLength": 1 },
          "side_effect_class": { "type": "string", "minLength": 1 },
          "affected_root": { "type": "string", "minLength": 1 },
          "authorize_execution_ref": { "type": "string", "minLength": 1 },
          "request_builder": { "type": "string", "minLength": 1 },
          "grant_artifact_ref": { "type": "string", "minLength": 1 },
          "receipt_artifact_ref": { "type": "string", "minLength": 1 },
          "denial_reason_code": { "type": "string", "minLength": 1 },
          "negative_controls": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "tests": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
