{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/execution-receipt-v3.schema.json",
  "title": "Octon Execution Receipt v3",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "request_id",
    "grant_id",
    "target_id",
    "action_type",
    "path_type",
    "environment_class",
    "requested_capabilities",
    "granted_capabilities",
    "requested_capability_packs",
    "granted_capability_packs",
    "policy_mode_requested",
    "policy_mode_effective",
    "decision",
    "reason_codes",
    "workflow_mode",
    "execution_role_ref",
    "risk_materiality_ref",
    "support_target_tuple_ref",
    "rollback_plan_ref",
    "side_effects",
    "authorized_effects",
    "timestamps"
  ],
  "properties": {
    "schema_version": { "const": "execution-receipt-v3" },
    "request_id": { "type": "string", "minLength": 1 },
    "grant_id": { "type": "string", "minLength": 1 },
    "target_id": { "type": "string", "minLength": 1 },
    "action_type": { "type": "string", "minLength": 1 },
    "path_type": { "type": "string", "minLength": 1 },
    "environment_class": { "type": "string", "enum": ["development", "protected"] },
    "workflow_mode": { "type": "string", "enum": ["autonomous", "role-mediated", "human-only"] },
    "requested_capabilities": { "type": "array", "items": { "type": "string" } },
    "granted_capabilities": { "type": "array", "items": { "type": "string" } },
    "requested_capability_packs": { "type": "array", "items": { "type": "string" } },
    "granted_capability_packs": { "type": "array", "items": { "type": "string" } },
    "policy_mode_requested": { "type": "string", "minLength": 1 },
    "policy_mode_effective": { "type": "string", "minLength": 1 },
    "decision": { "type": "string", "enum": ["ALLOW", "STAGE_ONLY", "DENY", "ESCALATE"] },
    "reason_codes": { "type": "array", "items": { "type": "string" } },
    "execution_role_ref": { "type": "object" },
    "context_pack_ref": { "type": "string", "minLength": 1 },
    "risk_materiality_ref": { "type": "string", "minLength": 1 },
    "support_target_tuple_ref": { "type": "string", "minLength": 1 },
    "rollback_plan_ref": { "type": "string", "minLength": 1 },
    "context_evidence_required": { "type": "boolean" },
    "context_evidence_binding": { "$ref": "#/$defs/context_evidence_binding" },
    "browser_ui_record_refs": { "type": "array", "items": { "type": "string" } },
    "api_egress_record_refs": { "type": "array", "items": { "type": "string" } },
    "side_effects": { "type": "object" },
    "authorized_effects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "token_id",
          "token_type",
          "effect_kind",
          "scope_ref",
          "token_record_ref",
          "consumption_receipt_ref",
          "journal_event_refs"
        ],
        "properties": {
          "token_id": { "type": "string", "minLength": 1 },
          "token_type": { "type": "string", "minLength": 1 },
          "effect_kind": { "type": "string", "minLength": 1 },
          "scope_ref": { "type": "string", "minLength": 1 },
          "token_record_ref": { "type": "string", "minLength": 1 },
          "consumption_receipt_ref": { "type": "string", "minLength": 1 },
          "journal_event_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          }
        }
      }
    },
    "intent_ref": { "type": "object" },
    "evidence_links": { "type": "object" },
    "budget": { "type": "object" },
    "timestamps": {
      "type": "object",
      "required": ["started_at", "completed_at"],
      "properties": {
        "started_at": { "type": "string", "minLength": 1 },
        "completed_at": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^(sha256:)?[a-f0-9]{64}$"
    },
    "context_evidence_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_pack_ref",
        "context_pack_receipt_ref",
        "context_pack_sha256",
        "receipt_sha256",
        "builder_spec_ref",
        "builder_version",
        "verification_status",
        "freshness_status",
        "valid_until",
        "context_policy_ref",
        "model_visible_context_ref",
        "model_visible_context_sha256",
        "context_validity_state",
        "source_count",
        "failed_required_source_count",
        "subordinate_to_authorize_execution"
      ],
      "properties": {
        "context_pack_ref": { "type": "string", "minLength": 1 },
        "context_pack_receipt_ref": { "type": "string", "minLength": 1 },
        "context_pack_sha256": { "$ref": "#/$defs/sha256" },
        "receipt_sha256": { "$ref": "#/$defs/sha256" },
        "builder_spec_ref": {
          "type": "string",
          "const": ".octon/framework/engine/runtime/spec/context-pack-builder-v1.md"
        },
        "builder_version": { "type": "string", "const": "context-pack-builder-v1" },
        "verification_status": {
          "type": "string",
          "enum": ["valid", "missing", "stale", "invalid", "unverifiable"]
        },
        "freshness_status": {
          "type": "string",
          "enum": ["valid", "stale", "unverifiable"]
        },
        "valid_until": { "type": "string", "minLength": 1 },
        "context_policy_ref": { "type": "string", "minLength": 1 },
        "model_visible_context_ref": { "type": "string", "minLength": 1 },
        "model_visible_context_sha256": { "$ref": "#/$defs/sha256" },
        "context_validity_state": {
          "type": "string",
          "enum": ["valid", "stale", "invalidated", "rebuild_required", "unverifiable"]
        },
        "context_rebuild_ref": { "type": ["string", "null"] },
        "context_invalidation_ref": { "type": ["string", "null"] },
        "source_count": { "type": "integer", "minimum": 0 },
        "failed_required_source_count": { "type": "integer", "minimum": 0 },
        "subordinate_to_authorize_execution": { "const": true }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": { "const": "ALLOW" },
          "context_evidence_required": { "const": true }
        },
        "required": ["decision", "context_evidence_required"]
      },
      "then": {
        "required": ["context_pack_ref", "context_evidence_binding"],
        "properties": {
          "context_evidence_binding": {
            "properties": {
              "verification_status": { "const": "valid" },
              "freshness_status": { "const": "valid" },
              "context_validity_state": { "const": "valid" },
              "source_count": { "minimum": 1 },
              "failed_required_source_count": { "const": 0 },
              "subordinate_to_authorize_execution": { "const": true }
            }
          }
        }
      }
    }
  ]
}
