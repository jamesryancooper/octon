{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/material-side-effect-inventory-v1.schema.json",
  "title": "Octon Material Side-Effect Inventory v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "classes"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "material-side-effect-inventory-v1"
    },
    "classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "roots", "required_boundary"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "roots": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          },
          "examples": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "required_boundary": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "risk_tier": { "type": "string", "minLength": 1 },
          "material": { "type": "boolean" }
        }
      }
    }
  }
}
