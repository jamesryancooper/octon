{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/stewardship-epoch-v1.schema.json",
  "title": "Stewardship Epoch v1",
  "description": "Finite renewable operating window inside a Stewardship Program. No stewardship work may occur outside an active epoch.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "program_id",
    "epoch_id",
    "status",
    "start_at",
    "end_at",
    "review_deadline_at",
    "allowed_mission_classes",
    "allowed_action_classes",
    "max_missions",
    "max_runs",
    "budget_profile",
    "circuit_breaker_profile",
    "event_triggers",
    "idle_threshold",
    "closeout_requirements",
    "renewal_eligibility",
    "epoch_replaces_mission_control_lease",
    "material_execution_allowed"
  ],
  "properties": {
    "schema_version": { "const": "stewardship-epoch-v1" },
    "program_id": { "type": "string", "minLength": 1 },
    "epoch_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "active", "idle", "paused", "closing", "closed", "renewed", "revoked", "escalated"] },
    "start_at": { "type": "string", "minLength": 1 },
    "end_at": { "type": "string", "minLength": 1 },
    "review_deadline_at": { "type": "string", "minLength": 1 },
    "allowed_mission_classes": { "type": "array" },
    "allowed_action_classes": { "type": "array" },
    "max_missions": { "type": "integer", "minimum": 1 },
    "max_runs": { "type": "integer", "minimum": 1 },
    "budget_profile": { "type": "string", "minLength": 1 },
    "circuit_breaker_profile": { "type": "string", "minLength": 1 },
    "event_triggers": { "type": "array" },
    "idle_threshold": { "type": "string", "minLength": 1 },
    "closeout_requirements": { "type": "array" },
    "renewal_eligibility": { "type": "object" },
    "epoch_replaces_mission_control_lease": { "const": false },
    "material_execution_allowed": { "const": false }
  }
}
