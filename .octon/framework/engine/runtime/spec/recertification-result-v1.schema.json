{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/engine/runtime/spec/recertification-result-v1.schema.json",
  "title": "Octon Recertification Result v1",
  "description": "A retained result validating post-promotion coherence or failing closed with evidence.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "recertification_id",
    "promotion_ref",
    "status",
    "authority_placement",
    "root_boundaries",
    "runtime_authorization_coverage",
    "support_target_claims",
    "capability_pack_routes",
    "connector_admissions",
    "generated_effective_handles",
    "context_pack_behavior",
    "run_lifecycle",
    "evidence_completeness",
    "rollback_posture",
    "operator_read_model_non_authority",
    "documentation_runtime_consistency",
    "validator_health",
    "proof_plane_completeness",
    "evidence_refs",
    "failure_blocks_closure"
  ],
  "properties": {
    "schema_version": { "const": "recertification-result-v1" },
    "recertification_id": { "type": "string", "minLength": 1 },
    "promotion_ref": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["passed", "failed_closed", "blocked", "not_run"] },
    "authority_placement": { "type": "string" },
    "root_boundaries": { "type": "string" },
    "runtime_authorization_coverage": { "type": "string" },
    "support_target_claims": { "type": "string" },
    "capability_pack_routes": { "type": "string" },
    "connector_admissions": { "type": "string" },
    "generated_effective_handles": { "type": "string" },
    "context_pack_behavior": { "type": "string" },
    "run_lifecycle": { "type": "string" },
    "evidence_completeness": { "type": "string" },
    "rollback_posture": { "type": "string" },
    "operator_read_model_non_authority": { "type": "string" },
    "documentation_runtime_consistency": { "type": "string" },
    "validator_health": { "type": "string" },
    "proof_plane_completeness": { "type": "string" },
    "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "failure_blocks_closure": { "const": true }
  }
}
