{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/autonomy-budget-v1.schema.json",
  "title": "Autonomy Budget v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "mission_id",
    "state",
    "window",
    "counters",
    "threshold_profile_ref",
    "last_state_change_at",
    "applied_mode_adjustments",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "const": "autonomy-budget-v1" },
    "mission_id": { "type": "string", "minLength": 1 },
    "state": { "type": "string", "enum": ["healthy", "warning", "exhausted"] },
    "window": { "type": "string", "minLength": 1 },
    "threshold_profile_ref": { "type": "string", "minLength": 1 },
    "last_state_change_at": { "type": "string", "minLength": 1 },
    "applied_mode_adjustments": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "updated_at": { "type": "string", "minLength": 1 },
    "counters": { "type": "object" }
  }
}
