{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/mission-control-lease-v1.schema.json",
  "title": "Mission Control Lease v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "mission_id",
    "lease_id",
    "state",
    "issued_by",
    "issued_at",
    "expires_at",
    "continuation_scope",
    "last_reviewed_at"
  ],
  "properties": {
    "schema_version": { "const": "mission-control-lease-v1" },
    "mission_id": { "type": "string", "minLength": 1 },
    "lease_id": { "type": "string", "minLength": 1 },
    "state": { "type": "string", "enum": ["active", "paused", "revoked", "expired"] },
    "issued_by": { "type": "string", "minLength": 1 },
    "issued_at": { "type": "string", "minLength": 1 },
    "expires_at": { "type": "string", "minLength": 1 },
    "continuation_scope": {
      "type": "object",
      "required": [
        "summary",
        "allowed_execution_postures",
        "max_concurrent_runs",
        "allowed_action_classes",
        "default_safing_subset"
      ],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "allowed_execution_postures": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "max_concurrent_runs": { "type": "integer", "minimum": 0 },
        "allowed_action_classes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "default_safing_subset": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "revocation_reason": { "type": ["string", "null"] },
    "last_reviewed_at": { "type": "string", "minLength": 1 }
  }
}
