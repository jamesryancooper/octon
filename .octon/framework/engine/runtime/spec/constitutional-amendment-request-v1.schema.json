{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/engine/runtime/spec/constitutional-amendment-request-v1.schema.json",
  "title": "Octon Constitutional Amendment Request v1",
  "description": "Elevated request class for changes affecting Octon's constitutional kernel, authority hierarchy, root placement, authorization boundary, evidence obligations, support model, generated/effective trust, fail-closed posture, material-effect model, proposal standards, or self-evolution approval rules.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "request_id",
    "candidate_ref",
    "affected_authority_refs",
    "invariant_impact",
    "compatibility_impact",
    "runtime_impact",
    "support_target_impact",
    "rollback_or_retirement_plan",
    "lab_evidence_refs",
    "simulation_evidence_refs",
    "migration_cutover_plan_ref",
    "human_or_quorum_approval_required",
    "approval_refs",
    "promotion_receipt_ref",
    "post_promotion_recertification_required",
    "amendment_request_authorizes_change"
  ],
  "properties": {
    "schema_version": { "const": "constitutional-amendment-request-v1" },
    "request_id": { "type": "string", "minLength": 1 },
    "candidate_ref": { "type": "string", "minLength": 1 },
    "affected_authority_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "invariant_impact": { "type": "string", "minLength": 1 },
    "compatibility_impact": { "type": "string", "minLength": 1 },
    "runtime_impact": { "type": "string", "minLength": 1 },
    "support_target_impact": { "type": "string", "minLength": 1 },
    "rollback_or_retirement_plan": { "type": "string", "minLength": 1 },
    "lab_evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "simulation_evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "migration_cutover_plan_ref": { "type": "string", "minLength": 1 },
    "human_or_quorum_approval_required": { "const": true },
    "approval_refs": { "type": "array", "items": { "type": "string" } },
    "promotion_receipt_ref": { "type": ["string", "null"] },
    "post_promotion_recertification_required": { "const": true },
    "amendment_request_authorizes_change": { "const": false }
  }
}
