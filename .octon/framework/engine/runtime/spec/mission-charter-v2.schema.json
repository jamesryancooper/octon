{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/mission-charter-v2.schema.json",
  "title": "Octon Mission Charter v2",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "mission_id",
    "title",
    "summary",
    "status",
    "mission_class",
    "owner_ref",
    "created_at",
    "risk_ceiling",
    "allowed_action_classes",
    "default_safing_subset",
    "default_schedule_hint",
    "default_overlap_policy",
    "scope_ids",
    "success_criteria",
    "failure_conditions"
  ],
  "properties": {
    "schema_version": { "const": "octon-mission-v2" },
    "mission_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "status": { "type": "string", "minLength": 1 },
    "mission_class": {
      "type": "string",
      "enum": ["observe", "campaign", "reconcile", "maintenance", "migration", "incident", "destructive"]
    },
    "owner_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "risk_ceiling": { "type": "string", "pattern": "^ACP-[0-4]$" },
    "allowed_action_classes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "default_safing_subset": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "default_schedule_hint": { "type": "string", "minLength": 1 },
    "default_overlap_policy": { "type": "string", "minLength": 1 },
    "scope_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "success_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "failure_conditions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "notes_ref": { "type": "string", "minLength": 1 },
    "active_run_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "objective_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_charter_ref",
        "execution_unit",
        "run_control_root",
        "mission_role",
        "mission_required_for"
      ],
      "properties": {
        "workspace_charter_ref": { "type": "string", "minLength": 1 },
        "execution_unit": { "type": "string", "enum": ["run-contract"] },
        "run_control_root": { "type": "string", "minLength": 1 },
        "mission_role": { "type": "string", "enum": ["continuity-container"] },
        "mission_required_for": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "transitional_execution_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mission_only_execution",
        "stage_attempt_root",
        "retirement_gate",
        "profile_selection_receipt_ref"
      ],
      "properties": {
        "mission_only_execution": { "type": "string", "enum": ["transitional", "retired"] },
        "stage_attempt_root": { "type": "string", "minLength": 1 },
        "retirement_gate": { "type": "string", "minLength": 1 },
        "profile_selection_receipt_ref": { "type": "string", "minLength": 1 }
      }
    }
  }
}
