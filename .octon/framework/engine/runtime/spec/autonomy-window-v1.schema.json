{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/autonomy-window-v1.schema.json",
  "title": "Autonomy Window v1",
  "description": "Operator-visible control wrapper that summarizes and enforces lower-level mission controls without granting execution authority.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "mission_id",
    "engagement_id",
    "state",
    "mission_charter_ref",
    "mission_control_lease_ref",
    "autonomy_budget_ref",
    "circuit_breakers_ref",
    "allowed_execution_postures",
    "allowed_action_classes",
    "max_concurrent_runs",
    "context_freshness_policy",
    "connector_posture",
    "stop_conditions",
    "review_cadence",
    "closeout_rules_ref",
    "authority_boundary",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "const": "autonomy-window-v1" },
    "mission_id": { "type": "string", "minLength": 1 },
    "engagement_id": { "type": "string", "minLength": 1 },
    "state": {
      "type": "string",
      "enum": ["active", "paused", "revoked", "blocked", "closed"]
    },
    "mission_charter_ref": { "type": "string", "minLength": 1 },
    "mission_control_lease_ref": { "type": "string", "minLength": 1 },
    "autonomy_budget_ref": { "type": "string", "minLength": 1 },
    "circuit_breakers_ref": { "type": "string", "minLength": 1 },
    "allowed_execution_postures": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "allowed_action_classes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "max_concurrent_runs": { "type": "integer", "minimum": 1, "maximum": 1 },
    "context_freshness_policy": {
      "type": "object",
      "required": [
        "project_profile_required",
        "work_package_required",
        "context_pack_required_per_run",
        "stale_posture_route"
      ],
      "properties": {
        "project_profile_required": { "type": "boolean" },
        "work_package_required": { "type": "boolean" },
        "context_pack_required_per_run": { "type": "boolean" },
        "stale_posture_route": { "type": "string", "minLength": 1 }
      }
    },
    "connector_posture": {
      "type": "object",
      "required": [
        "connector_posture_ref",
        "connector_admission_policy_ref",
        "live_effectful_broad_connectors"
      ],
      "properties": {
        "connector_posture_ref": { "type": "string", "minLength": 1 },
        "connector_admission_policy_ref": { "type": "string", "minLength": 1 },
        "live_effectful_broad_connectors": {
          "type": "string",
          "enum": ["deferred", "denied"]
        }
      }
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "review_cadence": {
      "type": "object",
      "required": ["review_required", "last_reviewed_at"],
      "properties": {
        "review_required": { "type": "boolean" },
        "last_reviewed_at": { "type": "string", "minLength": 1 }
      }
    },
    "closeout_rules_ref": { "type": "string", "minLength": 1 },
    "authority_boundary": {
      "type": "object",
      "required": [
        "autonomy_window_authorizes_execution",
        "run_contract_required",
        "execution_authorization_required"
      ],
      "properties": {
        "autonomy_window_authorizes_execution": { "const": false },
        "run_contract_required": { "const": true },
        "execution_authorization_required": { "const": true }
      }
    },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 }
  }
}
