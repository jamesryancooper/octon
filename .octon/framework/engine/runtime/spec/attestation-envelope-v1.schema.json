{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/engine/runtime/spec/attestation-envelope-v1.schema.json",
  "title": "Attestation Envelope v1",
  "description": "A structured claim from a trust domain. It may become evidence after local acceptance but never authorizes execution by itself.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "attestation_id",
    "issuer",
    "subject",
    "claim_type",
    "scope",
    "valid_from",
    "expires_at",
    "evidence_refs",
    "revocation_refs",
    "verification_method",
    "trust_domain_id",
    "verification_status",
    "freshness_status",
    "revocation_status",
    "local_acceptance_evidence_refs",
    "consumer_verification_requirements",
    "local_acceptance",
    "attestation_authorizes_execution",
    "attestation_replaces_local_authority",
    "attestation_widens_support_claims"
  ],
  "properties": {
    "schema_version": { "const": "attestation-envelope-v1" },
    "attestation_id": { "type": "string", "minLength": 1 },
    "issuer": { "type": "string", "minLength": 1 },
    "subject": { "type": "string", "minLength": 1 },
    "claim_type": { "type": "string", "minLength": 1 },
    "scope": { "type": "string", "minLength": 1 },
    "valid_from": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "revocation_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "verification_method": { "type": "string", "minLength": 1 },
    "signature": { "type": ["string", "null"] },
    "trust_domain_id": { "type": "string", "minLength": 1 },
    "verification_status": { "type": "string", "enum": ["unverified", "verified", "failed"] },
    "freshness_status": { "type": "string", "enum": ["fresh", "stale", "expired"] },
    "revocation_status": { "type": "string", "enum": ["not_checked", "unrevoked", "revoked", "unknown"] },
    "checked_at": { "type": ["string", "null"], "format": "date-time" },
    "local_acceptance_evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "unsigned_acceptance_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unsigned_allowed", "route_when_unsigned"],
      "properties": {
        "unsigned_allowed": { "type": "boolean" },
        "route_when_unsigned": { "type": "string", "enum": ["deny", "local-evidence-only"] }
      }
    },
    "consumer_verification_requirements": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "local_acceptance": { "type": "string", "enum": ["unreviewed", "verified", "accepted", "rejected", "revoked", "expired"] },
    "attestation_authorizes_execution": { "const": false },
    "attestation_replaces_local_authority": { "const": false },
    "attestation_widens_support_claims": { "const": false },
    "updated_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "local_acceptance": { "const": "accepted" } },
        "required": ["local_acceptance"]
      },
      "then": {
        "properties": {
          "verification_status": { "const": "verified" },
          "freshness_status": { "const": "fresh" },
          "revocation_status": { "const": "unrevoked" }
        }
      }
    }
  ]
}
