{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/execution-request-v3.schema.json",
  "title": "Octon Execution Request v3",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "request_id",
    "caller_path",
    "action_type",
    "target_id",
    "requested_capabilities",
    "requested_capability_packs",
    "side_effect_flags",
    "risk_tier",
    "workflow_mode",
    "execution_role_ref",
    "risk_materiality_ref",
    "support_target_tuple_ref",
    "rollback_plan_ref"
  ],
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "caller_path": { "type": "string", "minLength": 1 },
    "action_type": { "type": "string", "minLength": 1 },
    "target_id": { "type": "string", "minLength": 1 },
    "requested_capabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "side_effect_flags": { "type": "object" },
    "risk_tier": { "type": "string", "minLength": 1 },
    "workflow_mode": {
      "type": "string",
      "enum": ["autonomous", "role-mediated", "human-only"]
    },
    "requested_capability_packs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "requested_effect_kinds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "execution_role_ref": { "type": "object" },
    "context_pack_ref": { "type": "string", "minLength": 1 },
    "risk_materiality_ref": { "type": "string", "minLength": 1 },
    "support_target_tuple_ref": { "type": "string", "minLength": 1 },
    "rollback_plan_ref": { "type": "string", "minLength": 1 },
    "context_evidence_binding": { "$ref": "#/$defs/context_evidence_binding" },
    "requires_context_evidence": { "type": "boolean" },
    "boundary_sensitive": { "type": "boolean" },
    "browser_ui_execution_ref": { "type": ["string", "null"] },
    "api_egress_ref": { "type": ["string", "null"] },
    "intent_ref": { "type": "object" },
    "review_requirements": { "type": "object" },
    "scope_constraints": { "type": "object" },
    "policy_mode_requested": { "type": "string" },
    "autonomy_context": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "mission_ref",
        "slice_ref",
        "intent_ref",
        "mission_class",
        "oversight_mode",
        "execution_posture",
        "reversibility_class",
        "boundary_id"
      ],
      "properties": {
        "mission_ref": { "type": "object" },
        "slice_ref": { "type": "object" },
        "intent_ref": { "type": "object" },
        "mission_class": { "type": "string", "minLength": 1 },
        "oversight_mode": { "type": "string", "enum": ["silent", "notify", "feedback_window", "proceed_on_silence", "approval_required"] },
        "execution_posture": { "type": "string", "enum": ["one_shot", "continuous", "interruptible_scheduled"] },
        "reversibility_class": { "type": "string", "enum": ["reversible", "compensable", "irreversible"] },
        "boundary_id": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^(sha256:)?[a-f0-9]{64}$"
    },
    "context_evidence_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_pack_ref",
        "context_pack_receipt_ref",
        "context_pack_sha256",
        "receipt_sha256",
        "builder_spec_ref",
        "builder_version",
        "verification_status",
        "freshness_status",
        "valid_until",
        "context_policy_ref",
        "model_visible_context_ref",
        "model_visible_context_sha256",
        "context_validity_state",
        "source_count",
        "failed_required_source_count",
        "subordinate_to_authorize_execution"
      ],
      "properties": {
        "context_pack_ref": { "type": "string", "minLength": 1 },
        "context_pack_receipt_ref": { "type": "string", "minLength": 1 },
        "context_pack_sha256": { "$ref": "#/$defs/sha256" },
        "receipt_sha256": { "$ref": "#/$defs/sha256" },
        "builder_spec_ref": {
          "type": "string",
          "const": ".octon/framework/engine/runtime/spec/context-pack-builder-v1.md"
        },
        "builder_version": { "type": "string", "const": "context-pack-builder-v1" },
        "verification_status": {
          "type": "string",
          "enum": ["valid", "missing", "stale", "invalid", "unverifiable"]
        },
        "freshness_status": {
          "type": "string",
          "enum": ["valid", "stale", "unverifiable"]
        },
        "valid_until": { "type": "string", "minLength": 1 },
        "context_policy_ref": { "type": "string", "minLength": 1 },
        "model_visible_context_ref": { "type": "string", "minLength": 1 },
        "model_visible_context_sha256": { "$ref": "#/$defs/sha256" },
        "context_validity_state": {
          "type": "string",
          "enum": ["valid", "stale", "invalidated", "rebuild_required", "unverifiable"]
        },
        "context_rebuild_ref": { "type": ["string", "null"] },
        "context_invalidation_ref": { "type": ["string", "null"] },
        "source_count": { "type": "integer", "minimum": 0 },
        "failed_required_source_count": { "type": "integer", "minimum": 0 },
        "subordinate_to_authorize_execution": { "const": true }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "workflow_mode": { "const": "autonomous" }
        },
        "required": ["workflow_mode"]
      },
      "then": {
        "required": ["autonomy_context"]
      }
    },
    {
      "if": {
        "anyOf": [
          {
            "properties": {
              "requires_context_evidence": { "const": true }
            },
            "required": ["requires_context_evidence"]
          },
          {
            "properties": {
              "boundary_sensitive": { "const": true }
            },
            "required": ["boundary_sensitive"]
          },
          {
            "properties": {
              "risk_tier": { "enum": ["consequential", "boundary-sensitive"] }
            },
            "required": ["risk_tier"]
          }
        ]
      },
      "then": {
        "required": ["context_pack_ref", "context_evidence_binding"],
        "properties": {
          "context_evidence_binding": {
            "properties": {
              "verification_status": { "const": "valid" },
              "freshness_status": { "const": "valid" },
              "context_validity_state": { "const": "valid" },
              "source_count": { "minimum": 1 },
              "failed_required_source_count": { "const": 0 },
              "subordinate_to_authorize_execution": { "const": true }
            }
          }
        }
      }
    }
  ]
}
