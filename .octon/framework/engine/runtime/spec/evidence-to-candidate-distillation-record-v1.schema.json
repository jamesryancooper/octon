{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/engine/runtime/spec/evidence-to-candidate-distillation-record-v1.schema.json",
  "title": "Octon Evidence-to-Candidate Distillation Record v1",
  "description": "A non-authoritative record showing how retained evidence suggested an Evolution Candidate.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "distillation_id",
    "evidence_source_roots",
    "evidence_refs",
    "issue_pattern",
    "excluded_evidence",
    "confidence",
    "risk_posture",
    "origin",
    "candidate_refs",
    "distillation_authorizes_promotion",
    "non_authority_statement"
  ],
  "properties": {
    "schema_version": { "const": "evidence-to-candidate-distillation-record-v1" },
    "distillation_id": { "type": "string", "minLength": 1 },
    "evidence_source_roots": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "issue_pattern": { "type": "string", "minLength": 1 },
    "excluded_evidence": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
    "risk_posture": { "type": "string", "minLength": 1 },
    "origin": { "type": "string", "enum": ["human", "runtime", "model_suggested"] },
    "candidate_refs": { "type": "array", "items": { "type": "string" } },
    "distillation_authorizes_promotion": { "const": false },
    "non_authority_statement": { "type": "string", "minLength": 1 }
  }
}
