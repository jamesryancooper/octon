{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/plan-revision-record-v1.schema.json",
  "title": "Plan Revision Record v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "revision_id",
    "plan_id",
    "previous_plan_digest",
    "new_plan_digest",
    "reason",
    "evidence_refs",
    "validation_outcome",
    "actor_ref",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "plan-revision-record-v1" },
    "revision_id": { "type": "string", "minLength": 1 },
    "plan_id": { "type": "string", "minLength": 1 },
    "previous_plan_digest": { "$ref": "#/$defs/sha256" },
    "new_plan_digest": { "$ref": "#/$defs/sha256" },
    "reason": { "type": "string", "minLength": 1 },
    "evidence_refs": { "$ref": "#/$defs/ref_list" },
    "validation_outcome": {
      "type": "string",
      "enum": ["pass", "fail", "blocked", "stage_only", "escalate"]
    },
    "actor_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^(sha256:)?[a-f0-9]{64}$"
    },
    "ref_list": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
