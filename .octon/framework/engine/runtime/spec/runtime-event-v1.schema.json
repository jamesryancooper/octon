{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/runtime-event-v1.schema.json",
  "title": "Octon Runtime Event v1",
  "description": "Compatibility-only engine-local runtime event envelope. Dot-named runtime-event-v1 events must be normalized into canonical hyphenated run-event-v2 events before they enter the canonical control journal, reconstruction path, replay path, or closeout evidence snapshots.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "run_id",
    "timestamp"
  ],
  "properties": {
    "schema_version": { "const": "runtime-event-v1" },
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": {
      "type": "string",
      "enum": [
        "run.started",
        "run.context_pack_requested",
        "run.context_pack_built",
        "run.context_pack_bound",
        "run.context_pack_rejected",
        "run.context_pack_compacted",
        "run.context_pack_invalidated",
        "run.context_pack_rebuilt",
        "run.grant_issued",
        "run.grant_denied",
        "effect_token.requested",
        "effect_token.minted",
        "effect_token.denied",
        "effect_token.consumption_requested",
        "effect_token.consumed",
        "effect_token.rejected",
        "effect_token.expired",
        "effect_token.revoked",
        "approval.requested",
        "approval.resolved",
        "capability.invoked",
        "checkpoint.created",
        "evidence.persisted",
        "replay.available",
        "rollback.started",
        "rollback.completed",
        "intervention.recorded",
        "disclosure.ready",
        "run.closed"
      ]
    },
    "run_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "minLength": 1 },
    "canonical_event_type": {
      "type": ["string", "null"],
      "enum": [
        "run-created",
        "run-bound",
        "context-pack-requested",
        "context-pack-built",
        "context-pack-bound",
        "context-pack-rejected",
        "context-pack-compacted",
        "context-pack-invalidated",
        "context-pack-rebuilt",
        "authority-granted",
        "authority-denied",
        "approval-requested",
        "approval-granted",
        "approval-denied",
        "capability-invoked",
        "checkpoint-created",
        "evidence-snapshot-created",
        "replay-materialized",
        "rollback-started",
        "rollback-completed",
        "operator-intervention-recorded",
        "run-card-published",
        "disclosure-published",
        "run-closed",
        null
      ]
    },
    "alias_status": {
      "type": "string",
      "const": "compatibility-alias-only"
    },
    "normalization_rule_ref": {
      "type": ["string", "null"]
    },
    "request_id": { "type": ["string", "null"] },
    "grant_id": { "type": ["string", "null"] },
    "token_id": { "type": ["string", "null"] },
    "effect_kind": { "type": ["string", "null"] },
    "scope_ref": { "type": ["string", "null"] },
    "pack_ref": { "type": ["string", "null"] },
    "context_pack_ref": { "type": ["string", "null"] },
    "receipt_ref": { "type": ["string", "null"] },
    "context_pack_receipt_ref": { "type": ["string", "null"] },
    "model_visible_context_ref": { "type": ["string", "null"] },
    "model_visible_hash": { "type": ["string", "null"] },
    "model_visible_context_sha256": { "type": ["string", "null"] },
    "policy_ref": { "type": ["string", "null"] },
    "context_policy_ref": { "type": ["string", "null"] },
    "invalidation_reason": { "type": ["string", "null"] },
    "rebuild_ref": { "type": ["string", "null"] },
    "context_rebuild_ref": { "type": ["string", "null"] },
    "compaction_ref": { "type": ["string", "null"] },
    "context_compaction_ref": { "type": ["string", "null"] },
    "omissions_ref": { "type": ["string", "null"] },
    "redactions_ref": { "type": ["string", "null"] },
    "omissions_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "redactions_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "auth_request_ref": { "type": ["string", "null"] },
    "auth_grant_ref": { "type": ["string", "null"] },
    "auth_receipt_ref": { "type": ["string", "null"] },
    "token_record_ref": { "type": ["string", "null"] },
    "consumption_receipt_ref": { "type": ["string", "null"] },
    "refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "details": { "type": "object" }
  }
}
