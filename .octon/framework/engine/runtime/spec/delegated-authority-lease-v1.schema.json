{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/engine/runtime/spec/delegated-authority-lease-v1.schema.json",
  "title": "Delegated Authority Lease v1",
  "description": "Bounded, expiring, revocable cross-domain permission. The lease is an input to local authorization, not a replacement for it.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "lease_id",
    "grantor",
    "grantee",
    "scope",
    "action_classes",
    "support_tuple",
    "support_target_ref",
    "capability_packs",
    "capability_pack_registry_ref",
    "valid_from",
    "expires_at",
    "status",
    "lifecycle_state",
    "lifecycle_transitions",
    "activation_requirements",
    "renewal_policy",
    "revocation_conditions",
    "revocation_authority_refs",
    "evidence_obligations",
    "approval_refs",
    "rollback_or_compensation_posture",
    "local_authorization_requirements",
    "lease_consumption_route",
    "governance_exclusions_ref",
    "lease_authorizes_execution",
    "permanent_authority",
    "run_contract_bypass_allowed",
    "execution_authorization_bypass_allowed",
    "support_claim_widening_allowed",
    "capability_widening_allowed"
  ],
  "properties": {
    "schema_version": { "const": "delegated-authority-lease-v1" },
    "lease_id": { "type": "string", "minLength": 1 },
    "grantor": { "type": "string", "minLength": 1 },
    "grantee": { "type": "string", "minLength": 1 },
    "scope": { "type": "string", "minLength": 1 },
    "action_classes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "support_tuple": { "type": "string", "minLength": 1 },
    "support_target_ref": { "type": "string", "minLength": 1 },
    "capability_packs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "capability_pack_registry_ref": { "type": "string", "minLength": 1 },
    "valid_from": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "revoked_at": { "type": ["string", "null"], "format": "date-time" },
    "revocation_ref": { "type": ["string", "null"] },
    "revocation_conditions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "revocation_authority_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "evidence_obligations": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "approval_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "rollback_or_compensation_posture": { "type": "string", "minLength": 1 },
    "local_authorization_requirements": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "status": { "type": "string", "enum": ["proposed", "active", "revoked", "expired", "denied", "stage_only"] },
    "lifecycle_state": { "type": "string", "enum": ["proposed", "approved_inactive", "active", "revoked", "expired", "denied", "stage_only"] },
    "lifecycle_transitions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "activation_requirements": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "renewal_policy": { "type": "string", "minLength": 1 },
    "lease_consumption_route": { "type": "string", "enum": ["local-authorization-input-only"] },
    "governance_exclusions_ref": { "type": "string", "minLength": 1 },
    "lease_authorizes_execution": { "const": false },
    "permanent_authority": { "const": false },
    "run_contract_bypass_allowed": { "const": false },
    "execution_authorization_bypass_allowed": { "const": false },
    "support_claim_widening_allowed": { "const": false },
    "capability_widening_allowed": { "const": false },
    "updated_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
