{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/engine/runtime/spec/promotion-receipt-v1.schema.json",
  "title": "Octon Self-Evolution Promotion Receipt v1",
  "description": "A v5 retained receipt for proposal-to-promotion attempts and outcomes. This complements the constitutional promotion receipt contract.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "receipt_id",
    "promotion_id",
    "proposal_ref",
    "status",
    "source_refs",
    "target_refs",
    "authority_basis_refs",
    "policy_refs",
    "evidence_refs",
    "rollback_or_retirement_posture_ref",
    "recertification_request_ref",
    "generated_projection_refresh_refs",
    "receipt_authorizes_future_change"
  ],
  "properties": {
    "schema_version": { "const": "self-evolution-promotion-receipt-v1" },
    "receipt_id": { "type": "string", "minLength": 1 },
    "promotion_id": { "type": "string", "minLength": 1 },
    "proposal_ref": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["applied", "blocked", "rejected", "stage_only", "requires_decision"] },
    "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "target_refs": { "type": "array", "items": { "type": "string" } },
    "authority_basis_refs": { "type": "array", "items": { "type": "string" } },
    "policy_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "rollback_or_retirement_posture_ref": { "type": "string", "minLength": 1 },
    "recertification_request_ref": { "type": "string", "minLength": 1 },
    "generated_projection_refresh_refs": { "type": "array", "items": { "type": "string" } },
    "receipt_authorizes_future_change": { "const": false }
  }
}
