{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/policy-receipt-v2.schema.json",
  "title": "Octon ACP Policy Receipt v2",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_id",
    "timestamp",
    "decision",
    "effective_acp",
    "reason_codes",
    "reason_details",
    "remediation",
    "instruction_layers",
    "context_acquisition",
    "context_overhead_ratio",
    "workflow_mode"
  ],
  "properties": {
    "schema_version": { "const": "policy-receipt-v2" },
    "run_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "minLength": 1 },
    "decision": { "type": "string", "enum": ["ALLOW", "STAGE_ONLY", "DENY", "ESCALATE"] },
    "effective_acp": { "type": "string", "pattern": "^ACP-[0-4]$" },
    "reason_codes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "reason_details": { "type": "array" },
    "remediation": { "type": "string", "minLength": 1 },
    "workflow_mode": { "type": "string", "enum": ["autonomous", "role-mediated", "human-only"] },
    "mission_ref": { "type": ["object", "null"] },
    "slice_ref": { "type": ["object", "null"] },
    "oversight_mode": { "type": ["string", "null"] },
    "execution_posture": { "type": ["string", "null"] },
    "reversibility_class": { "type": ["string", "null"] },
    "boundary_id": { "type": ["string", "null"] },
    "rollback_handle": { "type": ["string", "null"] },
    "compensation_handle": { "type": ["string", "null"] },
    "recovery_window": { "type": ["string", "null"] },
    "autonomy_budget_state": { "type": ["string", "null"] },
    "breaker_state": { "type": ["string", "null"] },
    "intent_ref": { "type": "object" },
    "instruction_layers": { "type": "array", "minItems": 1 },
    "context_acquisition": { "type": "object" },
    "context_overhead_ratio": { "type": "number", "minimum": 0 }
  }
}
