{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/authorized-effect-token-v2.schema.json",
  "title": "Octon Authorized Effect Token v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "token_id",
    "token_type",
    "effect_kind",
    "run_id",
    "request_id",
    "grant_id",
    "decision_artifact_ref",
    "authority_grant_bundle_ref",
    "run_control_root",
    "run_evidence_root",
    "lifecycle_state_ref",
    "route_id",
    "runtime_effective_route_bundle_ref",
    "runtime_effective_route_bundle_sha256",
    "runtime_effective_route_generation_id",
    "runtime_effective_freshness_mode",
    "runtime_effective_publication_receipt_ref",
    "runtime_effective_non_authority_classification",
    "support_target_tuple_ref",
    "support_claim_effect",
    "support_route",
    "allowed_capability_packs",
    "scope_ref",
    "scope_envelope",
    "rollback_posture_ref",
    "approval_grant_refs",
    "exception_lease_refs",
    "budget_ref",
    "budget_rule_id",
    "egress_ref",
    "egress_route",
    "issued_at",
    "single_use",
    "issuer_ref",
    "revocation_refs",
    "token_record_ref",
    "token_digest"
  ],
  "properties": {
    "schema_version": {
      "const": "authorized-effect-token-v2"
    },
    "token_id": { "type": "string", "minLength": 1 },
    "token_type": { "type": "string", "minLength": 1 },
    "effect_kind": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "grant_id": { "type": "string", "minLength": 1 },
    "decision_artifact_ref": { "type": ["string", "null"] },
    "authority_grant_bundle_ref": { "type": ["string", "null"] },
    "run_control_root": { "type": "string", "minLength": 1 },
    "run_evidence_root": { "type": "string", "minLength": 1 },
    "lifecycle_state_ref": { "type": "string", "minLength": 1 },
    "route_id": { "type": ["string", "null"] },
    "runtime_effective_route_bundle_ref": { "type": ["string", "null"] },
    "runtime_effective_route_bundle_sha256": {
      "type": ["string", "null"],
      "pattern": "^(sha256:)?[A-Fa-f0-9]{64}$|^runtime-route-bundle-publication-bypass$"
    },
    "runtime_effective_route_generation_id": { "type": ["string", "null"] },
    "runtime_effective_freshness_mode": { "type": ["string", "null"] },
    "runtime_effective_publication_receipt_ref": { "type": ["string", "null"] },
    "runtime_effective_non_authority_classification": { "type": ["string", "null"] },
    "support_target_tuple_ref": { "type": ["string", "null"] },
    "support_claim_effect": { "type": ["string", "null"] },
    "support_route": { "type": ["string", "null"] },
    "allowed_capability_packs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "scope_ref": { "type": "string", "minLength": 1 },
    "scope_envelope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "read": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "write": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "executor_profile": { "type": ["string", "null"] },
        "locality_scope": { "type": ["string", "null"] }
      }
    },
    "rollback_plan_ref": { "type": ["string", "null"] },
    "rollback_posture_ref": { "type": ["string", "null"] },
    "approval_request_ref": { "type": ["string", "null"] },
    "approval_grant_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "exception_lease_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "budget_ref": { "type": ["string", "null"] },
    "budget_rule_id": { "type": ["string", "null"] },
    "egress_ref": { "type": ["string", "null"] },
    "egress_route": { "type": ["string", "null"] },
    "issued_at": { "type": "string", "minLength": 1 },
    "expires_at": { "type": ["string", "null"] },
    "single_use": { "type": "boolean" },
    "issuer_ref": { "type": "string", "minLength": 1 },
    "revocation_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "token_record_ref": { "type": "string", "minLength": 1 },
    "journal_ref": { "type": ["string", "null"] },
    "token_digest": {
      "type": "string",
      "pattern": "^sha256:[A-Fa-f0-9]{64}$"
    }
  }
}
