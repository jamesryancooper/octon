{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/subscriptions-v1.schema.json",
  "title": "Mission Subscriptions v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "mission_id",
    "owners",
    "watchers",
    "digest_recipients",
    "alert_recipients",
    "routing_policy_ref",
    "last_routing_evaluation_at"
  ],
  "properties": {
    "schema_version": { "const": "subscriptions-v1" },
    "mission_id": { "type": "string", "minLength": 1 },
    "owners": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "watchers": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "digest_recipients": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "alert_recipients": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "routing_policy_ref": { "type": "string", "minLength": 1 },
    "last_routing_evaluation_at": { "type": "string", "minLength": 1 }
  }
}
