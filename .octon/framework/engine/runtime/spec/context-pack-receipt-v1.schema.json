{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/context-pack-receipt-v1.schema.json",
  "title": "Octon Context Pack Receipt v1",
  "description": "Deterministic receipt proving context pack assembly, source freshness, source verification, and request binding before authorization.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "context_pack_id",
    "context_pack_ref",
    "context_pack_sha256",
    "run_id",
    "request_id",
    "builder_spec_ref",
    "builder_version",
    "context_policy_ref",
    "model_visible_context_sha256",
    "model_visible_context_ref",
    "source_manifest_ref",
    "omissions_ref",
    "redactions_ref",
    "invalidation_events_ref",
    "built_at",
    "freshness",
    "validity_state",
    "invalidation_state",
    "verification_status",
    "authority_boundary",
    "request_binding",
    "source_summary",
    "sources",
    "omissions",
    "failure_policy"
  ],
  "properties": {
    "schema_version": { "const": "context-pack-receipt-v1" },
    "receipt_id": { "type": "string", "minLength": 1 },
    "context_pack_id": { "type": "string", "minLength": 1 },
    "context_pack_ref": { "type": "string", "minLength": 1 },
    "context_pack_sha256": { "$ref": "#/$defs/sha256" },
    "run_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "builder_spec_ref": {
      "type": "string",
      "const": ".octon/framework/engine/runtime/spec/context-pack-builder-v1.md"
    },
    "builder_version": { "type": "string", "const": "context-pack-builder-v1" },
    "context_policy_ref": { "type": "string", "minLength": 1 },
    "model_visible_context_sha256": { "$ref": "#/$defs/sha256" },
    "model_visible_context_ref": { "type": "string", "minLength": 1 },
    "source_manifest_ref": { "type": "string", "minLength": 1 },
    "omissions_ref": { "type": "string", "minLength": 1 },
    "redactions_ref": { "type": "string", "minLength": 1 },
    "invalidation_events_ref": { "type": "string", "minLength": 1 },
    "built_at": { "type": "string", "minLength": 1 },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generated_at", "valid_until", "freshness_status"],
      "properties": {
        "generated_at": { "type": "string", "minLength": 1 },
        "valid_until": { "type": "string", "minLength": 1 },
        "freshness_status": {
          "type": "string",
          "enum": ["valid", "stale", "unverifiable"]
        }
      }
    },
    "verification_status": {
      "type": "string",
      "enum": ["valid", "missing", "stale", "invalid", "unverifiable"]
    },
    "validity_state": {
      "type": "string",
      "enum": ["valid", "stale", "invalidated", "rebuild_required", "unverifiable"]
    },
    "invalidation_state": {
      "type": "string",
      "enum": ["not_invalidated", "invalidated", "unverifiable"]
    },
    "rebuild_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "compaction_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "replay_reconstruction_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "replay_ref": { "type": "string", "minLength": 1 },
    "authorization_binding_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authorize_execution_ref", "subordinate_to_authorize_execution"],
      "properties": {
        "authorize_execution_ref": { "type": "string", "minLength": 1 },
        "subordinate_to_authorize_execution": { "const": true }
      }
    },
    "request_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "target_id",
        "action_type",
        "workflow_mode",
        "risk_tier",
        "support_target_tuple_ref",
        "requires_context_evidence"
      ],
      "properties": {
        "request_id": { "type": "string", "minLength": 1 },
        "target_id": { "type": "string", "minLength": 1 },
        "action_type": { "type": "string", "minLength": 1 },
        "workflow_mode": {
          "type": "string",
          "enum": ["autonomous", "role-mediated", "human-only"]
        },
        "risk_tier": { "type": "string", "minLength": 1 },
        "support_target_tuple_ref": { "type": "string", "minLength": 1 },
        "requires_context_evidence": { "type": "boolean" },
        "boundary_sensitive": { "type": "boolean" },
        "consequential": { "type": "boolean" }
      }
    },
    "source_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_source_count",
        "evidence_source_count",
        "derived_source_count",
        "non_authoritative_source_count",
        "required_source_count",
        "failed_required_source_count"
      ],
      "properties": {
        "authority_source_count": { "type": "integer", "minimum": 0 },
        "evidence_source_count": { "type": "integer", "minimum": 0 },
        "derived_source_count": { "type": "integer", "minimum": 0 },
        "non_authoritative_source_count": { "type": "integer", "minimum": 0 },
        "required_source_count": { "type": "integer", "minimum": 0 },
        "failed_required_source_count": { "type": "integer", "minimum": 0 }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source_evidence" }
    },
    "omissions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_ref", "reason", "required"],
        "properties": {
          "source_ref": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" }
        }
      }
    },
    "failure_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_required_context_route",
        "stale_required_context_route",
        "invalid_required_context_route",
        "unverifiable_required_context_route"
      ],
      "properties": {
        "missing_required_context_route": { "$ref": "#/$defs/fail_closed_route" },
        "stale_required_context_route": { "$ref": "#/$defs/fail_closed_route" },
        "invalid_required_context_route": { "$ref": "#/$defs/fail_closed_route" },
        "unverifiable_required_context_route": { "$ref": "#/$defs/fail_closed_route" },
        "reason_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "builder_notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^(sha256:)?[a-f0-9]{64}$"
    },
    "nullable_sha256": {
      "oneOf": [
        { "$ref": "#/$defs/sha256" },
        { "type": "null" }
      ]
    },
    "source_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref",
        "source_kind",
        "authority_label",
        "required",
        "sha256",
        "verification_status",
        "freshness_status"
      ],
      "properties": {
        "source_ref": { "type": "string", "minLength": 1 },
        "source_kind": {
          "type": "string",
          "enum": [
            "constitutional-kernel",
            "governance-declaration",
            "run-authority",
            "mission-authority",
            "support-target",
            "capability-or-adapter",
            "risk-materiality",
            "rollback",
            "instruction-layer",
            "policy-receipt",
            "worktree",
            "runtime-effective-handle",
            "retained-evidence",
            "generated-effective-handle",
            "derived",
            "non-authoritative",
            "non-authoritative-input"
          ]
        },
        "authority_label": {
          "type": "string",
          "enum": ["authoritative", "derived", "non_authoritative"]
        },
        "required": { "type": "boolean" },
        "sha256": { "$ref": "#/$defs/nullable_sha256" },
        "verification_status": {
          "type": "string",
          "enum": ["valid", "missing", "stale", "invalid", "unverifiable"]
        },
        "freshness_status": {
          "type": "string",
          "enum": ["valid", "stale", "not_applicable", "unverifiable"]
        },
        "resolved_at": { "type": ["string", "null"], "minLength": 1 },
        "evidence_ref": { "type": ["string", "null"], "minLength": 1 }
      }
    },
    "fail_closed_route": {
      "type": "string",
      "enum": ["DENY", "STAGE_ONLY", "ESCALATE"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "verification_status": { "const": "valid" }
        },
        "required": ["verification_status"]
      },
      "then": {
        "properties": {
          "source_summary": {
            "properties": {
              "failed_required_source_count": { "const": 0 }
            }
          },
          "freshness": {
            "properties": {
              "freshness_status": { "const": "valid" }
            }
          }
        }
      }
    }
  ]
}
