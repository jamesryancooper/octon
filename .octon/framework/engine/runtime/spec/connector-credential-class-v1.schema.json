{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/connector-credential-class-v1.schema.json",
  "title": "Connector Credential Class v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "credential_class", "storage_posture", "scope", "redaction_policy_ref", "credential_use_authorizes_execution"],
  "properties": {
    "schema_version": { "const": "connector-credential-class-v1" },
    "credential_class": { "type": "string", "minLength": 1 },
    "storage_posture": { "type": "string", "minLength": 1 },
    "scope": { "type": "array", "items": { "type": "string" } },
    "redaction_policy_ref": { "type": "string", "minLength": 1 },
    "human_approval_required": { "type": "boolean" },
    "retained_evidence_required": { "const": true },
    "credential_use_authorizes_execution": { "const": false }
  }
}
