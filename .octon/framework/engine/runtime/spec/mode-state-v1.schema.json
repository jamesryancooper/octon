{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/mode-state-v1.schema.json",
  "title": "Mode State v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "mission_id",
    "oversight_mode",
    "execution_posture",
    "safety_state",
    "phase",
    "active_run_ref",
    "current_slice_ref",
    "next_safe_interrupt_boundary_id",
    "effective_scenario_resolution_ref",
    "autonomy_burn_state",
    "breaker_state",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "const": "mode-state-v1" },
    "mission_id": { "type": "string", "minLength": 1 },
    "oversight_mode": { "type": "string", "enum": ["silent", "notify", "feedback_window", "proceed_on_silence", "approval_required"] },
    "execution_posture": { "type": "string", "enum": ["one_shot", "continuous", "interruptible_scheduled"] },
    "safety_state": { "type": "string", "enum": ["active", "paused", "degraded", "safe", "break_glass"] },
    "phase": { "type": "string", "enum": ["planning", "staging", "promoting", "running", "recovering", "finalizing", "closed"] },
    "active_run_ref": { "type": ["object", "null"] },
    "current_slice_ref": { "type": ["object", "null"] },
    "next_safe_interrupt_boundary_id": { "type": ["string", "null"] },
    "effective_scenario_resolution_ref": { "type": ["string", "null"] },
    "autonomy_burn_state": { "type": "string", "enum": ["healthy", "warning", "exhausted"] },
    "breaker_state": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 }
  }
}
