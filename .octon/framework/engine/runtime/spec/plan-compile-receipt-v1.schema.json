{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/plan-compile-receipt-v1.schema.json",
  "title": "Plan Compile Receipt v1",
  "description": "Retained evidence that one ready PlanNode compiled to candidates or requests. This receipt is not an authorization grant.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "receipt_id",
    "plan_id",
    "node_id",
    "source_plan_digest",
    "mission_digest",
    "action_slice_candidate_ref",
    "evidence_requirements",
    "rollback_or_compensation_ref",
    "validation_result",
    "compiler_version",
    "authority_boundary",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "plan-compile-receipt-v1" },
    "receipt_id": { "type": "string", "minLength": 1 },
    "plan_id": { "type": "string", "minLength": 1 },
    "node_id": { "type": "string", "minLength": 1 },
    "source_plan_digest": { "$ref": "#/$defs/sha256" },
    "mission_digest": { "$ref": "#/$defs/sha256" },
    "action_slice_candidate_ref": { "type": "string", "minLength": 1 },
    "run_contract_draft_ref": { "type": "string", "minLength": 1 },
    "context_pack_request_ref": { "type": "string", "minLength": 1 },
    "authorization_request_ref": { "type": "string", "minLength": 1 },
    "evidence_requirements": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "rollback_or_compensation_ref": { "type": "string", "minLength": 1 },
    "validation_result": {
      "type": "string",
      "enum": ["pass", "fail", "blocked", "stage_only", "escalate"]
    },
    "compiler_version": { "type": "string", "minLength": 1 },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "compile_receipt_authorizes_execution",
        "authorization_request_is_grant",
        "run_contract_required",
        "context_pack_required",
        "execution_authorization_required"
      ],
      "properties": {
        "compile_receipt_authorizes_execution": { "const": false },
        "authorization_request_is_grant": { "const": false },
        "run_contract_required": { "const": true },
        "context_pack_required": { "const": true },
        "execution_authorization_required": { "const": true }
      }
    },
    "created_at": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^(sha256:)?[a-f0-9]{64}$"
    }
  }
}
