{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/mission-plan-v1.schema.json",
  "title": "Mission Plan v1",
  "description": "Mission-bound planning control state. A MissionPlan is not execution authority.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "plan_id",
    "mission_id",
    "mission_ref",
    "mission_digest",
    "workspace_charter_ref",
    "owner_ref",
    "status",
    "risk_ceiling",
    "allowed_action_classes",
    "support_target_tuple_refs",
    "scope_ids",
    "success_criteria_refs",
    "failure_condition_refs",
    "planning_budget",
    "decomposition_depth_budget",
    "rolling_wave_window",
    "index_refs",
    "compiled_run_refs",
    "evidence_root_ref",
    "authority_boundary",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "const": "mission-plan-v1" },
    "plan_id": { "type": "string", "minLength": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "mission_ref": { "type": "string", "minLength": 1 },
    "mission_digest": { "$ref": "#/$defs/sha256" },
    "workspace_charter_ref": { "type": "string", "minLength": 1 },
    "owner_ref": { "type": "string", "minLength": 1 },
    "orchestrator_ref": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": [
        "plan-candidate",
        "mission-bound",
        "partially-decomposed",
        "readiness-checked",
        "change-package-candidates",
        "compiled-run-contracts",
        "evidence-updated",
        "blocked",
        "stale",
        "closed",
        "superseded",
        "retired"
      ]
    },
    "risk_ceiling": { "type": "string", "pattern": "^ACP-[0-4]$" },
    "allowed_action_classes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "support_target_tuple_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "scope_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "success_criteria_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "failure_condition_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "planning_budget": { "$ref": "#/$defs/planning_budget" },
    "decomposition_depth_budget": {
      "type": "integer",
      "minimum": 1,
      "maximum": 8
    },
    "rolling_wave_window": { "$ref": "#/$defs/rolling_wave_window" },
    "index_refs": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "compiled_run_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_root_ref": { "type": "string", "minLength": 1 },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mission_plan_authorizes_execution",
        "run_contract_required",
        "context_pack_required_before_authorization",
        "execution_authorization_required",
        "generated_views_authoritative"
      ],
      "properties": {
        "mission_plan_authorizes_execution": { "const": false },
        "run_contract_required": { "const": true },
        "context_pack_required_before_authorization": { "const": true },
        "execution_authorization_required": { "const": true },
        "generated_views_authoritative": { "const": false }
      }
    },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^(sha256:)?[a-f0-9]{64}$"
    },
    "planning_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_children_per_node",
        "max_open_decompositions_per_branch",
        "max_initial_executable_leaves",
        "max_revisions_without_execution_evidence"
      ],
      "properties": {
        "max_children_per_node": { "type": "integer", "minimum": 1 },
        "max_open_decompositions_per_branch": { "type": "integer", "minimum": 1 },
        "max_initial_executable_leaves": { "type": "integer", "minimum": 1 },
        "max_revisions_without_execution_evidence": { "type": "integer", "minimum": 0 }
      }
    },
    "rolling_wave_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "near_term_only"],
      "properties": {
        "mode": { "type": "string", "enum": ["near-term", "blocking-only", "disabled"] },
        "near_term_only": { "type": "boolean" },
        "window_description": { "type": "string", "minLength": 1 }
      }
    }
  }
}
