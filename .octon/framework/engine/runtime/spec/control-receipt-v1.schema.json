{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/control-receipt-v1.schema.json",
  "title": "Control Receipt v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "receipt_id",
    "mission_id",
    "control_event_kind",
    "subject_ref",
    "applied_by",
    "applied_at",
    "prior_state_ref",
    "new_state_ref",
    "reason_codes",
    "policy_refs",
    "affected_paths"
  ],
  "properties": {
    "schema_version": { "const": "control-receipt-v1" },
    "receipt_id": { "type": "string", "minLength": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "control_event_kind": {
      "type": "string",
      "enum": [
        "directive_applied",
        "authorize_update_applied",
        "lease_changed",
        "schedule_changed",
        "breaker_tripped",
        "breaker_reset",
        "safing_changed",
        "break_glass_activated",
        "break_glass_cleared",
        "mission_seed",
        "mission_close"
      ]
    },
    "subject_ref": { "type": "object" },
    "applied_by": { "type": "string", "minLength": 1 },
    "applied_at": { "type": "string", "minLength": 1 },
    "prior_state_ref": { "type": ["string", "null"] },
    "new_state_ref": { "type": ["string", "null"] },
    "reason": { "type": ["string", "null"] },
    "reason_codes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "policy_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "affected_paths": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "linked_run_id": { "type": ["string", "null"] },
    "linked_directive_refs": { "type": "array", "items": { "type": "string" } },
    "linked_authorize_update_refs": { "type": "array", "items": { "type": "string" } },
    "supersedes_receipt_id": { "type": ["string", "null"] }
  }
}
