{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/engine/runtime/spec/evolution-ledger-v1.schema.json",
  "title": "Octon Evolution Ledger v1",
  "description": "Append-only index of self-evolution lineage. It does not replace proposal manifests, ADRs, run evidence, lab evidence, promotion receipts, retained validation evidence, or recertification evidence.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "ledger_id",
    "role",
    "program_refs",
    "candidate_refs",
    "distillation_refs",
    "simulation_refs",
    "lab_gate_refs",
    "proposal_refs",
    "decision_request_refs",
    "constitutional_amendment_request_refs",
    "promotion_refs",
    "rollback_refs",
    "retirement_refs",
    "recertification_refs",
    "durable_learning_refs",
    "ledger_replaces_source_truth"
  ],
  "properties": {
    "schema_version": { "const": "evolution-ledger-v1" },
    "ledger_id": { "type": "string", "minLength": 1 },
    "role": { "const": "index-and-rollup-not-source-truth" },
    "program_refs": { "type": "array", "items": { "type": "string" } },
    "candidate_refs": { "type": "array", "items": { "type": "string" } },
    "distillation_refs": { "type": "array", "items": { "type": "string" } },
    "simulation_refs": { "type": "array", "items": { "type": "string" } },
    "lab_gate_refs": { "type": "array", "items": { "type": "string" } },
    "proposal_refs": { "type": "array", "items": { "type": "string" } },
    "decision_request_refs": { "type": "array", "items": { "type": "string" } },
    "constitutional_amendment_request_refs": { "type": "array", "items": { "type": "string" } },
    "promotion_refs": { "type": "array", "items": { "type": "string" } },
    "rollback_refs": { "type": "array", "items": { "type": "string" } },
    "retirement_refs": { "type": "array", "items": { "type": "string" } },
    "recertification_refs": { "type": "array", "items": { "type": "string" } },
    "durable_learning_refs": { "type": "array", "items": { "type": "string" } },
    "ledger_replaces_source_truth": { "const": false }
  }
}
