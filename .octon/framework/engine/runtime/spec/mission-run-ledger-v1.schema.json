{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/mission-run-ledger-v1.schema.json",
  "title": "Mission Run Ledger v1",
  "description": "Mission-level index over governed runs. It does not replace per-run journals.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "mission_id",
    "role",
    "run_journal_authority_ref",
    "runs",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "const": "mission-run-ledger-v1" },
    "mission_id": { "type": "string", "minLength": 1 },
    "role": { "const": "mission-level-index-not-run-journal" },
    "run_journal_authority_ref": { "type": "string", "minLength": 1 },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "run_id",
          "action_slice_id",
          "run_status",
          "run_closeout_state",
          "evidence_completeness",
          "rollback_disposition",
          "replay_readiness",
          "disclosure_readiness",
          "continuity_update_refs",
          "journal_authority_ref"
        ],
        "properties": {
          "run_id": { "type": "string", "minLength": 1 },
          "action_slice_id": { "type": "string", "minLength": 1 },
          "run_contract_candidate_ref": { "type": ["string", "null"] },
          "canonical_run_contract_ref": { "type": ["string", "null"] },
          "run_status": { "type": "string", "minLength": 1 },
          "run_closeout_state": { "type": "string", "minLength": 1 },
          "evidence_completeness": { "type": "string", "minLength": 1 },
          "rollback_disposition": { "type": "string", "minLength": 1 },
          "replay_readiness": { "type": "string", "minLength": 1 },
          "disclosure_readiness": { "type": "string", "minLength": 1 },
          "continuity_update_refs": { "type": "array" },
          "journal_authority_ref": { "type": "string", "minLength": 1 }
        }
      }
    },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 }
  }
}
