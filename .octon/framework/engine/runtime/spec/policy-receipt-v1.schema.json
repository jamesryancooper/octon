{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/policy-receipt-v1.schema.json",
  "title": "Octon ACP Policy Receipt v1",
  "description": "Canonical machine-readable schema for ACP decision receipts emitted by engine/runtime/policy flows.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_id",
    "timestamp",
    "decision",
    "effective_acp",
    "reason_codes",
    "reason_details",
    "remediation",
    "instruction_layers",
    "context_acquisition",
    "context_overhead_ratio"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "policy-receipt-v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "ALLOW",
        "STAGE_ONLY",
        "DENY",
        "ESCALATE"
      ]
    },
    "effective_acp": {
      "type": "string",
      "pattern": "^ACP-[0-4]$"
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reason_details": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "remediation"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "remediation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "remediation": {
      "type": "string",
      "minLength": 1
    },
    "intent_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "boundary_id": {
      "type": "string",
      "minLength": 1
    },
    "boundary_set_version": {
      "type": "string",
      "minLength": 1
    },
    "workflow_mode": {
      "type": "string",
      "enum": [
        "autonomous",
        "agent-augmented",
        "human-only"
      ]
    },
    "capability_classification": {
      "type": "string",
      "enum": [
        "agent-ready",
        "agent-augmented",
        "human-only"
      ]
    },
    "instruction_layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "layer_id",
          "source",
          "sha256",
          "bytes",
          "visibility"
        ],
        "properties": {
          "layer_id": {
            "type": "string",
            "enum": [
              "provider",
              "system",
              "developer",
              "user"
            ]
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          },
          "visibility": {
            "type": "string",
            "enum": [
              "full",
              "partial",
              "none"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "context_acquisition": {
      "type": "object",
      "required": [
        "file_reads",
        "search_queries",
        "commands",
        "subagent_spawns",
        "duration_ms"
      ],
      "properties": {
        "file_reads": {
          "type": "integer",
          "minimum": 0
        },
        "search_queries": {
          "type": "integer",
          "minimum": 0
        },
        "commands": {
          "type": "integer",
          "minimum": 0
        },
        "subagent_spawns": {
          "type": "integer",
          "minimum": 0
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "context_overhead_ratio": {
      "type": "number",
      "minimum": 0
    }
  }
}
