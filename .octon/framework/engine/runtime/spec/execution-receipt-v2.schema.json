{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/execution-receipt-v2.schema.json",
  "title": "Octon Execution Receipt v2",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "request_id",
    "grant_id",
    "target_id",
    "action_type",
    "path_type",
    "environment_class",
    "requested_capabilities",
    "granted_capabilities",
    "policy_mode_requested",
    "policy_mode_effective",
    "decision",
    "reason_codes",
    "side_effects",
    "timestamps",
    "workflow_mode"
  ],
  "properties": {
    "schema_version": { "const": "execution-receipt-v2" },
    "request_id": { "type": "string", "minLength": 1 },
    "grant_id": { "type": "string", "minLength": 1 },
    "target_id": { "type": "string", "minLength": 1 },
    "action_type": { "type": "string", "minLength": 1 },
    "path_type": { "type": "string", "minLength": 1 },
    "environment_class": { "type": "string", "enum": ["development", "protected"] },
    "workflow_mode": { "type": "string", "enum": ["autonomous", "role-mediated", "human-only"] },
    "requested_capabilities": { "type": "array", "items": { "type": "string" } },
    "granted_capabilities": { "type": "array", "items": { "type": "string" } },
    "requested_capability_packs": { "type": "array", "items": { "type": "string" } },
    "granted_capability_packs": { "type": "array", "items": { "type": "string" } },
    "policy_mode_requested": { "type": "string", "minLength": 1 },
    "policy_mode_effective": { "type": "string", "minLength": 1 },
    "decision": { "type": "string", "enum": ["ALLOW", "STAGE_ONLY", "DENY", "ESCALATE"] },
    "reason_codes": { "type": "array", "items": { "type": "string" } },
    "context_pack_ref": { "type": ["string", "null"] },
    "risk_materiality_ref": { "type": ["string", "null"] },
    "rollback_plan_ref": { "type": ["string", "null"] },
    "browser_ui_record_refs": { "type": "array", "items": { "type": "string" } },
    "api_egress_record_refs": { "type": "array", "items": { "type": "string" } },
    "evidence_completeness_status": { "type": ["string", "null"] },
    "side_effects": { "type": "object" },
    "mission_ref": { "type": ["object", "null"] },
    "slice_ref": { "type": ["object", "null"] },
    "intent_ref": { "type": "object" },
    "mission_class": { "type": ["string", "null"] },
    "oversight_mode": { "type": ["string", "null"] },
    "execution_posture": { "type": ["string", "null"] },
    "reversibility_class": { "type": ["string", "null"] },
    "boundary_id": { "type": ["string", "null"] },
    "rollback_handle": { "type": ["string", "null"] },
    "compensation_handle": { "type": ["string", "null"] },
    "recovery_window": { "type": ["string", "null"] },
    "autonomy_budget_state": { "type": ["string", "null"] },
    "breaker_state": { "type": ["string", "null"] },
    "applied_directive_refs": { "type": "array", "items": { "type": "string" } },
    "applied_authorize_update_refs": { "type": "array", "items": { "type": "string" } },
    "evidence_links": { "type": "object" },
    "budget": { "type": "object" },
    "timestamps": {
      "type": "object",
      "required": ["started_at", "completed_at"],
      "properties": {
        "started_at": { "type": "string", "minLength": 1 },
        "completed_at": { "type": "string", "minLength": 1 }
      }
    }
  }
}
