{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/engine/runtime/spec/federation-compact-v1.schema.json",
  "title": "Federation Compact v1",
  "description": "Locally approved agreement between trust domains. A compact coordinates trust and does not execute work.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "compact_id",
    "participating_domains",
    "purpose",
    "accepted_proof_types",
    "accepted_attestation_types",
    "cross_domain_decision_rules",
    "data_sharing_rules",
    "delegated_authority_limits",
    "valid_from",
    "expires_at",
    "renewal",
    "revocation",
    "local_approval_refs",
    "approval_authority_ref",
    "approved_at",
    "recertification_due_at",
    "status",
    "compact_authorizes_execution",
    "compact_overrides_local_authority",
    "compact_widens_support_claims",
    "compact_mutates_local_authority"
  ],
  "properties": {
    "schema_version": { "const": "federation-compact-v1" },
    "compact_id": { "type": "string", "minLength": 1 },
    "participating_domains": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "purpose": { "type": "string", "minLength": 1 },
    "accepted_proof_types": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "accepted_attestation_types": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "cross_domain_decision_rules": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "data_sharing_rules": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "delegated_authority_limits": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "valid_from": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "renewal": { "type": "string", "minLength": 1 },
    "revocation": { "type": "string", "minLength": 1 },
    "local_approval_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "approval_authority_ref": { "type": "string", "minLength": 1 },
    "approved_at": { "type": ["string", "null"], "format": "date-time" },
    "recertification_due_at": { "type": "string", "format": "date-time" },
    "revoked_at": { "type": ["string", "null"], "format": "date-time" },
    "revocation_ref": { "type": ["string", "null"] },
    "status": { "type": "string", "enum": ["proposed", "approved", "rejected", "revoked", "expired", "stage_only"] },
    "compact_authorizes_execution": { "const": false },
    "compact_overrides_local_authority": { "const": false },
    "compact_widens_support_claims": { "const": false },
    "compact_mutates_local_authority": { "const": false }
  }
}
