{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/orchestration/governance/capability-map-v1.schema.json",
  "title": "Octon Capability Map v1",
  "description": "Workflow autonomy classification map for execution-role-ready, role-mediated, and human-only execution modes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "map_id",
    "map_version",
    "owner",
    "approved_by",
    "workflows"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "capability-map-v1"
    },
    "map_id": {
      "type": "string",
      "minLength": 1
    },
    "map_version": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    },
    "review_cadence_days": {
      "type": "integer",
      "minimum": 1
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification",
        "autonomous_allowed"
      ],
      "properties": {
        "classification": {
          "type": "string",
          "enum": [
            "execution-role-ready",
            "role-mediated",
            "human-only"
          ]
        },
        "autonomous_allowed": {
          "type": "boolean"
        }
      }
    },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "workflow_id",
          "classification",
          "autonomous_allowed"
        ],
        "properties": {
          "workflow_id": {
            "type": "string",
            "minLength": 1
          },
          "classification": {
            "type": "string",
            "enum": [
              "execution-role-ready",
              "role-mediated",
              "human-only"
            ]
          },
          "autonomous_allowed": {
            "type": "boolean"
          },
          "required_contracts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          }
        }
      }
    }
  }
}
