{
  "version": "1.0.0",
  "canonical": {
    "commit_policy_doc": ".octon/framework/execution-roles/practices/commits.md",
    "pr_policy_doc": ".octon/framework/execution-roles/practices/pull-request-standards.md",
    "pr_template_path": ".github/PULL_REQUEST_TEMPLATE.md"
  },
  "commit": {
    "header_format": "<type>(<scope>): <summary>",
    "allowed_types": [
      "feat",
      "fix",
      "refactor",
      "perf",
      "test",
      "docs",
      "chore",
      "ci",
      "revert"
    ],
    "scope_pattern": "[a-z0-9][a-z0-9-]*",
    "header_max_length": 72,
    "body_max_line_length": 72,
    "footer_max_line_length": 72,
    "summary_must_be_lowercase": true,
    "summary_must_not_end_with_period": true
  },
  "branch": {
    "default_format": "<type>/<ticket-id>-<short-description>",
    "allowed_types": [
      "feat",
      "fix",
      "refactor",
      "perf",
      "test",
      "docs",
      "chore",
      "ci",
      "revert"
    ],
    "ticket_pattern": "[A-Za-z0-9]+-[0-9]+",
    "slug_pattern": "[a-z0-9]+(?:-[a-z0-9]+)*"
  },
  "pr_title": {
    "header_format": "<type>(<scope>): <summary>",
    "allowed_types": [
      "feat",
      "fix",
      "refactor",
      "perf",
      "test",
      "docs",
      "chore",
      "ci",
      "revert"
    ],
    "scope_pattern": "[a-z0-9][a-z0-9-]*"
  },
  "merge": {
    "strategy": "squash",
    "require_pr_title_conventional": true
  }
}
