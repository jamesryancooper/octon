{
  "version": "1.0.0",
  "canonical": {
    "commit_policy_doc": ".octon/framework/execution-roles/practices/commits.md",
    "pr_policy_doc": ".octon/framework/execution-roles/practices/pull-request-standards.md",
    "pr_template_path": ".github/PULL_REQUEST_TEMPLATE.md",
    "default_work_unit_policy_ref": ".octon/framework/product/contracts/default-work-unit.yml",
    "change_receipt_schema_ref": ".octon/framework/product/contracts/change-receipt-v1.schema.json"
  },
  "change": {
    "default_work_unit": "change",
    "route_ids": [
      "direct-main",
      "branch-no-pr",
      "branch-pr",
      "stage-only-escalate"
    ],
    "pr_required_routes": [
      "branch-pr"
    ],
    "branch_required_routes": [
      "branch-no-pr",
      "branch-pr"
    ],
    "no_pr_routes": [
      "direct-main",
      "branch-no-pr",
      "stage-only-escalate"
    ],
    "receipt_required": true
  },
  "commit": {
    "policy_doc": ".octon/framework/execution-roles/practices/commits.md",
    "header_format": "<type>(<scope>): <summary>",
    "allowed_types": [
      "feat",
      "fix",
      "refactor",
      "perf",
      "test",
      "docs",
      "chore",
      "ci",
      "revert"
    ],
    "scope_pattern": "[a-z0-9][a-z0-9-]*",
    "header_max_length": 72,
    "body_max_line_length": 72,
    "footer_max_line_length": 72,
    "summary_must_be_lowercase": true,
    "summary_must_not_end_with_period": true
  },
  "pr": {
    "policy_doc": ".octon/framework/execution-roles/practices/pull-request-standards.md",
    "applies_to_routes": [
      "branch-pr"
    ],
    "requires_change_identity": true,
    "requires_change_receipt_projection": true,
    "autonomous_draft_completion": {
      "status": "allowed",
      "route": "branch-pr",
      "requires_open_draft": true,
      "requires_autonomous_lane": true,
      "requires_change_receipt_or_closeout_evidence": true,
      "high_impact_posture": {
        "classification": "risk:high",
        "autonomy_model": "elevated-autonomy",
        "manual_default": false,
        "requires_explicit_self_review": true,
        "requires_post_merge_origin_main_verification": true,
        "escalate_only_for_concrete_blockers": true
      },
      "required_checks": [
        "AI Review Gate / decision when required",
        "PR Quality Standards",
        "Validate branch naming",
        "PR Clean State Enforcer",
        "Validate autonomy policy"
      ],
      "requires_no_unresolved_author_action_threads": true,
      "requires_no_blocking_labels": true,
      "requires_no_requested_changes": true,
      "requires_no_merge_conflicts": true,
      "requires_no_stale_head_state": true,
      "merge_path": "current live protected-main ruleset",
      "protected_main_bypass_allowed": false
    }
  },
  "branch": {
    "default_format": "<type>/<ticket-id>-<short-description>",
    "allowed_types": [
      "feat",
      "fix",
      "refactor",
      "perf",
      "test",
      "docs",
      "chore",
      "ci",
      "revert"
    ],
    "ticket_pattern": "[A-Za-z0-9]+-[0-9]+",
    "slug_pattern": "[a-z0-9]+(?:-[a-z0-9]+)*"
  },
  "pr_title": {
    "header_format": "<type>(<scope>): <summary>",
    "allowed_types": [
      "feat",
      "fix",
      "refactor",
      "perf",
      "test",
      "docs",
      "chore",
      "ci",
      "revert"
    ],
    "scope_pattern": "[a-z0-9][a-z0-9-]*"
  },
  "merge": {
    "strategy": "squash",
    "require_pr_title_conventional": true
  }
}
