{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/product/contracts/change-receipt-v1.schema.json",
  "title": "Octon Change Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "change_id",
    "selected_route",
    "target_lifecycle_outcome",
    "lifecycle_outcome",
    "outcome_intent",
    "intent",
    "scope",
    "validation_evidence_refs",
    "durable_history",
    "integration_status",
    "publication_status",
    "cleanup_status",
    "rollback_handle",
    "closeout_outcome",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "change-receipt-v1"
    },
    "change_id": {
      "type": "string",
      "minLength": 1
    },
    "selected_route": {
      "type": "string",
      "enum": [
        "direct-main",
        "branch-no-pr",
        "branch-pr",
        "stage-only-escalate"
      ]
    },
    "operator_requested_route": {
      "type": "string",
      "enum": [
        "direct-main",
        "branch-no-pr",
        "branch-pr",
        "stage-only-escalate"
      ]
    },
    "target_lifecycle_outcome": {
      "type": "string",
      "enum": [
        "preserved",
        "branch-local-complete",
        "published-branch",
        "published",
        "ready",
        "landed",
        "cleaned",
        "blocked",
        "escalated",
        "denied"
      ]
    },
    "lifecycle_outcome": {
      "type": "string",
      "enum": [
        "preserved",
        "branch-local-complete",
        "published-branch",
        "published",
        "ready",
        "landed",
        "cleaned",
        "blocked",
        "escalated",
        "denied"
      ]
    },
    "outcome_intent": {
      "type": "string",
      "enum": [
        "preserve-only",
        "local-only",
        "handoff-only",
        "attempt-landing",
        "attempt-cleaned-closeout",
        "record-blocker-only",
        "pr-publication",
        "pr-ready",
        "pr-landing",
        "direct-main-landing"
      ]
    },
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string" },
        "touched_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "diff_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "source_branch_ref": {
      "type": "string",
      "minLength": 1
    },
    "target_branch_ref": {
      "type": "string",
      "minLength": 1
    },
    "remote_branch_ref": {
      "type": "string",
      "minLength": 1
    },
    "landing_evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "not_applicable",
            "not_attempted",
            "eligible",
            "attempted",
            "blocked",
            "succeeded",
            "failed"
          ]
        },
        "provider_ruleset_ref": { "type": "string", "minLength": 1 },
        "source_ref": { "type": "string", "minLength": 1 },
        "target_ref": { "type": "string", "minLength": 1 },
        "blocker_reason": { "type": "string", "minLength": 1 },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "hosted_landing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "remote",
        "target_branch",
        "source_branch",
        "source_ref",
        "target_pre_ref",
        "target_post_ref",
        "validated_ref",
        "required_check_refs",
        "provider_ruleset_ref",
        "fast_forward_only"
      ],
      "properties": {
        "remote": { "type": "string", "minLength": 1 },
        "target_branch": { "type": "string", "minLength": 1 },
        "source_branch": { "type": "string", "minLength": 1 },
        "source_ref": { "type": "string", "minLength": 1 },
        "target_pre_ref": { "type": "string", "minLength": 1 },
        "target_post_ref": { "type": "string", "minLength": 1 },
        "validated_ref": { "type": "string", "minLength": 1 },
        "required_check_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "provider_ruleset_ref": { "type": "string", "minLength": 1 },
        "push_refspec": { "type": "string", "minLength": 1 },
        "fast_forward_only": { "const": true }
      }
    },
    "landed_ref": {
      "type": "string",
      "minLength": 1
    },
    "not_landed_reason": {
      "type": "string",
      "minLength": 1
    },
    "not_cleaned_reason": {
      "type": "string",
      "minLength": 1
    },
    "main_alignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_main_ref",
        "origin_main_ref",
        "landed_ref",
        "aligned"
      ],
      "properties": {
        "local_main_ref": { "type": "string", "minLength": 1 },
        "origin_main_ref": { "type": "string", "minLength": 1 },
        "landed_ref": { "type": "string", "minLength": 1 },
        "aligned": { "const": true },
        "verification_ref": { "type": "string", "minLength": 1 }
      }
    },
    "integration_method": {
      "type": "string",
      "enum": [
        "direct-commit",
        "fast-forward",
        "merge-commit",
        "squash",
        "cherry-pick",
        "github-merge",
        "manual",
        "not-applicable"
      ]
    },
    "integration_status": {
      "type": "string",
      "enum": [
        "not_landed",
        "landed",
        "not_applicable"
      ]
    },
    "publication_status": {
      "type": "string",
      "enum": [
        "none",
        "pushed-branch",
        "hosted-main-updated",
        "pr-opened",
        "pr-ready",
        "pr-merged",
        "not_applicable"
      ]
    },
    "cleanup_status": {
      "type": "string",
      "enum": [
        "not_applicable",
        "pending",
        "completed",
        "deferred"
      ]
    },
    "cleanup_evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "source_branch_cleanup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_applicable", "pending", "completed", "deferred", "skipped", "blocked"]
        },
        "local_branch": { "type": "string", "minLength": 1 },
        "remote_branch": { "type": "string", "minLength": 1 },
        "worktree": { "type": "string", "minLength": 1 },
        "blocker_reason": { "type": "string", "minLength": 1 },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "external_blocker_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "validation_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "review_evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "review_waiver_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "durable_history": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ref"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["commit", "patch", "checkpoint", "branch", "pr"]
        },
        "ref": { "type": "string", "minLength": 1 },
        "pr_url": { "type": "string" },
        "branch": { "type": "string" }
      }
    },
    "rollback_handle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ref"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["revert-commit", "patch-reversal", "checkpoint-restore", "discard-branch", "manual-instructions"]
        },
        "ref": { "type": "string", "minLength": 1 },
        "instructions": { "type": "string" }
      }
    },
    "closeout_outcome": {
      "type": "string",
      "enum": ["completed", "continued", "stage_only", "blocked", "escalated", "denied"]
    },
    "remaining_blockers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": { "properties": { "selected_route": { "const": "branch-pr" } } },
      "then": {
        "required": ["source_branch_ref"],
        "properties": {
          "target_lifecycle_outcome": {
            "enum": ["preserved", "published", "ready", "landed", "cleaned", "blocked", "escalated", "denied"]
          },
          "lifecycle_outcome": {
            "enum": ["preserved", "published", "ready", "landed", "cleaned", "blocked", "escalated", "denied"]
          },
          "publication_status": {
            "enum": ["none", "pr-opened", "pr-ready", "pr-merged"]
          }
        }
      }
    },
    {
      "if": { "properties": { "selected_route": { "const": "branch-no-pr" } } },
      "then": {
        "required": ["source_branch_ref"],
        "properties": {
          "target_lifecycle_outcome": {
            "enum": ["preserved", "branch-local-complete", "published-branch", "landed", "cleaned", "blocked", "escalated", "denied"]
          },
          "lifecycle_outcome": {
            "enum": ["preserved", "branch-local-complete", "published-branch", "landed", "cleaned", "blocked", "escalated", "denied"]
          },
          "publication_status": {
            "enum": ["none", "pushed-branch", "hosted-main-updated"]
          },
          "durable_history": {
            "properties": {
              "kind": {
                "enum": ["commit", "patch", "checkpoint", "branch"]
              }
            }
          }
        },
        "not": {
          "anyOf": [
            { "required": ["pr_url"] },
            { "required": ["pr_number"] },
            {
              "properties": {
                "durable_history": {
                  "required": ["pr_url"]
                }
              }
            },
            {
              "properties": {
                "durable_history": {
                  "properties": {
                    "kind": { "const": "pr" }
                  }
                }
              }
            }
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_route": { "const": "branch-no-pr" },
          "lifecycle_outcome": { "const": "branch-local-complete" }
        }
      },
      "then": {
        "properties": {
          "integration_status": {
            "enum": ["not_landed", "not_applicable"]
          },
          "publication_status": {
            "enum": ["none", "pushed-branch"]
          },
          "durable_history": {
            "properties": {
              "kind": { "const": "commit" }
            }
          },
          "closeout_outcome": {
            "enum": ["continued", "blocked", "escalated", "denied"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_route": { "const": "branch-no-pr" },
          "lifecycle_outcome": { "const": "published-branch" }
        }
      },
      "then": {
        "required": ["remote_branch_ref"],
        "properties": {
          "integration_status": {
            "enum": ["not_landed", "not_applicable"]
          },
          "publication_status": {
            "const": "pushed-branch"
          },
          "closeout_outcome": {
            "enum": ["continued", "blocked", "escalated", "denied"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_route": { "const": "branch-no-pr" },
          "lifecycle_outcome": {
            "enum": ["landed", "cleaned"]
          }
        }
      },
      "then": {
        "required": [
          "hosted_landing",
          "landing_evaluation",
          "landed_ref",
          "target_branch_ref",
          "integration_method",
          "main_alignment"
        ],
        "properties": {
          "integration_status": {
            "const": "landed"
          },
          "publication_status": {
            "const": "hosted-main-updated"
          },
          "integration_method": {
            "const": "fast-forward"
          },
          "durable_history": {
            "properties": {
              "kind": {
                "enum": ["commit", "branch"]
              }
            }
          },
          "hosted_landing": {
            "properties": {
              "fast_forward_only": { "const": true }
            }
          },
          "landing_evaluation": {
            "properties": {
              "status": {
                "enum": ["attempted", "succeeded"]
              }
            }
          },
          "main_alignment": {
            "properties": {
              "aligned": { "const": true }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_route": { "const": "branch-pr" },
          "lifecycle_outcome": { "const": "preserved" }
        }
      },
      "then": {
        "properties": {
          "integration_status": {
            "enum": ["not_landed", "not_applicable"]
          },
          "publication_status": {
            "const": "none"
          },
          "durable_history": {
            "properties": {
              "kind": {
                "enum": ["commit", "patch", "checkpoint", "branch"]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_route": { "const": "branch-pr" },
          "lifecycle_outcome": { "const": "published" }
        }
      },
      "then": {
        "properties": {
          "integration_status": {
            "enum": ["not_landed", "not_applicable"]
          },
          "publication_status": {
            "const": "pr-opened"
          },
          "durable_history": {
            "properties": {
              "kind": { "const": "pr" },
              "pr_url": { "type": "string", "minLength": 1 }
            },
            "required": ["kind", "ref", "pr_url"]
          },
          "closeout_outcome": {
            "enum": ["continued", "blocked", "escalated", "denied"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_route": { "const": "branch-pr" },
          "lifecycle_outcome": { "const": "ready" }
        }
      },
      "then": {
        "properties": {
          "integration_status": {
            "enum": ["not_landed", "not_applicable"]
          },
          "publication_status": {
            "const": "pr-ready"
          },
          "durable_history": {
            "properties": {
              "kind": { "const": "pr" },
              "pr_url": { "type": "string", "minLength": 1 }
            },
            "required": ["kind", "ref", "pr_url"]
          },
          "closeout_outcome": {
            "enum": ["continued", "blocked", "escalated", "denied"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_route": { "const": "branch-pr" },
          "lifecycle_outcome": {
            "enum": ["landed", "cleaned"]
          }
        }
      },
      "then": {
        "required": ["landed_ref", "target_branch_ref", "integration_method"],
        "properties": {
          "integration_status": {
            "const": "landed"
          },
          "publication_status": {
            "const": "pr-merged"
          },
          "durable_history": {
            "properties": {
              "kind": { "const": "pr" },
              "pr_url": { "type": "string", "minLength": 1 }
            },
            "required": ["kind", "ref", "pr_url"]
          },
          "main_alignment": {
            "properties": {
              "aligned": { "const": true }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "selected_route": { "const": "direct-main" } } },
      "then": {
        "required": ["landed_ref", "target_branch_ref", "main_alignment"],
        "properties": {
          "target_lifecycle_outcome": {
            "enum": ["landed", "cleaned"]
          },
          "lifecycle_outcome": {
            "enum": ["landed", "cleaned"]
          },
          "integration_status": {
            "const": "landed"
          },
          "publication_status": {
            "enum": ["none", "hosted-main-updated", "not_applicable"]
          },
          "integration_method": {
            "const": "direct-commit"
          },
          "durable_history": {
            "properties": {
              "kind": { "const": "commit" }
            }
          },
          "main_alignment": {
            "properties": {
              "aligned": { "const": true }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "integration_status": { "const": "landed" }
        }
      },
      "then": {
        "required": ["landed_ref", "target_branch_ref", "integration_method", "main_alignment"],
        "properties": {
          "lifecycle_outcome": {
            "enum": ["landed", "cleaned"]
          },
          "durable_history": {
            "properties": {
              "kind": {
                "enum": ["commit", "branch", "pr"]
              }
            }
          },
          "main_alignment": {
            "properties": {
              "aligned": { "const": true }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_outcome": {
            "enum": ["landed", "cleaned"]
          }
        }
      },
      "then": {
        "required": ["landed_ref", "target_branch_ref", "integration_method", "main_alignment"],
        "properties": {
          "integration_status": {
            "const": "landed"
          },
          "durable_history": {
            "properties": {
              "kind": {
                "enum": ["commit", "branch", "pr"]
              }
            }
          },
          "main_alignment": {
            "properties": {
              "aligned": { "const": true }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "target_lifecycle_outcome": {
            "enum": ["landed", "cleaned"]
          },
          "integration_status": {
            "enum": ["not_landed", "not_applicable"]
          }
        },
        "required": ["target_lifecycle_outcome", "integration_status"]
      },
      "then": {
        "required": ["landing_evaluation", "not_landed_reason"],
        "properties": {
          "closeout_outcome": {
            "enum": ["continued", "stage_only", "blocked", "escalated", "denied"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "target_lifecycle_outcome": { "const": "cleaned" },
          "lifecycle_outcome": {
            "enum": ["preserved", "branch-local-complete", "published-branch", "published", "ready", "landed", "blocked", "escalated", "denied"]
          }
        },
        "required": ["target_lifecycle_outcome", "lifecycle_outcome"]
      },
      "then": {
        "required": ["not_cleaned_reason"],
        "properties": {
          "closeout_outcome": {
            "enum": ["continued", "stage_only", "blocked", "escalated", "denied"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_outcome": { "const": "cleaned" }
        }
      },
      "then": {
        "properties": {
          "cleanup_status": {
            "enum": ["completed", "deferred"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cleanup_status": { "const": "completed" }
        }
      },
      "then": {
        "required": ["cleanup_evidence_refs"],
        "properties": {
          "cleanup_evidence_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cleanup_status": { "const": "deferred" }
        }
      },
      "then": {
        "anyOf": [
          {
            "required": ["cleanup_evidence_refs"],
            "properties": {
              "cleanup_evidence_refs": { "minItems": 1 }
            }
          },
          {
            "required": ["external_blocker_refs"],
            "properties": {
              "external_blocker_refs": { "minItems": 1 }
            }
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "selected_route": {
            "enum": ["branch-no-pr", "branch-pr"]
          },
          "integration_status": { "const": "landed" },
          "closeout_outcome": { "const": "completed" }
        }
      },
      "then": {
        "required": ["source_branch_cleanup"],
        "properties": {
          "cleanup_status": {
            "enum": ["completed", "deferred"]
          }
        }
      }
    },
    {
      "if": { "properties": { "lifecycle_outcome": { "const": "preserved" } } },
      "then": {
        "properties": {
          "integration_status": {
            "enum": ["not_landed", "not_applicable"]
          }
        }
      }
    },
    {
      "if": { "properties": { "selected_route": { "const": "stage-only-escalate" } } },
      "then": {
        "properties": {
          "lifecycle_outcome": {
            "enum": ["preserved", "blocked", "escalated", "denied"]
          },
          "target_lifecycle_outcome": {
            "enum": ["preserved", "blocked", "escalated", "denied"]
          },
          "integration_status": {
            "enum": ["not_landed", "not_applicable"]
          },
          "publication_status": {
            "enum": ["none", "not_applicable"]
          },
          "closeout_outcome": {
            "enum": ["stage_only", "blocked", "escalated", "denied"]
          }
        }
      }
    }
  ]
}
