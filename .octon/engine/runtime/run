#!/bin/sh
set -eu

# Resolve .octon directory from this script location.
RUNTIME_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
ENGINE_DIR="$(CDPATH= cd -- "$RUNTIME_DIR/.." && pwd)"
OCTON_DIR="$(CDPATH= cd -- "$ENGINE_DIR/.." && pwd)"
RUNTIME_OPS_DIR="$ENGINE_DIR/_ops"
RUNTIME_STATE_DIR="$RUNTIME_OPS_DIR/state"

OS="$(uname -s 2>/dev/null || echo unknown)"
ARCH="$(uname -m 2>/dev/null || echo unknown)"

BIN_DIR="$RUNTIME_OPS_DIR/bin"

# Map OS/arch -> expected binary name.
case "$OS" in
  Darwin)
    case "$ARCH" in
      arm64) BIN="$BIN_DIR/octon-macos-arm64" ;;
      x86_64) BIN="$BIN_DIR/octon-macos-x64" ;;
      *) BIN="" ;;
    esac
    ;;
  Linux)
    case "$ARCH" in
      x86_64) BIN="$BIN_DIR/octon-linux-x64" ;;
      aarch64|arm64) BIN="$BIN_DIR/octon-linux-arm64" ;;
      *) BIN="" ;;
    esac
    ;;
  *)
    BIN=""
    ;;
esac

case "${1:-}" in
  ""|studio|workflow|-h|--help|help)
    BIN=""
    ;;
esac

if [ -n "${BIN:-}" ] && [ -x "$BIN" ]; then
  if [ "${OCTON_RUNTIME_PREFER_SOURCE:-0}" != "1" ]; then
    exec "$BIN" "$@"
  fi
fi

# Development fallback: run from source.
# This keeps the launcher usable before platform binaries are produced.
mkdir -p "$RUNTIME_STATE_DIR/build/runtime-crates-target"
export CARGO_TARGET_DIR="$RUNTIME_STATE_DIR/build/runtime-crates-target"
exec cargo run -q --manifest-path "$RUNTIME_DIR/crates/Cargo.toml" -p octon_kernel -- "$@"
