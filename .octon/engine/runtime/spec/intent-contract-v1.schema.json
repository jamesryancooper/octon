{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/intent-contract-v1.schema.json",
  "title": "Octon Intent Contract v1",
  "description": "Machine-readable organizational intent contract bound to autonomous runs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "intent_id",
    "version",
    "objective_signals",
    "authorized_actions",
    "hard_boundaries",
    "owner",
    "approved_by"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "intent-contract-v1"
    },
    "intent_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "objective_signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          }
        }
      }
    },
    "authorized_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "hard_boundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "boundary_id",
          "rule",
          "on_violation"
        ],
        "properties": {
          "boundary_id": {
            "type": "string",
            "minLength": 1
          },
          "rule": {
            "type": "string",
            "minLength": 1
          },
          "on_violation": {
            "type": "string",
            "enum": [
              "deny",
              "escalate"
            ]
          }
        }
      }
    },
    "tradeoff_hierarchy": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "review_by": {
      "type": "string",
      "minLength": 1
    }
  }
}
