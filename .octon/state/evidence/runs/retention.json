{
  "schema_version": "1.0",
  "default_action": "retain",
  "classes": [
    {
      "id": "governance_evidence",
      "description": "Audit and policy evidence required for historical governance and compliance traceability.",
      "match_prefixes": [
        "acp-",
        "audit",
        "archive-proposal-",
        "create-architecture-proposal-",
        "create-design-proposal-",
        "create-migration-proposal-",
        "create-policy-proposal-",
        "docs-gate-",
        "promote-proposal-",
        "runtime-acp",
        "runtime-soft-delete-",
        "runtime-agent-quorum-",
        "snippet-emit-",
        "uec-audit-",
        "uec-global-",
        "uec-evaluate-harness-",
        "uec-safe-stage-",
        "uec-validate-proposal-",
        "validate-proposal-"
      ],
      "retention_days": 365,
      "action_after_retention": "archive"
    },
    {
      "id": "operational_debug",
      "description": "Short-lived local validation and debugging runs.",
      "match_prefixes": [
        "debug-",
        "run-",
        "service-",
        "tool-",
        "stdio-",
        "workflow-"
      ],
      "retention_days": 30,
      "action_after_retention": "prune"
    },
    {
      "id": "scratch",
      "description": "Temporary scratch runs and throwaway experiments.",
      "match_prefixes": [
        "tmp-"
      ],
      "retention_days": 7,
      "action_after_retention": "prune"
    }
  ],
  "always_keep_files": [
    "README.md",
    "retention.json",
    "audit-plan.md"
  ]
}
