{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/continuity/tasks.schema.json",
  "title": "Octon Continuity Tasks",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "goal",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.2"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "knowledgeLinks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "specs",
        "contracts",
        "decisions",
        "evidence"
      ],
      "properties": {
        "specs": {
          "$ref": "#/$defs/stringArray"
        },
        "contracts": {
          "$ref": "#/$defs/stringArray"
        },
        "decisions": {
          "$ref": "#/$defs/stringArray"
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "in_progress",
            "blocked",
            "completed",
            "cancelled"
          ]
        },
        "priority": {
          "type": "integer",
          "minimum": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "blockers": {
          "$ref": "#/$defs/stringArray"
        },
        "acceptance_criteria": {
          "$ref": "#/$defs/stringArray"
        },
        "knowledge_links": {
          "$ref": "#/$defs/knowledgeLinks"
        },
        "risk_tier": {
          "type": "string",
          "enum": [
            "T1",
            "T2",
            "T3"
          ]
        },
        "required_approvals": {
          "$ref": "#/$defs/stringArray"
        },
        "goal_contribution": {
          "type": "string",
          "minLength": 1
        },
        "completed_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
