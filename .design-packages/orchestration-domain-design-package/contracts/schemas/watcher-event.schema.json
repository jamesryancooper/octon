{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/design-packages/orchestration/watcher-event.schema.json",
  "title": "Watcher Event Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "watcher_id",
    "event_type",
    "emitted_at",
    "severity",
    "dedupe_key",
    "source_ref",
    "summary"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "watcher_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "emitted_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "high",
        "critical"
      ]
    },
    "dedupe_key": {
      "type": "string",
      "minLength": 1
    },
    "partition_key": {
      "type": "string",
      "minLength": 1
    },
    "source_ref": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "payload": {},
    "payload_ref": {
      "type": "string",
      "minLength": 1
    },
    "target_automation_id": {
      "type": "string",
      "minLength": 1
    },
    "candidate_incident_id": {
      "type": "string",
      "minLength": 1
    }
  }
}
