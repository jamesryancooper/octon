{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/design-packages/orchestration/automation-bindings.schema.json",
  "title": "Automation Bindings",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "default_params": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean"
        ]
      }
    },
    "event_to_param_map": {
      "$ref": "#/$defs/eventToParamMap"
    }
  },
  "$defs": {
    "eventToParamMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/binding"
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "required",
        "value_type"
      ],
      "properties": {
        "from": {
          "type": "string",
          "pattern": "^event(\\.[A-Za-z0-9_-]+)+$"
        },
        "required": {
          "type": "boolean"
        },
        "default": {
          "type": [
            "string",
            "number",
            "boolean"
          ]
        },
        "value_type": {
          "type": "string",
          "enum": [
            "string",
            "integer",
            "number",
            "boolean"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "required": {
                "const": true
              }
            }
          },
          "then": {
            "not": {
              "required": [
                "default"
              ]
            }
          }
        }
      ]
    }
  }
}
