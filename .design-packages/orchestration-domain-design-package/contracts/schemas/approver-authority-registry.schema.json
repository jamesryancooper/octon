{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/design-packages/orchestration/approver-authority-registry.schema.json",
  "title": "Approver Authority Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_version",
    "approvers"
  ],
  "properties": {
    "registry_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "approvers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/approver"
      }
    }
  },
  "$defs": {
    "scopeEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_class",
        "surfaces"
      ],
      "properties": {
        "action_class": {
          "type": "string",
          "minLength": 1
        },
        "surfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "workflow_groups": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "coordination_key_globs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "approver": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approver_id",
        "role",
        "approved_scopes",
        "issued_at",
        "expires_at",
        "revoked"
      ],
      "properties": {
        "approver_id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "approved_scopes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/scopeEntry"
          }
        },
        "issued_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
        },
        "expires_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
        },
        "revoked": {
          "type": "boolean"
        }
      }
    }
  }
}
