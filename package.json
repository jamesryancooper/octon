{
  "name": "harmony-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "pnpm --filter @harmony/api dev",
    "dev:all": "turbo run dev --parallel",
    "prepare": "husky",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:root": "sh -c 'mkdir -p reports && eslint . -f json -o reports/eslint-root.json'",
    "commitlint": "commitlint --edit",
    "test": "turbo run test",
    "contracts:check": "turbo run contracts:check",
    "deps:scan": "pnpm dlx osv-scanner --recursive --format sarif --output reports/osv.sarif || true",
    "sbom": "pnpm dlx @cyclonedx/cyclonedx-npm --output-file sbom/sbom.spdx.json",
    "secrets:scan": "pnpm dlx trufflehog filesystem --no-update --fail --path .",
    "preview:vercel": "turbo run preview:vercel",
    "flowkit:run": "pnpm --filter @harmony/kits flowkit:run-config",
    "flowkit:check-paths": "node scripts/check-flowkit-paths.js",
    "harmony": "pnpm --filter @harmony/cli harmony"
  },
  "engines": {
    "node": "24.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@changesets/cli": "^2.29.7",
    "@types/node": "^22.18.13",
    "husky": "^9.1.7",
    "turbo": "^2.5.8"
  }
}
