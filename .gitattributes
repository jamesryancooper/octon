# Git attributes for octon repository

# Ensure symlinks work correctly across platforms
* text=auto

# Preserve symlinks in harness skill folders
.claude/skills/* -text
.cursor/skills/* -text
.codex/skills/* -text

# Preserve symlinks in harness command folders
.claude/commands/refactor.md -text
.cursor/commands/refactor.md -text

# Mark skill symlinks explicitly (optional, helps some tools)
.claude/skills/** symlink
.cursor/skills/** symlink
.codex/skills/** symlink

# Mark command symlinks explicitly
.claude/commands/refactor.md symlink
.cursor/commands/refactor.md symlink
