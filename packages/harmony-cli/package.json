{
  "name": "@harmony/cli",
  "version": "0.0.1",
  "description": "Human-friendly CLI for orchestrating AI agents in the Harmony methodology",
  "type": "module",
  "private": true,
  "bin": {
    "harmony": "./dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "sh -c 'mkdir -p reports && eslint . -f json -o reports/eslint-cli.json'",
    "test": "tsx --test \"src/__tests__/**/*.test.ts\"",
    "harmony": "tsx src/cli.ts"
  },
  "dependencies": {
    "@harmony/kits": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "harmony",
    "cli",
    "ai",
    "orchestration",
    "methodology"
  ]
}

