{
  "name": "@harmony/ui-kit",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dist/ui.css": "./dist/ui.css",
    "./styles/tailwind.css": "./src/styles/tailwind.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/styles/tailwind.css",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run build:css",
    "build:css": "cross-env NODE_ENV=production postcss ./src/styles/tailwind.css -o ./dist/ui.css --config ./postcss.config.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "sh -c 'mkdir -p reports && eslint . -f json -o reports/eslint-ui.json'",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "tailwind-merge": "^2.5.4"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0-0",
    "react-dom": "^18.2.0 || ^19.0.0-0"
  },
  "devDependencies": {
    "@harmony/config": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@storybook/addon-a11y": "^8.4.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/addon-interactions": "^8.4.0",
    "@storybook/blocks": "^8.4.0",
    "@storybook/react": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@storybook/test": "^8.4.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "jsdom": "^24.1.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.0",
    "postcss-preset-env": "^10.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.6.0",
    "storybook": "^8.4.0",
    "vitest": "^2.1.4"
  }
}

