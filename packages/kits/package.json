{
  "name": "@harmony/kits",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "Aggregate package re-exporting all Harmony Kits",
  "exports": {
    "./flowkit": {
      "types": "./flowkit/dist/index.d.ts",
      "import": "./flowkit/dist/index.js"
    },
    "./guardkit": {
      "types": "./guardkit/dist/index.d.ts",
      "import": "./guardkit/dist/index.js"
    },
    "./promptkit": {
      "types": "./promptkit/dist/index.d.ts",
      "import": "./promptkit/dist/index.js"
    },
    "./costkit": {
      "types": "./costkit/dist/index.d.ts",
      "import": "./costkit/dist/index.js"
    },
    "./kit-base": {
      "types": "./kit-base/dist/index.d.ts",
      "import": "./kit-base/dist/index.js"
    }
  },
  "bin": {
    "promptkit": "./promptkit/dist/cli.js",
    "flowkit": "./flowkit/dist/cli.js"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "lint": "sh -c 'mkdir -p reports && eslint . -f json -o reports/eslint-kits.json'",
    "test": "vitest run",
    "test:watch": "vitest",
    "flowkit:run-config": "tsx flowkit/src/cli.ts",
    "promptkit": "tsx promptkit/src/cli.ts"
  },
  "dependencies": {
    "@harmony/kit-base": "workspace:*",
    "@harmony/flowkit": "workspace:*",
    "@harmony/guardkit": "workspace:*",
    "@harmony/promptkit": "workspace:*",
    "@harmony/costkit": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.18.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.1.3"
  }
}
