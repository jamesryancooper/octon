{
  "schemaVersion": "1.2.0",
  "methodologyVersion": "0.2.0",
  "name": "guardkit",
  "version": "0.1.0",
  "description": "AI output protection: injection detection, hallucination checks, secrets/PII redaction, code safety",
  "pillars": ["speed_with_safety", "quality_through_determinism"],
  "lifecycleStages": ["implement", "verify"],
  "inputsSchema": "schema/guardkit.inputs.v1.json",
  "outputsSchema": "schema/guardkit.outputs.v1.json",
  "observability": {
    "serviceName": "harmony.kit.guardkit",
    "requiredSpans": ["kit.guardkit.check", "kit.guardkit.sanitize"],
    "logRedaction": true
  },
  "policy": {
    "rulesetRef": "harmony-policy-v1",
    "rules": ["no-secrets", "no-pii", "no-injection"],
    "rulesetVersion": "1.0.0",
    "enforcement": "block",
    "failClosed": true
  },
  "determinism": {
    "ai": null,
    "artifactNaming": "guard-{checkId}"
  },
  "safety": {
    "hitl": {
      "requiredFor": ["high"]
    }
  },
  "idempotency": {
    "required": false,
    "idempotencyKeyFrom": ["contentHash", "checkType"]
  },
  "dryRun": {
    "supported": true
  },
  "compatibility": {
    "minSchemaVersion": "1.1.0",
    "maxSchemaVersion": "1.2.0",
    "supportedMethodologyVersions": ["0.2.0"],
    "contracts": ["guardkit.inputs.v1", "guardkit.outputs.v1"],
    "kits": ["promptkit", "flowkit"]
  }
}
