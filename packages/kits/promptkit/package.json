{
  "name": "@harmony/promptkit",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Runtime prompt compiler: template rendering, hashing, variant selection, token management, role assembly",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "bin": {
    "promptkit": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "run": "tsx src/cli.ts"
  },
  "dependencies": {
    "@harmony/kit-base": "workspace:*",
    "@harmony/prompts": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "nunjucks": "^3.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.18.13",
    "@types/nunjucks": "^3.2.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.1.3"
  },
  "files": [
    "dist",
    "schema",
    "metadata"
  ]
}

