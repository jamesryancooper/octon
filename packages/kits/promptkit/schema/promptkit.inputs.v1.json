{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/schemas/promptkit/promptkit.inputs.v1.json",
  "title": "PromptKitInputs",
  "description": "Input schema for PromptKit compile operations",
  "type": "object",
  "required": ["promptId"],
  "properties": {
    "promptId": {
      "type": "string",
      "description": "Identifier for the prompt to compile",
      "pattern": "^[a-z][a-z0-9/_-]*$"
    },
    "variables": {
      "type": "object",
      "description": "Variables to inject into the prompt template",
      "additionalProperties": true
    },
    "options": {
      "type": "object",
      "description": "Compile options",
      "properties": {
        "variant": {
          "type": "string",
          "description": "Prompt variant to use"
        },
        "maxTokens": {
          "type": "integer",
          "description": "Maximum tokens for output estimation",
          "minimum": 1
        },
        "model": {
          "type": "string",
          "description": "Target model for token counting"
        },
        "roleAssembly": {
          "type": "object",
          "description": "Role assembly configuration",
          "properties": {
            "systemPrefix": { "type": "string" },
            "userPrefix": { "type": "string" },
            "assistantPrefix": { "type": "string" }
          }
        },
        "hash": {
          "type": "boolean",
          "description": "Whether to generate content hash"
        }
      }
    }
  }
}

