{
  "schemaVersion": "1.2.0",
  "methodologyVersion": "0.2.0",
  "name": "costkit",
  "version": "0.1.0",
  "description": "LLM cost management and optimization: estimation, tracking, budgeting, alerts",
  "pillars": ["speed_with_safety", "quality_through_determinism"],
  "lifecycleStages": ["implement", "operate"],
  "inputsSchema": "schema/costkit.inputs.v1.json",
  "outputsSchema": "schema/costkit.outputs.v1.json",
  "observability": {
    "serviceName": "harmony.kit.costkit",
    "requiredSpans": ["kit.costkit.estimate", "kit.costkit.record"],
    "logRedaction": true
  },
  "policy": {
    "rulesetRef": "harmony-policy-v1",
    "rules": ["budget-check", "tier-compliance"],
    "rulesetVersion": "1.0.0",
    "enforcement": "block",
    "failClosed": false
  },
  "determinism": {
    "ai": null,
    "artifactNaming": "cost-{period}-{timestamp}"
  },
  "safety": {
    "hitl": {
      "requiredFor": ["high"]
    }
  },
  "idempotency": {
    "required": true,
    "idempotencyKeyFrom": ["model", "inputTokens", "outputTokens", "workflowType", "timestamp"]
  },
  "dryRun": {
    "supported": true
  },
  "compatibility": {
    "minSchemaVersion": "1.1.0",
    "maxSchemaVersion": "1.2.0",
    "supportedMethodologyVersions": ["0.2.0"],
    "contracts": ["costkit.inputs.v1", "costkit.outputs.v1"],
    "kits": ["flowkit", "promptkit"]
  }
}
