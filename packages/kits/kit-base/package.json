{
  "name": "@harmony/kit-base",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./run-record": {
      "types": "./dist/run-record.d.ts",
      "import": "./dist/run-record.js"
    },
    "./observability": {
      "types": "./dist/observability.d.ts",
      "import": "./dist/observability.js"
    },
    "./cli-flags": {
      "types": "./dist/cli-flags.d.ts",
      "import": "./dist/cli-flags.js"
    },
    "./metadata": {
      "types": "./dist/metadata.d.ts",
      "import": "./dist/metadata.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js"
    },
    "./idempotency": {
      "types": "./dist/idempotency.d.ts",
      "import": "./dist/idempotency.js"
    },
    "./cli-base": {
      "types": "./dist/cli-base.d.ts",
      "import": "./dist/cli-base.js"
    },
    "./http-client": {
      "types": "./dist/http-client.d.ts",
      "import": "./dist/http-client.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "validate:methodology": "npx tsx scripts/validate-methodology-alignment.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.18.13",
    "typescript": "^5.7.3",
    "vitest": "^3.1.3"
  }
}

