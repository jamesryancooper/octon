{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/schemas/kit-base/methodology-core.v1.json",
  "title": "MethodologyCore",
  "description": "Structural methodology definitions (pillars, lifecycle stages). These elements are stable and rarely change. Part of Methodology-as-Code sustainability pattern.",
  "type": "object",
  "required": ["version", "pillars", "lifecycleStages"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Methodology version (semver)",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "const": "0.2.0"
    },
    "pillars": {
      "type": "object",
      "description": "The five Harmony pillars - stable, rarely change",
      "required": ["speed_with_safety", "simplicity_over_complexity", "quality_through_determinism", "guided_agentic_autonomy", "evolvable_modularity"],
      "properties": {
        "speed_with_safety": {
          "$ref": "#/$defs/Pillar"
        },
        "simplicity_over_complexity": {
          "$ref": "#/$defs/Pillar"
        },
        "quality_through_determinism": {
          "$ref": "#/$defs/Pillar"
        },
        "guided_agentic_autonomy": {
          "$ref": "#/$defs/Pillar"
        },
        "evolvable_modularity": {
          "$ref": "#/$defs/Pillar"
        }
      },
      "additionalProperties": false
    },
    "lifecycleStages": {
      "type": "object",
      "description": "Harmony lifecycle stages - stable, rarely change",
      "required": ["spec", "plan", "implement", "verify", "ship", "operate", "learn"],
      "properties": {
        "spec": {
          "$ref": "#/$defs/LifecycleStageDefinition"
        },
        "plan": {
          "$ref": "#/$defs/LifecycleStageDefinition"
        },
        "implement": {
          "$ref": "#/$defs/LifecycleStageDefinition"
        },
        "verify": {
          "$ref": "#/$defs/LifecycleStageDefinition"
        },
        "ship": {
          "$ref": "#/$defs/LifecycleStageDefinition"
        },
        "operate": {
          "$ref": "#/$defs/LifecycleStageDefinition"
        },
        "learn": {
          "$ref": "#/$defs/LifecycleStageDefinition"
        }
      },
      "additionalProperties": false
    },
    "riskLevels": {
      "type": "object",
      "description": "Risk level definitions",
      "properties": {
        "trivial": {
          "$ref": "#/$defs/RiskLevelDefinition"
        },
        "low": {
          "$ref": "#/$defs/RiskLevelDefinition"
        },
        "medium": {
          "$ref": "#/$defs/RiskLevelDefinition"
        },
        "high": {
          "$ref": "#/$defs/RiskLevelDefinition"
        }
      }
    },
    "riskTiers": {
      "type": "object",
      "description": "Risk tier definitions (T1, T2, T3)",
      "properties": {
        "T1": {
          "$ref": "#/$defs/RiskTierDefinition"
        },
        "T2": {
          "$ref": "#/$defs/RiskTierDefinition"
        },
        "T3": {
          "$ref": "#/$defs/RiskTierDefinition"
        }
      }
    },
    "hitlCheckpoints": {
      "type": "array",
      "description": "Human-in-the-loop checkpoint definitions",
      "items": {
        "$ref": "#/$defs/HITLCheckpoint"
      }
    }
  },
  "$defs": {
    "Pillar": {
      "type": "object",
      "description": "Harmony pillar definition",
      "required": ["id", "name", "description"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Machine-readable identifier"
        },
        "name": {
          "type": "string",
          "description": "Human-readable name"
        },
        "description": {
          "type": "string",
          "description": "Pillar description"
        },
        "practices": {
          "type": "array",
          "description": "Primary practices that implement this pillar",
          "items": { "type": "string" }
        }
      }
    },
    "LifecycleStageDefinition": {
      "type": "object",
      "description": "Lifecycle stage definition",
      "required": ["id", "name", "description"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Machine-readable identifier"
        },
        "name": {
          "type": "string",
          "description": "Human-readable name"
        },
        "description": {
          "type": "string",
          "description": "Stage description"
        },
        "order": {
          "type": "integer",
          "description": "Order in the lifecycle (1-7)"
        },
        "gates": {
          "type": "array",
          "description": "Gates that must pass before proceeding",
          "items": { "type": "string" }
        },
        "artifacts": {
          "type": "array",
          "description": "Artifacts produced in this stage",
          "items": { "type": "string" }
        }
      }
    },
    "RiskLevelDefinition": {
      "type": "object",
      "description": "Risk level definition",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "hitlRequired": { "type": "boolean" },
        "approvalRequired": { "type": "boolean" }
      }
    },
    "RiskTierDefinition": {
      "type": "object",
      "description": "Risk tier definition",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "maxRiskLevel": {
          "type": "string",
          "enum": ["trivial", "low", "medium", "high"]
        }
      }
    },
    "HITLCheckpoint": {
      "type": "object",
      "description": "HITL checkpoint definition",
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "enum": ["pre-implement", "pre-merge", "pre-promote", "post-promote"]
        },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "requiredForRiskLevels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["trivial", "low", "medium", "high"]
          }
        }
      }
    }
  }
}

