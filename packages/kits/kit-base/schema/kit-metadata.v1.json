{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/schemas/kit-base/kit-metadata.v1.2.json",
  "title": "KitMetadata",
  "description": "Kit metadata schema v1.2. Adds explicit methodology and schema versioning for Methodology-as-Code sustainability.",
  "type": "object",
  "required": ["name", "version", "schemaVersion", "methodologyVersion", "pillars", "lifecycleStages", "inputsSchema", "outputsSchema", "observability", "determinism", "safety", "idempotency"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Version of the kit-metadata schema this document conforms to",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "const": "1.2.0"
    },
    "methodologyVersion": {
      "type": "string",
      "description": "Version of the Harmony methodology this kit aligns with",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "name": {
      "type": "string",
      "description": "Kit name (e.g., flowkit)"
    },
    "version": {
      "type": "string",
      "description": "Semantic version of the kit",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description"
    },
    "pillars": {
      "type": "array",
      "description": "Harmony pillars this kit reinforces (structural methodology - rarely changes)",
      "items": {
        "$ref": "#/$defs/HarmonyPillar"
      },
      "minItems": 1
    },
    "lifecycleStages": {
      "type": "array",
      "description": "Lifecycle stages this kit participates in (structural methodology - rarely changes)",
      "items": {
        "$ref": "#/$defs/LifecycleStage"
      },
      "minItems": 1
    },
    "inputsSchema": {
      "type": "string",
      "description": "Path to inputs JSON schema"
    },
    "outputsSchema": {
      "type": "string",
      "description": "Path to outputs JSON schema"
    },
    "policy": {
      "type": "object",
      "description": "Policy configuration (operational methodology - may evolve)",
      "properties": {
        "rulesetRef": {
          "type": "string",
          "description": "Reference to external ruleset (e.g., harmony-policy-v1)"
        },
        "rules": {
          "type": "array",
          "description": "Policy rules this kit enforces",
          "items": { "type": "string" }
        },
        "rulesetVersion": {
          "type": "string",
          "description": "Version of the ruleset"
        },
        "enforcement": {
          "$ref": "#/$defs/EnforcementMode"
        },
        "failClosed": {
          "type": "boolean",
          "description": "Whether to fail closed on policy check errors"
        }
      }
    },
    "observability": {
      "type": "object",
      "description": "Observability configuration",
      "required": ["serviceName", "requiredSpans"],
      "properties": {
        "serviceName": {
          "type": "string",
          "description": "OTel service name (e.g., harmony.kit.flowkit)"
        },
        "requiredSpans": {
          "type": "array",
          "description": "Required span names",
          "items": { "type": "string" }
        },
        "logRedaction": {
          "type": "boolean",
          "description": "Whether log redaction is enabled"
        }
      }
    },
    "determinism": {
      "type": "object",
      "description": "Determinism configuration",
      "properties": {
        "ai": {
          "type": ["object", "null"],
          "properties": {
            "provider": { "type": "string" },
            "model": { "type": "string" },
            "temperatureMax": { "type": "number" },
            "supportsSeed": { "type": "boolean" },
            "promptHashAlgorithm": { "type": "string" }
          }
        },
        "artifactNaming": { "type": "string" }
      }
    },
    "safety": {
      "type": "object",
      "description": "Safety configuration",
      "properties": {
        "hitl": {
          "type": "object",
          "properties": {
            "requiredFor": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["medium", "high"]
              }
            }
          }
        }
      }
    },
    "idempotency": {
      "type": "object",
      "description": "Idempotency configuration",
      "properties": {
        "required": { "type": "boolean" },
        "idempotencyKeyFrom": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "description": "Compatibility, versioning, and migration metadata",
      "properties": {
        "minSchemaVersion": {
          "type": "string",
          "description": "Minimum schema version this kit supports",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "maxSchemaVersion": {
          "type": "string",
          "description": "Maximum schema version this kit supports",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "supportedMethodologyVersions": {
          "type": "array",
          "description": "Methodology versions this kit is compatible with",
          "items": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          }
        },
        "contracts": {
          "type": "array",
          "description": "Contract versions this kit implements",
          "items": { "type": "string" }
        },
        "kits": {
          "type": "array",
          "description": "Other kits this kit is compatible with",
          "items": { "type": "string" }
        },
        "breakingChangePolicy": {
          "type": "string",
          "description": "Policy for breaking changes"
        },
        "deprecations": {
          "type": "array",
          "description": "Deprecated fields with migration information",
          "items": {
            "$ref": "#/$defs/Deprecation"
          }
        }
      }
    },
    "dryRun": {
      "type": "object",
      "description": "Dry-run support",
      "properties": {
        "supported": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "HarmonyPillar": {
      "type": "string",
      "description": "Harmony methodology pillar (structural - rarely changes)",
      "enum": [
        "speed_with_safety",
        "simplicity_over_complexity",
        "quality_through_determinism",
        "guided_agentic_autonomy",
        "evolvable_modularity"
      ]
    },
    "LifecycleStage": {
      "type": "string",
      "description": "Harmony lifecycle stage (structural - rarely changes)",
      "enum": ["spec", "plan", "implement", "verify", "ship", "operate", "learn"]
    },
    "EnforcementMode": {
      "type": "string",
      "description": "Policy enforcement mode for graceful transitions",
      "enum": ["block", "warn", "off"],
      "default": "block"
    },
    "Deprecation": {
      "type": "object",
      "description": "Deprecation notice with migration guidance",
      "required": ["field", "since", "migrationNote"],
      "properties": {
        "field": {
          "type": "string",
          "description": "Dot-path to deprecated field"
        },
        "since": {
          "type": "string",
          "description": "Schema version when deprecation was introduced",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "removeAt": {
          "type": "string",
          "description": "Schema version when field will be removed",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "migrationNote": {
          "type": "string",
          "description": "Instructions for migrating away from deprecated field"
        }
      }
    }
  }
}
