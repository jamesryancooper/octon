{
  "name": "@harmony/prompts",
  "version": "0.1.0",
  "description": "Canonical prompt library for Harmony AI agents - structured prompts with schemas, validation, and versioning",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "import": "./dist/catalog.js"
    },
    "./schemas/*": "./schemas/*",
    "./core/*": "./core/*"
  },
  "files": [
    "dist",
    "core",
    "schemas",
    "catalog.yaml"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:golden": "vitest run --config vitest.golden.config.ts",
    "validate": "tsx src/validate.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "peerDependencies": {
    "@harmony/contracts": "workspace:*"
  }
}

