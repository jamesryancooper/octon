{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/schemas/prompts/threat-model-from-spec.input.json",
  "title": "Threat Model from Spec - Input Schema",
  "description": "Input schema for the threat-model-from-spec prompt",
  "type": "object",
  "required": ["spec", "tier"],
  "properties": {
    "spec": {
      "type": "object",
      "required": ["title", "description", "surfaces"],
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "surfaces": {
          "type": "array",
          "items": { 
            "type": "string",
            "enum": ["api", "ui", "data", "background", "cli", "auth", "billing"]
          }
        },
        "contracts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "method": { "type": "string" },
              "auth_required": { "type": "boolean" }
            }
          }
        },
        "data_classification": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "field": { "type": "string" },
              "classification": { 
                "type": "string",
                "enum": ["PII", "PHI", "SECRET", "AUTH", "OTHER_SENSITIVE", "PUBLIC"]
              }
            }
          }
        }
      }
    },
    "tier": {
      "type": "string",
      "enum": ["T2", "T3"],
      "description": "Risk tier determines analysis depth"
    },
    "context": {
      "type": "object",
      "properties": {
        "existing_security_patterns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Security patterns already in the codebase"
        },
        "auth_mechanism": {
          "type": "string",
          "description": "How authentication works in this app"
        },
        "data_storage": {
          "type": "string",
          "description": "How/where data is stored"
        },
        "external_dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "External services this feature interacts with"
        }
      }
    }
  }
}

