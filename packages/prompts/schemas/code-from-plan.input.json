{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/schemas/prompts/code-from-plan.input.json",
  "title": "Code from Plan - Input Schema",
  "description": "Input schema for the code-from-plan prompt",
  "type": "object",
  "required": ["step", "plan_context"],
  "properties": {
    "step": {
      "type": "object",
      "required": ["step_number", "name", "description", "type", "files", "success_criteria"],
      "properties": {
        "step_number": { "type": "integer" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { 
          "type": "string", 
          "enum": ["scaffold", "implement", "test", "refactor", "config"] 
        },
        "files": {
          "type": "object",
          "properties": {
            "create": { "type": "array", "items": { "type": "string" } },
            "modify": { "type": "array", "items": { "type": "string" } },
            "delete": { "type": "array", "items": { "type": "string" } }
          }
        },
        "success_criteria": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "plan_context": {
      "type": "object",
      "properties": {
        "spec_title": { "type": "string" },
        "tier": { "type": "string", "enum": ["T1", "T2", "T3"] },
        "architecture": {
          "type": "object",
          "properties": {
            "pattern": { "type": "string" },
            "layers_affected": { "type": "array", "items": { "type": "string" } }
          }
        },
        "feature_flag": { "type": "string" }
      }
    },
    "codebase_context": {
      "type": "object",
      "properties": {
        "relevant_files": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        },
        "patterns": {
          "type": "object",
          "properties": {
            "import_aliases": { 
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "naming_conventions": {
              "type": "object",
              "properties": {
                "files": { "type": "string" },
                "functions": { "type": "string" },
                "types": { "type": "string" }
              }
            },
            "test_framework": { "type": "string" },
            "error_handling": { "type": "string" }
          }
        },
        "available_imports": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Modules that can be safely imported"
        }
      }
    },
    "previous_outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "step_number": { "type": "integer" },
          "files": { "type": "array" }
        }
      },
      "description": "Code generated in previous steps for reference"
    }
  }
}

