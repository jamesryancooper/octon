{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/schemas/prompts/plan-from-spec.input.json",
  "title": "Plan from Spec - Input Schema",
  "description": "Input schema for the plan-from-spec prompt",
  "type": "object",
  "required": ["spec"],
  "properties": {
    "spec": {
      "type": "object",
      "description": "The validated specification (T1, T2, or T3 format)",
      "required": ["title", "tier"],
      "properties": {
        "title": { "type": "string" },
        "tier": { "type": "string", "enum": ["T1", "T2", "T3"] },
        "description": { "type": "string" },
        "surfaces": { "type": "array", "items": { "type": "string" } },
        "contracts": { "type": "array" },
        "tests": { "type": "object" },
        "flag": { "type": "string" },
        "rollback": { 
          "oneOf": [
            { "type": "string" },
            { "type": "object" }
          ]
        }
      }
    },
    "codebase_context": {
      "type": "object",
      "description": "Relevant codebase context for planning",
      "properties": {
        "file_tree": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Relevant portion of the file tree"
        },
        "existing_patterns": {
          "type": "object",
          "description": "Detected patterns in the codebase",
          "properties": {
            "architecture": {
              "type": "string",
              "enum": ["hexagonal", "layered", "mvc", "other"]
            },
            "test_framework": { "type": "string" },
            "api_style": { "type": "string" }
          }
        },
        "relevant_files": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "content": { "type": "string" },
              "summary": { "type": "string" }
            }
          }
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Relevant installed packages"
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Additional constraints from human developer"
    }
  }
}

