{
  "schema_version": "workflow-contract-v1",
  "name": "audit-continuous-workflow",
  "description": "Invalid because a destructive workflow cannot use coordination kind none.",
  "version": "1.0.0",
  "entry_mode": "human",
  "execution_profile": "core",
  "side_effect_class": "destructive",
  "execution_controls": {
    "cancel_safe": false
  },
  "coordination_key_strategy": {
    "kind": "none"
  },
  "inputs": [],
  "stages": [
    {
      "id": "analyze",
      "asset": "../01-analyze.md",
      "kind": "analysis",
      "consumes": [],
      "produces": [
        "stage:analyze"
      ],
      "mutation_scope": []
    }
  ],
  "artifacts": [],
  "done_gate": {
    "checks": [
      "verification stage passes"
    ]
  },
  "constraints": {
    "fail_closed": true,
    "require_relative_local_assets": true
  },
  "executor_interface_version": "workflow-executor-v1"
}
