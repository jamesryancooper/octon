{
  "max_concurrency": 1,
  "concurrency_mode": "serialize",
  "idempotency_strategy": {
    "kind": "event-dedupe",
    "key_fields": [
      "automation_id",
      "event_id",
      "workflow_ref.workflow_id"
    ]
  },
  "retry_policy": {
    "max_attempts": 3,
    "backoff": "exponential",
    "retryable_classes": [
      "transient_runtime_failure"
    ]
  },
  "pause_on_error": true,
  "incident_policy": {
    "open_incident_on": [
      "repeated-terminal-failure",
      "retry-exhausted"
    ]
  }
}
