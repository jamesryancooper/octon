{
  "schema_version": "workflow-contract-v1",
  "name": "audit-continuous-workflow",
  "description": "Run a bounded continuous audit and publish a unique report bundle.",
  "version": "1.0.0",
  "entry_mode": "human",
  "execution_profile": "core",
  "side_effect_class": "mutating",
  "execution_controls": {
    "cancel_safe": false
  },
  "coordination_key_strategy": {
    "kind": "explicit-input",
    "source_fields": [
      "target_path"
    ],
    "format": "target:{target_path}"
  },
  "inputs": [
    {
      "name": "target_path",
      "type": "folder",
      "required": true,
      "description": "Root path to audit"
    }
  ],
  "stages": [
    {
      "id": "analyze",
      "asset": "stages/01-analyze.md",
      "kind": "analysis",
      "consumes": [],
      "produces": [
        "stage:analyze"
      ],
      "mutation_scope": []
    },
    {
      "id": "verify",
      "asset": "stages/99-verify.md",
      "kind": "verification",
      "consumes": [
        "stage:analyze"
      ],
      "produces": [
        "stage:verify"
      ],
      "mutation_scope": []
    }
  ],
  "artifacts": [
    {
      "name": "continuous_audit_report",
      "path": "../../output/reports/{{date}}-continuous-audit.md",
      "kind": "file",
      "format": "markdown",
      "determinism": "unique",
      "description": "Top-level workflow report"
    }
  ],
  "done_gate": {
    "checks": [
      "verification stage passes"
    ]
  },
  "constraints": {
    "fail_closed": true,
    "require_relative_local_assets": true,
    "forbid_design_packages": false
  },
  "executor_interface_version": "workflow-executor-v1"
}
