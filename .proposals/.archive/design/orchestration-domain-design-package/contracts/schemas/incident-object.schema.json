{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/design-packages/orchestration/incident-object.schema.json",
  "title": "Incident Object",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "incident_id",
    "title",
    "severity",
    "status",
    "owner",
    "created_at",
    "summary"
  ],
  "properties": {
    "incident_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": [
        "sev0",
        "sev1",
        "sev2",
        "sev3"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "acknowledged",
        "mitigating",
        "monitoring",
        "resolved",
        "closed",
        "cancelled"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "run_ids": {
      "$ref": "#/$defs/stringArray"
    },
    "mission_ids": {
      "$ref": "#/$defs/stringArray"
    },
    "workflow_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workflowRef"
      }
    },
    "automation_ids": {
      "$ref": "#/$defs/stringArray"
    },
    "event_ids": {
      "$ref": "#/$defs/stringArray"
    },
    "decision_ids": {
      "$ref": "#/$defs/stringArray"
    },
    "external_impact": {
      "type": "string",
      "minLength": 1
    },
    "closed_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "closed_by": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "workflowRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_group",
        "workflow_id"
      ],
      "properties": {
        "workflow_group": {
          "type": "string",
          "minLength": 1
        },
        "workflow_id": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "closed"
          }
        }
      },
      "then": {
        "required": [
          "closed_at",
          "closed_by"
        ]
      }
    }
  ]
}
