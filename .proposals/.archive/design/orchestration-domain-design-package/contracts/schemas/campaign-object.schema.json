{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/design-packages/orchestration/campaign-object.schema.json",
  "title": "Campaign Object",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "campaign_id",
    "title",
    "objective",
    "status",
    "owner",
    "created_at",
    "mission_ids",
    "success_criteria",
    "milestones"
  ],
  "properties": {
    "campaign_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "active",
        "paused",
        "completed",
        "cancelled",
        "archived"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "target_end_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "completed_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "cancelled_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "archived_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "mission_ids": {
      "$ref": "#/$defs/stringArray"
    },
    "success_criteria": {
      "$ref": "#/$defs/stringArray"
    },
    "risk_summary": {
      "type": "string",
      "minLength": 1
    },
    "completion_waiver_note": {
      "type": "string",
      "minLength": 1
    },
    "milestones": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/milestone"
      }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "milestone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "milestone_id",
        "title",
        "status"
      ],
      "properties": {
        "milestone_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "in_progress",
            "completed",
            "waived"
          ]
        },
        "mission_ids": {
          "$ref": "#/$defs/stringArray"
        },
        "target_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
        },
        "completed_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
        },
        "waiver_note": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "completed"
              }
            }
          },
          "then": {
            "required": [
              "completed_at"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "waived"
              }
            }
          },
          "then": {
            "required": [
              "waiver_note"
            ]
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "active",
              "paused",
              "completed",
              "cancelled",
              "archived"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "mission_ids": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "completed"
          }
        }
      },
      "then": {
        "required": [
          "completed_at"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "cancelled"
          }
        }
      },
      "then": {
        "required": [
          "cancelled_at"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "archived"
          }
        }
      },
      "then": {
        "required": [
          "archived_at"
        ]
      }
    }
  ]
}
