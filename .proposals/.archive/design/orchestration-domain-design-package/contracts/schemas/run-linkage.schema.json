{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/design-packages/orchestration/run-linkage.schema.json",
  "title": "Run Linkage Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "status",
    "started_at",
    "decision_id",
    "continuity_run_path",
    "summary"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "running",
        "succeeded",
        "failed",
        "cancelled"
      ]
    },
    "started_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "completed_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "workflow_ref": {
      "$ref": "#/$defs/workflowRef"
    },
    "mission_id": {
      "type": "string",
      "minLength": 1
    },
    "automation_id": {
      "type": "string",
      "minLength": 1
    },
    "incident_id": {
      "type": "string",
      "minLength": 1
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "queue_item_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_run_id": {
      "type": "string",
      "minLength": 1
    },
    "coordination_key": {
      "type": "string",
      "minLength": 1
    },
    "executor_id": {
      "type": "string",
      "minLength": 1
    },
    "executor_acknowledged_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "last_heartbeat_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "lease_expires_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "recovery_status": {
      "type": "string",
      "enum": [
        "healthy",
        "suspect",
        "recovery_pending",
        "recovered",
        "abandoned"
      ]
    },
    "recovery_reason": {
      "type": "string",
      "minLength": 1
    },
    "decision_id": {
      "type": "string",
      "pattern": "^dec-[A-Za-z0-9._:-]+$"
    },
    "continuity_run_path": {
      "type": "string",
      "pattern": "^\\.octon/continuity/runs/.+/$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "workflowRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_group",
        "workflow_id"
      ],
      "properties": {
        "workflow_group": {
          "type": "string",
          "minLength": 1
        },
        "workflow_id": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "running"
          }
        }
      },
      "then": {
        "required": [
          "executor_id",
          "executor_acknowledged_at",
          "last_heartbeat_at",
          "lease_expires_at",
          "recovery_status"
        ]
      },
      "else": {
        "required": [
          "completed_at"
        ]
      }
    }
  ]
}
