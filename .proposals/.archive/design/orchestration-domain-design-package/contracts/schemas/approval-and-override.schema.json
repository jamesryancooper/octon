{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/design-packages/orchestration/approval-and-override.schema.json",
  "title": "Approval And Override Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "approval_id",
    "artifact_type",
    "action_class",
    "scope",
    "approved_by",
    "issued_at",
    "expires_at",
    "rationale",
    "review_required"
  ],
  "properties": {
    "approval_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "approval",
        "waiver",
        "override"
      ]
    },
    "action_class": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    },
    "issued_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "expires_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "review_required": {
      "type": "boolean"
    },
    "review_by": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "override_reason": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "$ref": "#/$defs/stringArray"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "workflowRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_group",
        "workflow_id"
      ],
      "properties": {
        "workflow_group": {
          "type": "string",
          "minLength": 1
        },
        "workflow_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "action"
      ],
      "properties": {
        "surface": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "workflow_ref": {
          "$ref": "#/$defs/workflowRef"
        },
        "coordination_key": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "review_required": {
            "const": true
          }
        }
      },
      "then": {
        "required": [
          "review_by"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "artifact_type": {
            "const": "override"
          }
        }
      },
      "then": {
        "required": [
          "override_reason"
        ]
      }
    }
  ]
}
