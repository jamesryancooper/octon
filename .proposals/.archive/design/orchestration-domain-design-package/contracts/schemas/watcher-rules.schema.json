{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/design-packages/orchestration/watcher-rules.schema.json",
  "title": "Watcher Rules",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rules"
  ],
  "properties": {
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rule_id",
          "source_ids",
          "condition",
          "event_type",
          "severity",
          "summary_template"
        ],
        "properties": {
          "rule_id": {
            "type": "string",
            "minLength": 1
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "condition": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "threshold",
                  "absence",
                  "change",
                  "match"
                ]
              },
              "path": {
                "type": "string",
                "minLength": 1
              },
              "operator": {
                "type": "string",
                "enum": [
                  ">",
                  ">=",
                  "<",
                  "<=",
                  "==",
                  "!=",
                  "contains",
                  "matches"
                ]
              },
              "value": {},
              "window": {
                "type": "string",
                "pattern": "^P(T.*)?[0-9A-Z]+.*$"
              }
            }
          },
          "event_type": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "warning",
                "high",
                "critical"
              ]
          },
          "summary_template": {
            "type": "string",
            "minLength": 1
          },
          "dedupe_key_fields": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "routing_hints": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "target_automation_id": {
                "type": "string",
                "minLength": 1
              },
              "candidate_incident_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
