{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/design-packages/orchestration/automation-policy.schema.json",
  "title": "Automation Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "max_concurrency",
    "concurrency_mode",
    "idempotency_strategy",
    "retry_policy",
    "pause_on_error"
  ],
  "properties": {
    "max_concurrency": {
      "type": "integer",
      "minimum": 1
    },
    "concurrency_mode": {
      "type": "string",
      "enum": [
        "serialize",
        "drop",
        "replace",
        "parallel"
      ]
    },
    "idempotency_strategy": {
      "$ref": "#/$defs/idempotencyStrategy"
    },
    "retry_policy": {
      "$ref": "#/$defs/retryPolicy"
    },
    "pause_on_error": {
      "type": "boolean"
    },
    "incident_policy": {
      "$ref": "#/$defs/incidentPolicy"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "idempotencyStrategy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "key_fields"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "event-dedupe",
            "schedule-window"
          ]
        },
        "key_fields": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "retryPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_attempts",
        "backoff",
        "retryable_classes"
      ],
      "properties": {
        "max_attempts": {
          "type": "integer",
          "minimum": 1
        },
        "backoff": {
          "type": "string",
          "enum": [
            "fixed",
            "linear",
            "exponential"
          ]
        },
        "retryable_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "validation_failure",
              "reference_resolution_failure",
              "policy_denied",
              "approval_missing",
              "transient_runtime_failure",
              "terminal_runtime_failure",
              "concurrency_conflict",
              "binding_validation_failure",
              "lock_acquisition_failure",
              "lock_lost_during_execution",
              "executor_liveness_failure",
              "stale_claim",
              "evidence_write_failure",
              "launch_commit_failure",
              "manual_quarantine"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "incidentPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "open_incident_on"
      ],
      "properties": {
        "open_incident_on": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "repeated-terminal-failure",
              "retry-exhausted",
              "launch-commit-failure",
              "evidence-write-failure"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "concurrency_mode": {
            "enum": [
              "serialize",
              "replace"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "max_concurrency": {
            "const": 1
          }
        }
      }
    }
  ]
}
