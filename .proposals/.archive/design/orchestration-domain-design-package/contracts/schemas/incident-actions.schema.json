{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/design-packages/orchestration/incident-actions.schema.json",
  "title": "Incident Actions",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "actions"
  ],
  "properties": {
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "action_id",
          "action_type",
          "status"
        ],
        "properties": {
          "action_id": {
            "type": "string",
            "minLength": 1
          },
          "action_type": {
            "type": "string",
            "enum": [
              "containment",
              "rollback",
              "remediation",
              "review"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "in_progress",
              "completed",
              "cancelled"
            ]
          },
          "workflow_ref": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "workflow_group",
              "workflow_id"
            ],
            "properties": {
              "workflow_group": {
                "type": "string",
                "minLength": 1
              },
              "workflow_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
