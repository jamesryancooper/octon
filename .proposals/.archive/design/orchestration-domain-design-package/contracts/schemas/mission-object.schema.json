{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/design-packages/orchestration/mission-object.schema.json",
  "title": "Mission Object",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mission_id",
    "title",
    "summary",
    "status",
    "owner",
    "created_at",
    "success_criteria"
  ],
  "properties": {
    "schema_version": {
      "const": "mission-object-v1"
    },
    "mission_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "created",
        "active",
        "completed",
        "cancelled",
        "archived"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "campaign_id": {
      "type": "string",
      "minLength": 1
    },
    "default_workflow_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workflowRef"
      }
    },
    "active_run_ids": {
      "$ref": "#/$defs/stringArray"
    },
    "recent_run_ids": {
      "$ref": "#/$defs/stringArray"
    },
    "related_run_ids": {
      "$ref": "#/$defs/stringArray"
    },
    "archived_from_status": {
      "type": "string",
      "enum": [
        "completed",
        "cancelled"
      ]
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "workflowRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_group",
        "workflow_id"
      ],
      "properties": {
        "workflow_group": {
          "type": "string",
          "minLength": 1
        },
        "workflow_id": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "archived"
          }
        }
      },
      "then": {
        "required": [
          "archived_from_status"
        ]
      }
    }
  ]
}
