{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/design-packages/orchestration/workflow-execution.schema.json",
  "title": "Workflow Definition And Execution Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "description",
    "version",
    "entry_mode",
    "execution_profile",
    "side_effect_class",
    "execution_controls",
    "coordination_key_strategy",
    "inputs",
    "stages",
    "artifacts",
    "done_gate",
    "constraints",
    "executor_interface_version"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "workflow-contract-v1"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "entry_mode": {
      "type": "string",
      "minLength": 1
    },
    "execution_profile": {
      "type": "string",
      "enum": [
        "core",
        "external-dependent"
      ]
    },
    "side_effect_class": {
      "type": "string",
      "enum": [
        "none",
        "read_only",
        "mutating",
        "destructive"
      ]
    },
    "execution_controls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cancel_safe"
      ],
      "properties": {
        "cancel_safe": {
          "type": "boolean"
        }
      }
    },
    "coordination_key_strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "none",
            "workflow-target",
            "mission-target",
            "incident-target",
            "explicit-input"
          ]
        },
        "source_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "format": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/inputField"
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stage"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "done_gate": {
      "$ref": "#/$defs/doneGate"
    },
    "constraints": {
      "$ref": "#/$defs/constraints"
    },
    "executor_interface_version": {
      "type": "string",
      "const": "workflow-executor-v1"
    }
  },
  "$defs": {
    "inputField": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type",
        "required"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "text",
            "boolean",
            "file",
            "folder",
            "integer",
            "number",
            "object",
            "array"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "default": {},
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "asset",
        "kind",
        "consumes",
        "produces",
        "mutation_scope"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "asset": {
          "type": "string",
          "pattern": "^stages/.+\\.md$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "analysis",
            "mutation",
            "projection",
            "verification"
          ]
        },
        "consumes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "produces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "mutation_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "path",
        "kind",
        "format",
        "determinism",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "file",
            "directory"
          ]
        },
        "format": {
          "type": "string",
          "minLength": 1
        },
        "determinism": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "doneGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checks"
      ],
      "properties": {
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fail_closed",
        "require_relative_local_assets"
      ],
      "properties": {
        "fail_closed": {
          "type": "boolean",
          "const": true
        },
        "require_relative_local_assets": {
          "type": "boolean",
          "const": true
        },
        "forbid_design_packages": {
          "type": "boolean"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "side_effect_class": {
            "enum": [
              "mutating",
              "destructive"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "coordination_key_strategy": {
            "properties": {
              "kind": {
                "not": {
                  "const": "none"
                }
              }
            },
            "required": [
              "source_fields",
              "format"
            ]
          }
        }
      }
    }
  ]
}
