{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/design-packages/orchestration/watcher-sources.schema.json",
  "title": "Watcher Sources",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sources"
  ],
  "properties": {
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "kind",
          "ref",
          "required_access"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "required_access": {
            "type": "string",
            "enum": [
              "read",
              "read-metadata"
            ]
          },
          "cursor_field": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
