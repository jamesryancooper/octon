{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/design-packages/orchestration/watcher-definition.schema.json",
  "title": "Watcher Definition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "watcher_id",
    "title",
    "owner",
    "status",
    "runner",
    "cursor_mode"
  ],
  "properties": {
    "watcher_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "disabled",
        "error"
      ]
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "poll",
            "subscription"
          ]
        },
        "cadence": {
          "type": "string",
          "pattern": "^P(T.*)?[0-9A-Z]+.*$"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "poll"
              }
            }
          },
          "then": {
            "required": [
              "cadence"
            ]
          }
        }
      ]
    },
    "cursor_mode": {
      "type": "string",
      "enum": [
        "none",
        "per-source-watermark",
        "opaque"
      ]
    },
    "suppression_window": {
      "type": "string",
      "pattern": "^P(T.*)?[0-9A-Z]+.*$"
    }
  }
}
