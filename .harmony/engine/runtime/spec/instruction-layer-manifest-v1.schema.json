{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/engine/runtime/spec/instruction-layer-manifest-v1.schema.json",
  "title": "Harmony Instruction-Layer Manifest v1",
  "description": "Canonical machine-readable schema for instruction-layer manifests emitted for material policy evaluations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "layers"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "instruction-layer-manifest-v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "layer_id",
          "source",
          "sha256",
          "bytes",
          "visibility"
        ],
        "properties": {
          "layer_id": {
            "type": "string",
            "enum": [
              "provider",
              "system",
              "developer",
              "user"
            ]
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          },
          "visibility": {
            "type": "string",
            "enum": [
              "full",
              "partial",
              "none"
            ]
          }
        }
      }
    }
  }
}
