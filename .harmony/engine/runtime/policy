#!/usr/bin/env bash
# policy - Engine-owned launcher for the harmony-policy runtime interface.

set -euo pipefail

RUNTIME_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENGINE_DIR="$(cd "$RUNTIME_DIR/.." && pwd)"
HARMONY_DIR="$(cd "$ENGINE_DIR/.." && pwd)"
RUNTIME_CRATES_DIR="$RUNTIME_DIR/crates"
DEFAULT_BIN="$ENGINE_DIR/_ops/state/build/runtime-crates-target/debug/harmony-policy"
POLICY_INTERFACE_CONFIG="$RUNTIME_DIR/config/policy-interface.yml"

DEFAULT_POLICY_REL=".harmony/capabilities/governance/policy/deny-by-default.v2.yml"
RECEIPT_WRITER_REL=".harmony/capabilities/_ops/scripts/policy-receipt-write.sh"
ROLLOUT_STATE_REL=".harmony/capabilities/_ops/state/rollout-mode.state"
ALLOW_EXIT_CODE=0
DENY_EXIT_CODE=13
CONTRACT_ERROR_EXIT_CODE=2
DEFAULT_RECEIPTS_RUNS_DIR=".harmony/continuity/runs"

config_paths_value() {
  local key="$1"
  awk -v key="$key" '
    /^paths:/ {in_paths=1; next}
    in_paths && /^[a-z_]+:/ {in_paths=0}
    in_paths && $1 == key ":" {
      value=$2
      gsub(/["'\'' ]/, "", value)
      print value
      exit
    }
  ' "$POLICY_INTERFACE_CONFIG"
}

config_exit_code_value() {
  local key="$1"
  awk -v key="$key" '
    /^exit_codes:/ {in_codes=1; next}
    in_codes && /^[a-z_]+:/ {in_codes=0}
    in_codes && $1 == key ":" {
      print $2
      exit
    }
  ' "$POLICY_INTERFACE_CONFIG"
}

load_policy_interface_config() {
  if [[ ! -f "$POLICY_INTERFACE_CONFIG" ]]; then
    return 0
  fi

  local value
  value="$(config_paths_value "default_policy" || true)"
  [[ -n "$value" ]] && DEFAULT_POLICY_REL="$value"

  value="$(config_paths_value "receipt_writer" || true)"
  [[ -n "$value" ]] && RECEIPT_WRITER_REL="$value"

  value="$(config_paths_value "rollout_mode_state" || true)"
  [[ -n "$value" ]] && ROLLOUT_STATE_REL="$value"

  value="$(config_exit_code_value "allow" || true)"
  [[ -n "$value" ]] && ALLOW_EXIT_CODE="$value"

  value="$(config_exit_code_value "deny" || true)"
  [[ -n "$value" ]] && DENY_EXIT_CODE="$value"

  value="$(config_exit_code_value "contract_error" || true)"
  [[ -n "$value" ]] && CONTRACT_ERROR_EXIT_CODE="$value"
}

load_policy_interface_config

policy_receipts_runs_dir() {
  local policy_path="$1"
  local runs_dir=""
  runs_dir="$(awk '/^[[:space:]]*runs_dir:[[:space:]]*/{print $2; exit}' "$policy_path" | tr -d '"'"'"'\''')"
  [[ -n "$runs_dir" ]] || runs_dir="$DEFAULT_RECEIPTS_RUNS_DIR"
  printf '%s\n' "$runs_dir"
}

resolve_receipt_validate_path() {
  local receipt_output="$1"
  local policy_path="$2"
  local request_path="$3"

  local parsed_path=""
  parsed_path="$(jq -r '.latest_receipt // .receipt // .compatibility_receipt // empty' <<<"$receipt_output" 2>/dev/null || true)"
  if [[ -n "$parsed_path" && -f "$parsed_path" ]]; then
    printf '%s\n' "$parsed_path"
    return 0
  fi

  local run_id=""
  run_id="$(jq -r '.run_id // empty' "$request_path" 2>/dev/null || true)"
  if [[ -z "$run_id" ]]; then
    return 1
  fi

  local runs_dir candidate
  runs_dir="$(policy_receipts_runs_dir "$policy_path")"

  candidate="$runs_dir/$run_id/receipt.latest.json"
  if [[ -f "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  candidate="$runs_dir/$run_id/receipt.json"
  if [[ -f "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  return 1
}

resolve_from_harmony() {
  local rel="$1"
  if [[ "$rel" == .harmony/* ]]; then
    echo "$HARMONY_DIR/${rel#.harmony/}"
    return 0
  fi
  if [[ "$rel" == ./* ]]; then
    echo "$HARMONY_DIR/${rel#./}"
    return 0
  fi
  if [[ "$rel" == /* ]]; then
    echo "$rel"
    return 0
  fi
  echo "$HARMONY_DIR/$rel"
}

DEFAULT_POLICY="$(resolve_from_harmony "$DEFAULT_POLICY_REL")"
RECEIPT_WRITER="$(resolve_from_harmony "$RECEIPT_WRITER_REL")"
ROLLOUT_STATE_FILE="$(resolve_from_harmony "$ROLLOUT_STATE_REL")"

binary_is_stale() {
  local bin="$1"
  if [[ ! -x "$bin" ]]; then
    return 0
  fi

  local src_root="$RUNTIME_CRATES_DIR/policy_engine"
  if find \
    "$src_root/src" \
    "$src_root/tests" \
    "$src_root/Cargo.toml" \
    "$RUNTIME_CRATES_DIR/Cargo.toml" \
    -type f -newer "$bin" -print -quit 2>/dev/null | grep -q .; then
    return 0
  fi

  return 1
}

ensure_harmony_policy_bin() {
  local candidate="${HARMONY_POLICY_BIN:-$DEFAULT_BIN}"

  if [[ -x "$candidate" ]] && ! binary_is_stale "$candidate"; then
    echo "$candidate"
    return 0
  fi

  if [[ ! -d "$RUNTIME_CRATES_DIR" ]]; then
    echo "Missing runtime crates directory: $RUNTIME_CRATES_DIR" >&2
    return 1
  fi

  mkdir -p "$ENGINE_DIR/_ops/state/build/runtime-crates-target"
  (
    cd "$RUNTIME_CRATES_DIR"
    export CARGO_TARGET_DIR="$ENGINE_DIR/_ops/state/build/runtime-crates-target"
    cargo build -q -p policy_engine --bin harmony-policy
  )

  if [[ -x "$candidate" ]]; then
    echo "$candidate"
    return 0
  fi

  if [[ -x "$DEFAULT_BIN" ]]; then
    echo "$DEFAULT_BIN"
    return 0
  fi

  echo "Unable to locate built harmony-policy binary" >&2
  return 1
}

run_acp_enforce() {
  local bin="$1"
  shift || true

  local emit_receipt="false"
  local emit_digest="false"
  local run_id_override=""
  local policy_path="$DEFAULT_POLICY"
  local request_path=""
  local request_arg_index=-1
  local show_help="false"
  local -a passthrough=()
  local -a input_args=("$@")

  local idx=0
  while (( idx < ${#input_args[@]} )); do
    local token="${input_args[$idx]}"
    case "$token" in
      --emit-receipt)
        emit_receipt="true"
        ;;
      --digest)
        emit_digest="true"
        ;;
      -h|--help)
        show_help="true"
        passthrough+=("$token")
        ;;
      --run-id)
        idx=$((idx + 1))
        if (( idx >= ${#input_args[@]} )); then
          echo "--run-id requires a value" >&2
          return "$CONTRACT_ERROR_EXIT_CODE"
        fi
        run_id_override="${input_args[$idx]}"
        ;;
      --policy)
        idx=$((idx + 1))
        if (( idx >= ${#input_args[@]} )); then
          echo "--policy requires a value" >&2
          return "$CONTRACT_ERROR_EXIT_CODE"
        fi
        policy_path="${input_args[$idx]}"
        passthrough+=("$token" "$policy_path")
        ;;
      --request)
        idx=$((idx + 1))
        if (( idx >= ${#input_args[@]} )); then
          echo "--request requires a value" >&2
          return "$CONTRACT_ERROR_EXIT_CODE"
        fi
        request_path="${input_args[$idx]}"
        passthrough+=("$token" "$request_path")
        request_arg_index=$((${#passthrough[@]} - 1))
        ;;
      *)
        passthrough+=("$token")
        ;;
    esac
    idx=$((idx + 1))
  done

  if [[ "$show_help" == "true" ]]; then
    cat <<'USAGE'
engine/runtime/policy wrapper options for `acp-enforce`:
  --emit-receipt   Emit ACP receipt/digest artifacts via policy-receipt-write.sh.
  --run-id <id>    Override request.run_id before evaluation (requires --request).
  --digest         Print rendered digest to stderr after receipt emission (requires --emit-receipt).
USAGE
    "$bin" acp-enforce --help
    return 0
  fi

  if [[ "$emit_receipt" != "true" ]]; then
    if [[ -n "$run_id_override" || "$emit_digest" == "true" ]]; then
      echo "--run-id/--digest require --emit-receipt" >&2
      return "$CONTRACT_ERROR_EXIT_CODE"
    fi
  fi

  local tmp_request=""
  local effective_request_path="$request_path"
  if [[ -n "$run_id_override" ]]; then
    if [[ -z "$request_path" || "$request_arg_index" -lt 0 ]]; then
      echo "--run-id requires --request for acp-enforce" >&2
      return "$CONTRACT_ERROR_EXIT_CODE"
    fi
    if ! command -v jq >/dev/null 2>&1; then
      echo "jq is required for --run-id request override" >&2
      return "$CONTRACT_ERROR_EXIT_CODE"
    fi
    tmp_request="$(mktemp "${TMPDIR:-/tmp}/acp-enforce-request.XXXXXX.json")"
    if ! jq --arg run_id "$run_id_override" '.run_id = $run_id' "$request_path" > "$tmp_request"; then
      rm -f "$tmp_request"
      echo "failed to apply run_id override to request: $request_path" >&2
      return "$CONTRACT_ERROR_EXIT_CODE"
    fi
    passthrough[$request_arg_index]="$tmp_request"
    effective_request_path="$tmp_request"
  fi

  local decision_output rc
  set +e
  decision_output="$("$bin" acp-enforce "${passthrough[@]}")"
  rc=$?
  set -e
  printf '%s\n' "$decision_output"

  local tmp_decision="" receipt_output="" receipt_rc=0 receipt_validate_rc=0 receipt_validate_output="" receipt_validate_path=""
  if [[ "$emit_receipt" == "true" ]]; then
    if [[ -z "$effective_request_path" ]]; then
      echo "--emit-receipt requires --request <path>" >&2
      rm -f "$tmp_request"
      [[ "$rc" -eq "$ALLOW_EXIT_CODE" ]] && return "$DENY_EXIT_CODE"
      return "$rc"
    fi
    if [[ ! -x "$RECEIPT_WRITER" ]]; then
      echo "receipt writer unavailable: $RECEIPT_WRITER" >&2
      rm -f "$tmp_request"
      [[ "$rc" -eq "$ALLOW_EXIT_CODE" ]] && return "$DENY_EXIT_CODE"
      return "$rc"
    fi
    if ! command -v jq >/dev/null 2>&1; then
      echo "jq is required for --emit-receipt mode" >&2
      rm -f "$tmp_request"
      [[ "$rc" -eq "$ALLOW_EXIT_CODE" ]] && return "$DENY_EXIT_CODE"
      return "$rc"
    fi
    if ! jq -e . >/dev/null 2>&1 <<<"$decision_output"; then
      echo "acp-enforce did not return JSON; cannot emit receipt" >&2
      rm -f "$tmp_request"
      [[ "$rc" -eq "$ALLOW_EXIT_CODE" ]] && return "$DENY_EXIT_CODE"
      return "$rc"
    fi

    tmp_decision="$(mktemp "${TMPDIR:-/tmp}/acp-enforce-decision.XXXXXX.json")"
    printf '%s\n' "$decision_output" > "$tmp_decision"

    set +e
    receipt_output="$("$RECEIPT_WRITER" --policy "$policy_path" --request "$effective_request_path" --decision "$tmp_decision" 2>&1)"
    receipt_rc=$?
    set -e
    if [[ "$receipt_rc" -ne 0 ]]; then
      echo "failed to emit ACP receipt: $receipt_output" >&2
      rm -f "$tmp_request" "$tmp_decision"
      [[ "$rc" -eq "$ALLOW_EXIT_CODE" ]] && return "$DENY_EXIT_CODE"
      return "$rc"
    fi

    receipt_validate_path="$(resolve_receipt_validate_path "$receipt_output" "$policy_path" "$effective_request_path" || true)"
    if [[ -z "$receipt_validate_path" || ! -f "$receipt_validate_path" ]]; then
      echo "receipt writer did not return a valid receipt path for validation" >&2
      echo "receipt writer raw output: $receipt_output" >&2
      rm -f "$tmp_request" "$tmp_decision"
      [[ "$rc" -eq "$ALLOW_EXIT_CODE" ]] && return "$DENY_EXIT_CODE"
      return "$rc"
    fi
    set +e
    receipt_validate_output="$("$bin" receipt-validate --policy "$policy_path" --receipt "$receipt_validate_path" 2>&1)"
    receipt_validate_rc=$?
    set -e
    if [[ "$receipt_validate_rc" -ne 0 ]]; then
      echo "failed ACP receipt validation: $receipt_validate_output" >&2
      rm -f "$tmp_request" "$tmp_decision"
      [[ "$rc" -eq "$ALLOW_EXIT_CODE" ]] && return "$DENY_EXIT_CODE"
      return "$rc"
    fi

    if [[ "$emit_digest" == "true" ]]; then
      local digest_path
      digest_path="$(jq -r '.latest_digest // .digest // empty' <<<"$receipt_output" 2>/dev/null || true)"
      if [[ -n "$digest_path" && -f "$digest_path" ]]; then
        echo "[acp-enforce] digest: $digest_path" >&2
        cat "$digest_path" >&2
      else
        echo "[acp-enforce] digest unavailable from receipt writer output" >&2
      fi
    fi
  fi

  rm -f "$tmp_request" "$tmp_decision"
  return "$rc"
}

main() {
  if [[ "${1:-}" == "--print-bin" ]]; then
    ensure_harmony_policy_bin
    return 0
  fi

  local bin
  bin="$(ensure_harmony_policy_bin)"
  if [[ -f "$ROLLOUT_STATE_FILE" ]]; then
    local mode
    mode="$(head -n 1 "$ROLLOUT_STATE_FILE" | tr -d '[:space:]')"
    if [[ "$mode" == "shadow" || "$mode" == "soft-enforce" || "$mode" == "hard-enforce" ]]; then
      export HARMONY_POLICY_MODE_OVERRIDE="$mode"
    fi
  fi

  local command="${1:-}"
  if [[ "$command" == "acp-enforce" ]]; then
    shift
    run_acp_enforce "$bin" "$@"
    return $?
  fi

  "$bin" "$@"
}

main "$@"
