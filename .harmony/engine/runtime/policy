#!/usr/bin/env bash
# policy - Engine-owned launcher for the harmony-policy runtime interface.

set -euo pipefail

RUNTIME_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENGINE_DIR="$(cd "$RUNTIME_DIR/.." && pwd)"
HARMONY_DIR="$(cd "$ENGINE_DIR/.." && pwd)"
RUNTIME_CRATES_DIR="$RUNTIME_DIR/crates"
DEFAULT_BIN="$ENGINE_DIR/_ops/state/build/runtime-crates-target/debug/harmony-policy"
POLICY_INTERFACE_CONFIG="$RUNTIME_DIR/config/policy-interface.yml"

DEFAULT_POLICY_REL=".harmony/capabilities/governance/policy/deny-by-default.v2.yml"
RECEIPT_WRITER_REL=".harmony/capabilities/_ops/scripts/policy-receipt-write.sh"
ROLLOUT_STATE_REL=".harmony/capabilities/_ops/state/rollout-mode.state"
INSTRUCTION_LAYER_MANIFEST_SCHEMA_REL=".harmony/engine/runtime/spec/instruction-layer-manifest-v1.schema.json"
MATERIAL_RUNS_REQUIRE_MANIFEST="true"
MANIFEST_FILENAME="instruction-layer-manifest.json"
ALLOW_EXIT_CODE=0
DENY_EXIT_CODE=13
CONTRACT_ERROR_EXIT_CODE=2
DEFAULT_RECEIPTS_RUNS_DIR=".harmony/continuity/runs"

config_paths_value() {
  local key="$1"
  awk -v key="$key" '
    /^paths:/ {in_paths=1; next}
    in_paths && /^[a-z_]+:/ {in_paths=0}
    in_paths && $1 == key ":" {
      value=$2
      gsub(/["'\'' ]/, "", value)
      print value
      exit
    }
  ' "$POLICY_INTERFACE_CONFIG"
}

config_exit_code_value() {
  local key="$1"
  awk -v key="$key" '
    /^exit_codes:/ {in_codes=1; next}
    in_codes && /^[a-z_]+:/ {in_codes=0}
    in_codes && $1 == key ":" {
      print $2
      exit
    }
  ' "$POLICY_INTERFACE_CONFIG"
}

config_wrapper_acp_value() {
  local key="$1"
  awk -v key="$key" '
    /^wrapper:/ {in_wrapper=1; next}
    in_wrapper && /^[a-z_]+:/ {in_wrapper=0}
    in_wrapper && /^  acp_enforce:/ {in_acp=1; next}
    in_wrapper && in_acp && /^  [a-z_]+:/ {in_acp=0}
    in_wrapper && in_acp && $1 == key ":" {
      value=$2
      gsub(/["'\'' ]/, "", value)
      print value
      exit
    }
  ' "$POLICY_INTERFACE_CONFIG"
}

load_policy_interface_config() {
  if [[ ! -f "$POLICY_INTERFACE_CONFIG" ]]; then
    return 0
  fi

  local value
  value="$(config_paths_value "default_policy" || true)"
  [[ -n "$value" ]] && DEFAULT_POLICY_REL="$value"

  value="$(config_paths_value "receipt_writer" || true)"
  [[ -n "$value" ]] && RECEIPT_WRITER_REL="$value"

  value="$(config_paths_value "rollout_mode_state" || true)"
  [[ -n "$value" ]] && ROLLOUT_STATE_REL="$value"

  value="$(config_paths_value "instruction_layer_manifest_schema" || true)"
  [[ -n "$value" ]] && INSTRUCTION_LAYER_MANIFEST_SCHEMA_REL="$value"

  value="$(config_exit_code_value "allow" || true)"
  [[ -n "$value" ]] && ALLOW_EXIT_CODE="$value"

  value="$(config_exit_code_value "deny" || true)"
  [[ -n "$value" ]] && DENY_EXIT_CODE="$value"

  value="$(config_exit_code_value "contract_error" || true)"
  [[ -n "$value" ]] && CONTRACT_ERROR_EXIT_CODE="$value"

  value="$(config_wrapper_acp_value "material_runs_require_manifest" || true)"
  [[ -n "$value" ]] && MATERIAL_RUNS_REQUIRE_MANIFEST="$value"
}

load_policy_interface_config

policy_receipts_runs_dir() {
  local policy_path="$1"
  local runs_dir=""
  runs_dir="$(awk '/^[[:space:]]*runs_dir:[[:space:]]*/{print $2; exit}' "$policy_path" | tr -d '"'"'"'\''')"
  [[ -n "$runs_dir" ]] || runs_dir="$DEFAULT_RECEIPTS_RUNS_DIR"
  printf '%s\n' "$runs_dir"
}

resolve_receipt_validate_path() {
  local receipt_output="$1"
  local policy_path="$2"
  local request_path="$3"

  local parsed_path=""
  parsed_path="$(jq -r '.latest_receipt // .receipt // .compatibility_receipt // empty' <<<"$receipt_output" 2>/dev/null || true)"
  if [[ -n "$parsed_path" && -f "$parsed_path" ]]; then
    printf '%s\n' "$parsed_path"
    return 0
  fi

  local run_id=""
  run_id="$(jq -r '.run_id // empty' "$request_path" 2>/dev/null || true)"
  if [[ -z "$run_id" ]]; then
    return 1
  fi

  local runs_dir candidate
  runs_dir="$(policy_receipts_runs_dir "$policy_path")"

  candidate="$runs_dir/$run_id/receipt.latest.json"
  if [[ -f "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  candidate="$runs_dir/$run_id/receipt.json"
  if [[ -f "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  return 1
}

resolve_from_harmony() {
  local rel="$1"
  if [[ "$rel" == .harmony/* ]]; then
    echo "$HARMONY_DIR/${rel#.harmony/}"
    return 0
  fi
  if [[ "$rel" == ./* ]]; then
    echo "$HARMONY_DIR/${rel#./}"
    return 0
  fi
  if [[ "$rel" == /* ]]; then
    echo "$rel"
    return 0
  fi
  echo "$HARMONY_DIR/$rel"
}

DEFAULT_POLICY="$(resolve_from_harmony "$DEFAULT_POLICY_REL")"
RECEIPT_WRITER="$(resolve_from_harmony "$RECEIPT_WRITER_REL")"
ROLLOUT_STATE_FILE="$(resolve_from_harmony "$ROLLOUT_STATE_REL")"
INSTRUCTION_LAYER_MANIFEST_SCHEMA_FILE="$(resolve_from_harmony "$INSTRUCTION_LAYER_MANIFEST_SCHEMA_REL")"

zero_sha256() {
  printf '%064d' 0
}

sha256_file() {
  local path="$1"
  if [[ ! -f "$path" ]]; then
    zero_sha256
    return 0
  fi
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$path" | awk '{print tolower($1)}'
    return 0
  fi
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$path" | awk '{print tolower($1)}'
    return 0
  fi
  if command -v openssl >/dev/null 2>&1; then
    openssl dgst -sha256 "$path" | awk '{print tolower($NF)}'
    return 0
  fi
  zero_sha256
}

file_bytes() {
  local path="$1"
  if [[ ! -f "$path" ]]; then
    echo 0
    return 0
  fi
  wc -c < "$path" | tr -d '[:space:]'
}

request_is_material_run() {
  local request_file="$1"
  jq -e '
    ((.phase // "" | ascii_downcase) as $phase |
      ($phase == "promote" or $phase == "finalize"))
    or
    (
      (.operation.target // {}) as $target |
      (
        ($target.material_side_effect // false) == true or
        ($target.meaningful_behavior_change // false) == true or
        ($target.durable_effect // false) == true or
        ($target.promotion // false) == true
      )
    )
  ' "$request_file" >/dev/null 2>&1
}

request_has_valid_instruction_layers() {
  local request_file="$1"
  jq -e '
    (.instruction_layers // empty) as $layers |
    ($layers | type == "array" and length > 0) and
    ($layers | all(.[]; (
      (.layer_id | type == "string" and
        (. == "provider" or . == "system" or . == "developer" or . == "user")) and
      (.source | type == "string" and length > 0) and
      (.sha256 | type == "string" and test("^[a-f0-9]{64}$")) and
      (.bytes | type == "number" and . >= 0 and . == floor) and
      (.visibility | type == "string" and
        (. == "full" or . == "partial" or . == "none"))
    )))
  ' "$request_file" >/dev/null 2>&1
}

request_has_valid_context_telemetry() {
  local request_file="$1"
  jq -e '
    (.context_acquisition | type == "object") and
    (.context_acquisition.file_reads | type == "number" and . >= 0 and . == floor) and
    (.context_acquisition.search_queries | type == "number" and . >= 0 and . == floor) and
    (.context_acquisition.commands | type == "number" and . >= 0 and . == floor) and
    (.context_acquisition.subagent_spawns | type == "number" and . >= 0 and . == floor) and
    (.context_acquisition.duration_ms | type == "number" and . >= 0 and . == floor) and
    (.context_overhead_ratio | type == "number" and . >= 0)
  ' "$request_file" >/dev/null 2>&1
}

build_default_context_acquisition_json() {
  local file_reads search_queries commands subagent_spawns duration_ms

  file_reads="${HARMONY_CONTEXT_FILE_READS:-0}"
  search_queries="${HARMONY_CONTEXT_SEARCH_QUERIES:-0}"
  commands="${HARMONY_CONTEXT_COMMANDS:-1}"
  subagent_spawns="${HARMONY_CONTEXT_SUBAGENT_SPAWNS:-0}"
  duration_ms="${HARMONY_CONTEXT_DURATION_MS:-0}"

  [[ "$file_reads" =~ ^[0-9]+$ ]] || file_reads=0
  [[ "$search_queries" =~ ^[0-9]+$ ]] || search_queries=0
  [[ "$commands" =~ ^[0-9]+$ ]] || commands=0
  [[ "$subagent_spawns" =~ ^[0-9]+$ ]] || subagent_spawns=0
  [[ "$duration_ms" =~ ^[0-9]+$ ]] || duration_ms=0

  jq -cn \
    --argjson file_reads "$file_reads" \
    --argjson search_queries "$search_queries" \
    --argjson commands "$commands" \
    --argjson subagent_spawns "$subagent_spawns" \
    --argjson duration_ms "$duration_ms" \
    '{
      file_reads: $file_reads,
      search_queries: $search_queries,
      commands: $commands,
      subagent_spawns: $subagent_spawns,
      duration_ms: $duration_ms
    }'
}

build_default_instruction_layers_json() {
  local request_file="$1"
  local provider_source system_source developer_source user_source
  local provider_visibility system_visibility developer_visibility user_visibility
  local developer_file user_file
  local provider_sha system_sha developer_sha user_sha
  local provider_bytes system_bytes developer_bytes user_bytes

  provider_source="${HARMONY_INSTRUCTION_LAYER_PROVIDER_SOURCE:-upstream}"
  system_source="${HARMONY_INSTRUCTION_LAYER_SYSTEM_SOURCE:-harmony-system}"
  developer_source="${HARMONY_INSTRUCTION_LAYER_DEVELOPER_SOURCE:-AGENTS.md}"
  user_source="${HARMONY_INSTRUCTION_LAYER_USER_SOURCE:-runtime-request}"

  provider_visibility="${HARMONY_INSTRUCTION_LAYER_PROVIDER_VISIBILITY:-partial}"
  system_visibility="${HARMONY_INSTRUCTION_LAYER_SYSTEM_VISIBILITY:-partial}"
  developer_visibility="${HARMONY_INSTRUCTION_LAYER_DEVELOPER_VISIBILITY:-full}"
  user_visibility="${HARMONY_INSTRUCTION_LAYER_USER_VISIBILITY:-full}"

  developer_file="${HARMONY_INSTRUCTION_LAYER_DEVELOPER_FILE:-$HARMONY_DIR/AGENTS.md}"
  user_file="${HARMONY_INSTRUCTION_LAYER_USER_FILE:-$request_file}"

  provider_sha="$(zero_sha256)"
  system_sha="$(zero_sha256)"
  developer_sha="$(sha256_file "$developer_file")"
  user_sha="$(sha256_file "$user_file")"

  provider_bytes=0
  system_bytes=0
  developer_bytes="$(file_bytes "$developer_file")"
  user_bytes="$(file_bytes "$user_file")"

  jq -cn \
    --arg provider_source "$provider_source" \
    --arg system_source "$system_source" \
    --arg developer_source "$developer_source" \
    --arg user_source "$user_source" \
    --arg provider_sha "$provider_sha" \
    --arg system_sha "$system_sha" \
    --arg developer_sha "$developer_sha" \
    --arg user_sha "$user_sha" \
    --argjson provider_bytes "$provider_bytes" \
    --argjson system_bytes "$system_bytes" \
    --argjson developer_bytes "$developer_bytes" \
    --argjson user_bytes "$user_bytes" \
    --arg provider_visibility "$provider_visibility" \
    --arg system_visibility "$system_visibility" \
    --arg developer_visibility "$developer_visibility" \
    --arg user_visibility "$user_visibility" \
    '[
      {
        layer_id: "provider",
        source: $provider_source,
        sha256: $provider_sha,
        bytes: $provider_bytes,
        visibility: $provider_visibility
      },
      {
        layer_id: "system",
        source: $system_source,
        sha256: $system_sha,
        bytes: $system_bytes,
        visibility: $system_visibility
      },
      {
        layer_id: "developer",
        source: $developer_source,
        sha256: $developer_sha,
        bytes: $developer_bytes,
        visibility: $developer_visibility
      },
      {
        layer_id: "user",
        source: $user_source,
        sha256: $user_sha,
        bytes: $user_bytes,
        visibility: $user_visibility
      }
    ]'
}

emit_instruction_layer_manifest() {
  local run_id="$1"
  local layers_json="$2"
  local run_dir manifest_path generated_at

  run_dir="$HARMONY_DIR/continuity/runs/$run_id"
  manifest_path="$run_dir/$MANIFEST_FILENAME"
  generated_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  mkdir -p "$run_dir"

  if ! jq -n \
    --arg generated_at "$generated_at" \
    --argjson layers "$layers_json" \
    '{
      schema_version: "instruction-layer-manifest-v1",
      generated_at: $generated_at,
      layers: $layers
    }' > "$manifest_path"; then
    return 1
  fi

  jq -e '
    .schema_version == "instruction-layer-manifest-v1" and
    (.generated_at | type == "string" and length > 0) and
    (.layers | type == "array" and length > 0) and
    (.layers | all(.[]; (
      (.layer_id | type == "string" and
        (. == "provider" or . == "system" or . == "developer" or . == "user")) and
      (.source | type == "string" and length > 0) and
      (.sha256 | type == "string" and test("^[a-f0-9]{64}$")) and
      (.bytes | type == "number" and . >= 0 and . == floor) and
      (.visibility | type == "string" and
        (. == "full" or . == "partial" or . == "none"))
    )))
  ' "$manifest_path" >/dev/null

  if [[ -f "$INSTRUCTION_LAYER_MANIFEST_SCHEMA_FILE" ]]; then
    jq -e . "$INSTRUCTION_LAYER_MANIFEST_SCHEMA_FILE" >/dev/null
  fi

  printf '%s\n' "$manifest_path"
}

prepare_request_with_manifest() {
  local request_file="$1"
  local run_id_override="$2"
  local output_request="$request_file"
  local run_id layers_json manifest_path tmp_request

  if [[ "$MATERIAL_RUNS_REQUIRE_MANIFEST" != "true" ]]; then
    printf '%s\n' "$output_request"
    return 0
  fi
  if ! request_is_material_run "$request_file"; then
    printf '%s\n' "$output_request"
    return 0
  fi
  if ! command -v jq >/dev/null 2>&1; then
    echo "jq is required for material-run instruction-layer manifests" >&2
    return "$CONTRACT_ERROR_EXIT_CODE"
  fi

  if request_has_valid_instruction_layers "$request_file"; then
    layers_json="$(jq -c '.instruction_layers' "$request_file")"
  else
    layers_json="$(build_default_instruction_layers_json "$request_file")"
    tmp_request="$(mktemp "${TMPDIR:-/tmp}/acp-enforce-manifest-request.XXXXXX.json")"
    if ! jq --argjson layers "$layers_json" '.instruction_layers = $layers' "$request_file" > "$tmp_request"; then
      rm -f "$tmp_request"
      echo "failed to inject instruction_layers into material request" >&2
      return "$CONTRACT_ERROR_EXIT_CODE"
    fi
    output_request="$tmp_request"
  fi

  if ! request_has_valid_context_telemetry "$output_request"; then
    local context_acquisition_json context_overhead_ratio tmp_with_telemetry
    context_acquisition_json="$(build_default_context_acquisition_json)"
    context_overhead_ratio="${HARMONY_CONTEXT_OVERHEAD_RATIO:-0}"
    if ! jq -en --arg ratio "$context_overhead_ratio" '$ratio | tonumber | . >= 0' >/dev/null 2>&1; then
      context_overhead_ratio="0"
    fi

    tmp_with_telemetry="$(mktemp "${TMPDIR:-/tmp}/acp-enforce-telemetry-request.XXXXXX.json")"
    if ! jq \
      --argjson context_acquisition "$context_acquisition_json" \
      --arg context_overhead_ratio "$context_overhead_ratio" \
      '.context_acquisition = $context_acquisition
       | .context_overhead_ratio = ($context_overhead_ratio | tonumber)' \
      "$output_request" > "$tmp_with_telemetry"; then
      rm -f "$tmp_with_telemetry"
      if [[ "$output_request" != "$request_file" ]]; then
        rm -f "$output_request"
      fi
      echo "failed to inject context telemetry into material request" >&2
      return "$CONTRACT_ERROR_EXIT_CODE"
    fi
    if [[ "$output_request" != "$request_file" ]]; then
      rm -f "$output_request"
    fi
    output_request="$tmp_with_telemetry"
  fi

  run_id="$(jq -r '.run_id // ""' "$output_request")"
  if [[ -n "$run_id_override" ]]; then
    run_id="$run_id_override"
  fi
  if [[ -z "$run_id" ]]; then
    rm -f "${tmp_request:-}"
    echo "material run request missing run_id; cannot emit instruction-layer manifest" >&2
    return "$CONTRACT_ERROR_EXIT_CODE"
  fi

  if ! manifest_path="$(emit_instruction_layer_manifest "$run_id" "$layers_json")"; then
    rm -f "${tmp_request:-}"
    echo "failed to emit instruction-layer manifest for material run '$run_id'" >&2
    return "$CONTRACT_ERROR_EXIT_CODE"
  fi

  if [[ "$output_request" == "$request_file" ]]; then
    tmp_request="$(mktemp "${TMPDIR:-/tmp}/acp-enforce-manifest-request.XXXXXX.json")"
    if ! jq --arg manifest "$manifest_path" '.instruction_layer_manifest = $manifest' "$request_file" > "$tmp_request"; then
      rm -f "$tmp_request"
      echo "failed to attach instruction-layer manifest path to request payload" >&2
      return "$CONTRACT_ERROR_EXIT_CODE"
    fi
    output_request="$tmp_request"
  else
    local tmp_with_manifest
    tmp_with_manifest="$(mktemp "${TMPDIR:-/tmp}/acp-enforce-manifest-request.XXXXXX.json")"
    if ! jq --arg manifest "$manifest_path" '.instruction_layer_manifest = $manifest' "$output_request" > "$tmp_with_manifest"; then
      rm -f "$tmp_with_manifest" "$output_request"
      echo "failed to attach instruction-layer manifest path to request payload" >&2
      return "$CONTRACT_ERROR_EXIT_CODE"
    fi
    rm -f "$output_request"
    output_request="$tmp_with_manifest"
  fi

  printf '%s\n' "$output_request"
}

binary_is_stale() {
  local bin="$1"
  if [[ ! -x "$bin" ]]; then
    return 0
  fi

  local src_root="$RUNTIME_CRATES_DIR/policy_engine"
  if find \
    "$src_root/src" \
    "$src_root/tests" \
    "$src_root/Cargo.toml" \
    "$RUNTIME_CRATES_DIR/Cargo.toml" \
    -type f -newer "$bin" -print -quit 2>/dev/null | grep -q .; then
    return 0
  fi

  return 1
}

ensure_harmony_policy_bin() {
  local candidate="${HARMONY_POLICY_BIN:-$DEFAULT_BIN}"

  if [[ -x "$candidate" ]] && ! binary_is_stale "$candidate"; then
    echo "$candidate"
    return 0
  fi

  if [[ ! -d "$RUNTIME_CRATES_DIR" ]]; then
    echo "Missing runtime crates directory: $RUNTIME_CRATES_DIR" >&2
    return 1
  fi

  mkdir -p "$ENGINE_DIR/_ops/state/build/runtime-crates-target"
  (
    cd "$RUNTIME_CRATES_DIR"
    export CARGO_TARGET_DIR="$ENGINE_DIR/_ops/state/build/runtime-crates-target"
    cargo build -q -p policy_engine --bin harmony-policy
  )

  if [[ -x "$candidate" ]]; then
    echo "$candidate"
    return 0
  fi

  if [[ -x "$DEFAULT_BIN" ]]; then
    echo "$DEFAULT_BIN"
    return 0
  fi

  echo "Unable to locate built harmony-policy binary" >&2
  return 1
}

run_acp_enforce() {
  local bin="$1"
  shift || true

  local emit_receipt="false"
  local emit_digest="false"
  local run_id_override=""
  local policy_path="$DEFAULT_POLICY"
  local request_path=""
  local request_arg_index=-1
  local show_help="false"
  local -a passthrough=()
  local -a input_args=("$@")

  local idx=0
  while (( idx < ${#input_args[@]} )); do
    local token="${input_args[$idx]}"
    case "$token" in
      --emit-receipt)
        emit_receipt="true"
        ;;
      --digest)
        emit_digest="true"
        ;;
      -h|--help)
        show_help="true"
        passthrough+=("$token")
        ;;
      --run-id)
        idx=$((idx + 1))
        if (( idx >= ${#input_args[@]} )); then
          echo "--run-id requires a value" >&2
          return "$CONTRACT_ERROR_EXIT_CODE"
        fi
        run_id_override="${input_args[$idx]}"
        ;;
      --policy)
        idx=$((idx + 1))
        if (( idx >= ${#input_args[@]} )); then
          echo "--policy requires a value" >&2
          return "$CONTRACT_ERROR_EXIT_CODE"
        fi
        policy_path="${input_args[$idx]}"
        passthrough+=("$token" "$policy_path")
        ;;
      --request)
        idx=$((idx + 1))
        if (( idx >= ${#input_args[@]} )); then
          echo "--request requires a value" >&2
          return "$CONTRACT_ERROR_EXIT_CODE"
        fi
        request_path="${input_args[$idx]}"
        passthrough+=("$token" "$request_path")
        request_arg_index=$((${#passthrough[@]} - 1))
        ;;
      *)
        passthrough+=("$token")
        ;;
    esac
    idx=$((idx + 1))
  done

  if [[ "$show_help" == "true" ]]; then
    cat <<'USAGE'
engine/runtime/policy wrapper options for `acp-enforce`:
  --emit-receipt   Emit ACP receipt/digest artifacts via policy-receipt-write.sh.
  --run-id <id>    Override request.run_id before evaluation (requires --request).
  --digest         Print rendered digest to stderr after receipt emission (requires --emit-receipt).
USAGE
    "$bin" acp-enforce --help
    return 0
  fi

  if [[ "$emit_receipt" != "true" ]]; then
    if [[ -n "$run_id_override" || "$emit_digest" == "true" ]]; then
      echo "--run-id/--digest require --emit-receipt" >&2
      return "$CONTRACT_ERROR_EXIT_CODE"
    fi
  fi

  local tmp_request=""
  local tmp_manifest_request=""
  local effective_request_path="$request_path"
  if [[ -n "$run_id_override" ]]; then
    if [[ -z "$request_path" || "$request_arg_index" -lt 0 ]]; then
      echo "--run-id requires --request for acp-enforce" >&2
      return "$CONTRACT_ERROR_EXIT_CODE"
    fi
    if ! command -v jq >/dev/null 2>&1; then
      echo "jq is required for --run-id request override" >&2
      return "$CONTRACT_ERROR_EXIT_CODE"
    fi
    tmp_request="$(mktemp "${TMPDIR:-/tmp}/acp-enforce-request.XXXXXX.json")"
    if ! jq --arg run_id "$run_id_override" '.run_id = $run_id' "$request_path" > "$tmp_request"; then
      rm -f "$tmp_request"
      echo "failed to apply run_id override to request: $request_path" >&2
      return "$CONTRACT_ERROR_EXIT_CODE"
    fi
    passthrough[$request_arg_index]="$tmp_request"
    effective_request_path="$tmp_request"
  fi

  if [[ -n "$effective_request_path" && "$request_arg_index" -ge 0 ]]; then
    set +e
    tmp_manifest_request="$(prepare_request_with_manifest "$effective_request_path" "$run_id_override")"
    local manifest_rc=$?
    set -e
    if [[ "$manifest_rc" -ne 0 ]]; then
      rm -f "$tmp_request"
      return "$manifest_rc"
    fi
    passthrough[$request_arg_index]="$tmp_manifest_request"
    effective_request_path="$tmp_manifest_request"
  fi

  local decision_output rc
  set +e
  decision_output="$("$bin" acp-enforce "${passthrough[@]}")"
  rc=$?
  set -e
  printf '%s\n' "$decision_output"

  local tmp_decision="" receipt_output="" receipt_rc=0 receipt_validate_rc=0 receipt_validate_output="" receipt_validate_path=""
  if [[ "$emit_receipt" == "true" ]]; then
    if [[ -z "$effective_request_path" ]]; then
      echo "--emit-receipt requires --request <path>" >&2
      rm -f "$tmp_request" "$tmp_manifest_request"
      [[ "$rc" -eq "$ALLOW_EXIT_CODE" ]] && return "$DENY_EXIT_CODE"
      return "$rc"
    fi
    if [[ ! -x "$RECEIPT_WRITER" ]]; then
      echo "receipt writer unavailable: $RECEIPT_WRITER" >&2
      rm -f "$tmp_request" "$tmp_manifest_request"
      [[ "$rc" -eq "$ALLOW_EXIT_CODE" ]] && return "$DENY_EXIT_CODE"
      return "$rc"
    fi
    if ! command -v jq >/dev/null 2>&1; then
      echo "jq is required for --emit-receipt mode" >&2
      rm -f "$tmp_request" "$tmp_manifest_request"
      [[ "$rc" -eq "$ALLOW_EXIT_CODE" ]] && return "$DENY_EXIT_CODE"
      return "$rc"
    fi
    if ! jq -e . >/dev/null 2>&1 <<<"$decision_output"; then
      echo "acp-enforce did not return JSON; cannot emit receipt" >&2
      rm -f "$tmp_request" "$tmp_manifest_request"
      [[ "$rc" -eq "$ALLOW_EXIT_CODE" ]] && return "$DENY_EXIT_CODE"
      return "$rc"
    fi

    tmp_decision="$(mktemp "${TMPDIR:-/tmp}/acp-enforce-decision.XXXXXX.json")"
    printf '%s\n' "$decision_output" > "$tmp_decision"

    set +e
    receipt_output="$("$RECEIPT_WRITER" --policy "$policy_path" --request "$effective_request_path" --decision "$tmp_decision" 2>&1)"
    receipt_rc=$?
    set -e
    if [[ "$receipt_rc" -ne 0 ]]; then
      echo "failed to emit ACP receipt: $receipt_output" >&2
      rm -f "$tmp_request" "$tmp_manifest_request" "$tmp_decision"
      [[ "$rc" -eq "$ALLOW_EXIT_CODE" ]] && return "$DENY_EXIT_CODE"
      return "$rc"
    fi

    receipt_validate_path="$(resolve_receipt_validate_path "$receipt_output" "$policy_path" "$effective_request_path" || true)"
    if [[ -z "$receipt_validate_path" || ! -f "$receipt_validate_path" ]]; then
      echo "receipt writer did not return a valid receipt path for validation" >&2
      echo "receipt writer raw output: $receipt_output" >&2
      rm -f "$tmp_request" "$tmp_manifest_request" "$tmp_decision"
      [[ "$rc" -eq "$ALLOW_EXIT_CODE" ]] && return "$DENY_EXIT_CODE"
      return "$rc"
    fi
    set +e
    receipt_validate_output="$("$bin" receipt-validate --policy "$policy_path" --receipt "$receipt_validate_path" 2>&1)"
    receipt_validate_rc=$?
    set -e
    if [[ "$receipt_validate_rc" -ne 0 ]]; then
      echo "failed ACP receipt validation: $receipt_validate_output" >&2
      rm -f "$tmp_request" "$tmp_manifest_request" "$tmp_decision"
      [[ "$rc" -eq "$ALLOW_EXIT_CODE" ]] && return "$DENY_EXIT_CODE"
      return "$rc"
    fi

    if [[ "$emit_digest" == "true" ]]; then
      local digest_path
      digest_path="$(jq -r '.latest_digest // empty' <<<"$receipt_output" 2>/dev/null || true)"
      if [[ -n "$digest_path" && -f "$digest_path" ]]; then
        echo "[acp-enforce] digest: $digest_path" >&2
        cat "$digest_path" >&2
      else
        echo "[acp-enforce] digest unavailable from receipt writer output" >&2
      fi
    fi
  fi

  rm -f "$tmp_request" "$tmp_manifest_request" "$tmp_decision"
  return "$rc"
}

main() {
  if [[ "${1:-}" == "--print-bin" ]]; then
    ensure_harmony_policy_bin
    return 0
  fi

  local bin
  bin="$(ensure_harmony_policy_bin)"
  if [[ -f "$ROLLOUT_STATE_FILE" ]]; then
    local mode
    mode="$(head -n 1 "$ROLLOUT_STATE_FILE" | tr -d '[:space:]')"
    if [[ "$mode" == "shadow" || "$mode" == "soft-enforce" || "$mode" == "hard-enforce" ]]; then
      export HARMONY_POLICY_MODE_OVERRIDE="$mode"
    fi
  fi

  local command="${1:-}"
  if [[ "$command" == "acp-enforce" ]]; then
    shift
    run_acp_enforce "$bin" "$@"
    return $?
  fi

  "$bin" "$@"
}

main "$@"
