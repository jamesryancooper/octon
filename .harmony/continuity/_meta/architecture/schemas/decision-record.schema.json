{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/continuity/decision-record.schema.json",
  "title": "Harmony Continuity Decision Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "outcome",
    "surface",
    "action",
    "actor",
    "decided_at",
    "reason_codes",
    "summary"
  ],
  "properties": {
    "decision_id": {
      "type": "string",
      "pattern": "^dec-[A-Za-z0-9._:-]+$"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "allow",
        "block",
        "escalate"
      ]
    },
    "surface": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "decided_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "workflow_ref": {
      "$ref": "#/$defs/workflowRef"
    },
    "mission_id": {
      "type": "string",
      "minLength": 1
    },
    "automation_id": {
      "type": "string",
      "minLength": 1
    },
    "incident_id": {
      "type": "string",
      "minLength": 1
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "queue_item_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "approval_refs": {
      "$ref": "#/$defs/stringArray"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "workflowRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_group",
        "workflow_id"
      ],
      "properties": {
        "workflow_group": {
          "type": "string",
          "minLength": 1
        },
        "workflow_id": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "allow"
          }
        }
      },
      "then": {},
      "else": {
        "not": {
          "required": [
            "run_id"
          ]
        }
      }
    }
  ]
}
