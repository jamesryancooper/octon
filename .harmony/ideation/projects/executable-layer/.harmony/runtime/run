#!/bin/sh
set -eu

# Resolve .harmony directory from this script location.
RUNTIME_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
HARMONY_DIR="$(CDPATH= cd -- "$RUNTIME_DIR/.." && pwd)"

OS="$(uname -s 2>/dev/null || echo unknown)"
ARCH="$(uname -m 2>/dev/null || echo unknown)"

BIN_DIR="$RUNTIME_DIR/bin"

# Map OS/arch -> expected binary name.
case "$OS" in
  Darwin)
    case "$ARCH" in
      arm64) BIN="$BIN_DIR/harmony-macos-arm64" ;;
      x86_64) BIN="$BIN_DIR/harmony-macos-x64" ;;
      *) BIN="" ;;
    esac
    ;;
  Linux)
    case "$ARCH" in
      x86_64) BIN="$BIN_DIR/harmony-linux-x64" ;;
      aarch64|arm64) BIN="$BIN_DIR/harmony-linux-arm64" ;;
      *) BIN="" ;;
    esac
    ;;
  *)
    BIN=""
    ;;
esac

if [ -n "${BIN:-}" ] && [ -x "$BIN" ]; then
  exec "$BIN" "$@"
fi

# Development fallback: run from source.
# This keeps the launcher usable before platform binaries are produced.
exec cargo run -q --manifest-path "$RUNTIME_DIR/crates/Cargo.toml" -p harmony_kernel -- "$@"
