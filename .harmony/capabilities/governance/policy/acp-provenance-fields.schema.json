{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/policy/acp-provenance-fields.schema.json",
  "title": "ACP Provenance Fields",
  "description": "Canonical provenance/replay field requirements for ACP promote decisions and receipts.",
  "type": "object",
  "required": [
    "run_id",
    "operation",
    "phase",
    "effective_acp",
    "decision",
    "reason_codes",
    "evidence",
    "rollback_handle",
    "budgets",
    "counters"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "type": "object",
      "required": ["class"],
      "properties": {
        "class": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "phase": {
      "type": "string",
      "enum": ["stage", "promote", "finalize"]
    },
    "effective_acp": {
      "type": "string",
      "pattern": "^ACP-[0-4]$"
    },
    "decision": {
      "type": "string",
      "enum": ["ALLOW", "STAGE_ONLY", "DENY", "ESCALATE"]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^ACP_[A-Z0-9_]+$"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "ref"],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    },
    "attestations": {
      "type": "array"
    },
    "rollback_handle": {
      "type": "string",
      "minLength": 1
    },
    "recovery_window": {
      "type": "string"
    },
    "budgets": {
      "type": "object"
    },
    "counters": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
