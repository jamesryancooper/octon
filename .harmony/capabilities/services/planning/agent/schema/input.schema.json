{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/schemas/agent/input.schema.json",
  "title": "AgentServiceInput",
  "type": "object",
  "required": ["planPath"],
  "properties": {
    "planPath": { "type": "string", "minLength": 1 },
    "runId": { "type": "string" },
    "resume": { "type": "boolean" },
    "memoize": { "type": "boolean" },
    "dryRun": { "type": "boolean" },
    "hitl": {
      "type": "object",
      "properties": {
        "required": { "type": "boolean" },
        "approved": { "type": "boolean" },
        "reason": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
