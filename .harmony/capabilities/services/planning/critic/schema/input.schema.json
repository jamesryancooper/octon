{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/schemas/planning-critic/input.schema.json",
  "title": "PlanningCriticInput",
  "type": "object",
  "required": ["command"],
  "properties": {
    "command": {
      "type": "string",
      "enum": ["validate", "score"]
    },
    "planPath": {
      "type": "string",
      "minLength": 1
    },
    "plan": {
      "type": "object",
      "additionalProperties": true
    },
    "strict": {
      "type": "boolean"
    },
    "riskTolerance": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    }
  },
  "additionalProperties": false
}
