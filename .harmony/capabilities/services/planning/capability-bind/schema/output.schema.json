{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/schemas/planning-capability-bind/output.schema.json",
  "title": "CapabilityBindServiceOutput",
  "type": "object",
  "required": ["status", "command", "result"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "partial", "error"]
    },
    "command": {
      "type": "string"
    },
    "result": {
      "type": "object",
      "required": ["command", "source", "bindingSummary", "stepBindings", "capabilityCatalog", "planSummary"],
      "properties": {
        "command": { "type": "string" },
        "source": { "type": "string" },
        "strategy": { "type": "string" },
        "planSummary": {
          "type": "object",
          "properties": {
            "goal": { "type": "string" },
            "stepCount": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": true
        },
        "bindingSummary": {
          "type": "object",
          "required": [
            "totalSteps",
            "requestedCapabilitiesCount",
            "supportedCapabilitiesCount",
            "degradedCapabilitiesCount",
            "unsupportedCapabilitiesCount"
          ],
          "properties": {
            "totalSteps": { "type": "integer", "minimum": 0 },
            "requestedCapabilitiesCount": { "type": "integer", "minimum": 0 },
            "supportedCapabilitiesCount": { "type": "integer", "minimum": 0 },
            "degradedCapabilitiesCount": { "type": "integer", "minimum": 0 },
            "unsupportedCapabilitiesCount": { "type": "integer", "minimum": 0 },
            "unsupportedCapabilities": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "capabilityCatalog": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["capability", "state", "via", "evidence_required"],
            "properties": {
              "capability": { "type": "string" },
              "state": { "type": "string", "enum": ["supported", "degraded", "unsupported"] },
              "via": { "type": "string", "enum": ["native", "adapter", "manual"] },
              "evidence_required": { "type": "boolean" },
              "notes": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "stepBindings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["stepId", "requiredCapabilities", "missingCapabilities", "status"],
            "properties": {
              "stepId": { "type": "string" },
              "requiredCapabilities": {
                "type": "array",
                "items": { "type": "string" }
              },
              "missingCapabilities": {
                "type": "array",
                "items": { "type": "string" }
              },
              "status": {
                "type": "string",
                "enum": ["bound", "degraded", "unsupported"]
              },
              "mode": {
                "type": "string",
                "enum": ["native", "adapter", "manual"]
              }
            }
          }
        }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
