{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/schemas/planning-replan/input.schema.json",
  "title": "PlanningReplanInput",
  "type": "object",
  "required": ["command"],
  "properties": {
    "command": {
      "type": "string",
      "enum": ["replan"]
    },
    "planPath": {
      "type": "string",
      "minLength": 1
    },
    "plan": {
      "type": "object",
      "additionalProperties": true
    },
    "blockedSteps": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "allowMissingDependencies": {
      "type": "boolean",
      "default": false
    }
  },
  "additionalProperties": false
}
