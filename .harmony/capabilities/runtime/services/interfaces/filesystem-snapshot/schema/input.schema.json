{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/schemas/filesystem-snapshot/input.v1.json",
  "title": "FilesystemSnapshotInput",
  "type": "object",
  "required": [
    "command",
    "payload"
  ],
  "additionalProperties": false,
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "fs.list",
        "fs.read",
        "fs.stat",
        "fs.search",
        "snapshot.build",
        "snapshot.diff",
        "snapshot.get-current"
      ]
    },
    "snapshot_id": {
      "type": "string",
      "pattern": "^snap-[a-f0-9]{8,64}$"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
