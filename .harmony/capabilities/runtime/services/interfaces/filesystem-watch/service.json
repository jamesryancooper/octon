{
  "abi": "wasi-component@0.2",
  "capabilities_required": [
    "clock.read",
    "fs.read",
    "fs.write",
    "log.write"
  ],
  "category": "interfaces",
  "docs": {
    "help": "Use watch.poll for bounded change detection. Pair with filesystem-snapshot for deterministic rebuild decisions.",
    "summary": "Portable watcher hints via deterministic polling and local cursor state."
  },
  "entry": "service.wasm",
  "format_version": "service-manifest-v1",
  "integrity": {
    "wasm_sha256": "d022834ca15c62fb2f882e41b8345f03d00903c86421e17f934ee274bc006a5e"
  },
  "limits": {
    "max_concurrency": 1,
    "max_request_bytes": 1048576,
    "max_response_bytes": 4194304,
    "timeout_ms": 60000
  },
  "name": "filesystem-watch",
  "ops": {
    "watch.poll": {
      "idempotent": true,
      "input_schema": {
        "additionalProperties": false,
        "properties": {
          "max_events": {
            "maximum": 10000,
            "minimum": 1,
            "type": "integer"
          },
          "max_files": {
            "maximum": 200000,
            "minimum": 1,
            "type": "integer"
          },
          "root": {
            "minLength": 1,
            "type": "string"
          },
          "state_dir": {
            "minLength": 1,
            "type": "string"
          },
          "state_key": {
            "maxLength": 256,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [],
        "type": "object"
      },
      "output_schema": {
        "anyOf": [
          {
            "additionalProperties": false,
            "properties": {
              "cursor": {
                "type": "string"
              },
              "events": {
                "items": {
                  "additionalProperties": false,
                  "properties": {
                    "change": {
                      "enum": [
                        "added",
                        "removed",
                        "changed"
                      ],
                      "type": "string"
                    },
                    "path": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "path",
                    "change"
                  ],
                  "type": "object"
                },
                "type": "array"
              },
              "filesystem_watch_contract_version": {
                "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
                "type": "string"
              },
              "ok": {
                "const": true
              },
              "scanned_at_ms": {
                "minimum": 0,
                "type": "integer"
              },
              "state_key": {
                "type": "string"
              },
              "summary": {
                "additionalProperties": false,
                "properties": {
                  "added": {
                    "minimum": 0,
                    "type": "integer"
                  },
                  "changed": {
                    "minimum": 0,
                    "type": "integer"
                  },
                  "removed": {
                    "minimum": 0,
                    "type": "integer"
                  },
                  "sample_size": {
                    "minimum": 0,
                    "type": "integer"
                  },
                  "total_files": {
                    "minimum": 0,
                    "type": "integer"
                  },
                  "truncated": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "added",
                  "changed",
                  "removed",
                  "sample_size",
                  "total_files",
                  "truncated"
                ],
                "type": "object"
              }
            },
            "required": [
              "ok",
              "filesystem_watch_contract_version",
              "cursor",
              "state_key",
              "scanned_at_ms",
              "summary",
              "events"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "error": {
                "additionalProperties": false,
                "properties": {
                  "code": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  }
                },
                "required": [
                  "code",
                  "message"
                ],
                "type": "object"
              },
              "filesystem_watch_contract_version": {
                "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
                "type": "string"
              },
              "ok": {
                "const": false
              }
            },
            "required": [
              "ok",
              "filesystem_watch_contract_version",
              "error"
            ],
            "type": "object"
          }
        ]
      },
      "streaming": false
    }
  },
  "version": "1.0.0"
}