{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/orchestration/runtime/queue/schemas/queue-item-and-lease.schema.json",
  "title": "Queue Item And Lease",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "queue_item_id",
    "target_automation_id",
    "status",
    "priority",
    "available_at",
    "attempt_count",
    "max_attempts",
    "summary",
    "enqueued_at"
  ],
  "properties": {
    "queue_item_id": {
      "type": "string",
      "minLength": 1
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "watcher_id": {
      "type": "string",
      "minLength": 1
    },
    "target_automation_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "claimed",
        "retry",
        "dead_letter"
      ]
    },
    "priority": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "available_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "claimed_by": {
      "type": "string",
      "minLength": 1
    },
    "claimed_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "claim_deadline": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    },
    "claim_token": {
      "type": "string",
      "minLength": 1
    },
    "attempt_count": {
      "type": "integer",
      "minimum": 0
    },
    "max_attempts": {
      "type": "integer",
      "minimum": 1
    },
    "payload_ref": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "last_error": {
      "type": "string",
      "minLength": 1
    },
    "enqueued_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "claimed"
          }
        }
      },
      "then": {
        "required": [
          "claimed_by",
          "claimed_at",
          "claim_deadline",
          "claim_token"
        ]
      }
    }
  ]
}
