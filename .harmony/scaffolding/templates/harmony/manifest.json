{
  "$schema": "../manifest.schema.json",
  "name": "harmony",
  "description": "Base .harmony/ template for all harnesses.",
  "inherits": null,
  "files": {
    "required": [
      "START.md",
      "scope.md",
      "conventions.md",
      "catalog.md"
    ],
    "directories": {
      "required": [
        "continuity",
        "quality",
        "scaffolding/prompts",
        "orchestration/workflows",
        "capabilities/commands",
        "cognition/context"
      ],
      "standard": [
        "scaffolding/templates",
        "scaffolding/examples",
        "agency/agents",
        "agency/assistants",
        "agency/teams",
        "orchestration/missions"
      ]
    }
  },
  "contents": {
    "START.md": "Boot sequence and orientation",
    "scope.md": "Boundaries and responsibilities",
    "conventions.md": "Style and formatting rules",
    "catalog.md": "Index of commands and workflows",
    "agency/manifest.yml": "Agency actor discovery and routing metadata",
    "agency/agents/registry.yml": "Agent definitions and delegation policy",
    "agency/agents/README.md": "How to use and create agents",
    "agency/agents/_template/agent.md": "Template for new agents",
    "continuity/log.md": "Append-only session history",
    "continuity/tasks.json": "Structured task list with goal",
    "continuity/entities.json": "Entity state tracking",
    "continuity/next.md": "Immediate actionable steps (promoted from ideation/scratchpad/)",
    "quality/done.md": "Definition of done for tasks",
    "quality/session-exit.md": "Steps before ending a session",
    "scaffolding/prompts/README.md": "Placeholder for prompts",
    "orchestration/workflows/README.md": "Placeholder for workflows",
    "orchestration/workflows/00-overview.md": "Workflow overview template",
    "capabilities/commands/README.md": "Placeholder for commands",
    "cognition/context/README.md": "Context directory overview",
    "cognition/context/decisions.md": "Agent-readable decision summaries",
    "cognition/context/lessons.md": "Anti-patterns and failures to avoid",
    "cognition/context/glossary.md": "Domain-specific terminology",
    "cognition/context/dependencies.md": "External dependencies",
    "cognition/context/constraints.md": "Technical and business constraints",
    "cognition/context/compaction.md": "Token compaction strategies",
    "cognition/context/tools.md": "Available tools reference",
    "scaffolding/templates/README.md": "Placeholder for templates",
    "scaffolding/examples/README.md": "Placeholder for examples",
    "agency/assistants/registry.yml": "Assistant @mention mappings",
    "agency/assistants/README.md": "How to use and create assistants",
    "agency/assistants/_template/assistant.md": "Template for new assistants",
    "agency/teams/registry.yml": "Team composition index",
    "agency/teams/README.md": "How to use and create teams",
    "agency/teams/_template/team.md": "Template for new teams",
    "orchestration/missions/registry.yml": "Active and archived missions index",
    "orchestration/missions/README.md": "How to create and manage missions",
    "orchestration/missions/_template/mission.md": "Mission template",
    "orchestration/missions/_template/tasks.json": "Mission tasks template",
    "orchestration/missions/_template/log.md": "Mission log template"
  }
}
