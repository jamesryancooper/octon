{
  "$schema": "../manifest.schema.json",
  "name": "harmony",
  "description": "Base .harmony/ template for all harnesses.",
  "inherits": null,
  "files": {
    "required": [
      "START.md",
      "scope.md",
      "conventions.md",
      "catalog.md"
    ],
    "directories": {
      "required": [
        "continuity",
        "quality",
        "scaffolding/prompts",
        "orchestration/runtime/workflows",
        "capabilities/runtime/commands",
        "cognition/context"
      ],
      "standard": [
        "scaffolding/templates",
        "scaffolding/_ops/scripts",
        "scaffolding/examples",
        "agency/governance",
        "agency/actors/agents",
        "agency/actors/assistants",
        "agency/actors/teams",
        "agency/practices",
        "orchestration/runtime/missions"
      ]
    }
  },
  "contents": {
    "START.md": "Boot sequence and orientation",
    "scope.md": "Boundaries and responsibilities",
    "conventions.md": "Style and formatting rules",
    "catalog.md": "Index of commands and workflows",
    "agency/manifest.yml": "Agency actor discovery and routing metadata",
    "agency/governance/CONSTITUTION.md": "Cross-agent non-negotiable governance contract",
    "agency/governance/DELEGATION.md": "Cross-agent delegation and handoff contract",
    "agency/governance/MEMORY.md": "Cross-agent memory retention and privacy contract",
    "agency/actors/agents/registry.yml": "Agent definitions and delegation policy",
    "agency/actors/agents/README.md": "How to use and create agents",
    "agency/actors/agents/_scaffold/template/AGENT.md": "Template for new agent execution contracts",
    "agency/actors/agents/_scaffold/template/SOUL.md": "Template for new agent identity contracts",
    "continuity/log.md": "Append-only session history",
    "continuity/tasks.json": "Structured task list with goal",
    "continuity/entities.json": "Entity state tracking",
    "continuity/next.md": "Immediate actionable steps (promoted from ideation/scratchpad/)",
    "assurance/practices/complete.md": "Definition of done for tasks",
    "assurance/practices/session-exit.md": "Steps before ending a session",
    "scaffolding/prompts/README.md": "Placeholder for prompts",
    "orchestration/runtime/workflows/README.md": "Placeholder for workflows",
    "orchestration/runtime/workflows/00-overview.md": "Workflow overview template",
    "capabilities/runtime/commands/README.md": "Placeholder for commands",
    "cognition/context/README.md": "Context directory overview",
    "cognition/context/decisions.md": "Agent-readable decision summaries",
    "cognition/context/lessons.md": "Anti-patterns and failures to avoid",
    "cognition/context/glossary.md": "Domain-specific terminology",
    "cognition/context/dependencies.md": "External dependencies",
    "cognition/context/constraints.md": "Technical and business constraints",
    "cognition/context/compaction.md": "Token compaction strategies",
    "cognition/context/tools.md": "Available tools reference",
    "scaffolding/templates/README.md": "Placeholder for templates",
    "scaffolding/templates/AGENTS.md": "Template for project-level AGENTS.md bootstrap file",
    "scaffolding/templates/BOOT.md": "Template for recurring startup checklist compatibility",
    "scaffolding/templates/BOOTSTRAP.md": "Template for one-time bootstrap checklist compatibility",
    "scaffolding/_ops/scripts/init-project.sh": "Initialize project-level bootstrap files from .harmony templates",
    "scaffolding/examples/README.md": "Placeholder for examples",
    "agency/actors/assistants/registry.yml": "Assistant @mention mappings",
    "agency/actors/assistants/README.md": "How to use and create assistants",
    "agency/actors/assistants/_scaffold/template/assistant.md": "Template for new assistants",
    "agency/actors/teams/registry.yml": "Team composition index",
    "agency/actors/teams/README.md": "How to use and create teams",
    "agency/actors/teams/_scaffold/template/team.md": "Template for new teams",
    "orchestration/runtime/missions/registry.yml": "Active and archived missions index",
    "orchestration/runtime/missions/README.md": "How to create and manage missions",
    "orchestration/runtime/missions/_scaffold/template/mission.md": "Mission template",
    "orchestration/runtime/missions/_scaffold/template/tasks.json": "Mission tasks template",
    "orchestration/runtime/missions/_scaffold/template/log.md": "Mission log template"
  }
}
