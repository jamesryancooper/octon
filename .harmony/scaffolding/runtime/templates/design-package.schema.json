{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Design Package Manifest",
  "description": "Schema for standard-governed Harmony design-package manifests.",
  "type": "object",
  "required": [
    "schema_version",
    "package_id",
    "title",
    "summary",
    "package_class",
    "selected_modules",
    "implementation_targets",
    "status",
    "lifecycle",
    "validation"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "design-package-v1"
    },
    "package_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "package_class": {
      "type": "string",
      "enum": ["domain-runtime", "experience-product"]
    },
    "selected_modules": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["contracts", "conformance", "reference", "history", "canonicalization"]
      }
    },
    "implementation_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "in-review", "implementation-ready", "archived"]
    },
    "lifecycle": {
      "type": "object",
      "required": ["temporary", "exit_expectation"],
      "properties": {
        "temporary": {
          "type": "boolean",
          "const": true
        },
        "exit_expectation": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": [
        "default_audit_mode",
        "package_validator_path",
        "conformance_validator_path"
      ],
      "properties": {
        "default_audit_mode": {
          "type": "string",
          "enum": ["rigorous", "short"]
        },
        "package_validator_path": {
          "type": ["string", "null"]
        },
        "conformance_validator_path": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
