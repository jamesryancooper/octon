{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Policy Proposal Manifest",
  "description": "Schema for Harmony policy proposal subtype manifests.",
  "type": "object",
  "required": ["schema_version", "policy_kind"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "policy-proposal-v1"
    },
    "policy_kind": {
      "type": "string",
      "enum": ["governance", "runtime", "authoring"]
    }
  },
  "additionalProperties": false
}
