{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Migration Proposal Manifest",
  "description": "Schema for Harmony migration proposal subtype manifests.",
  "type": "object",
  "required": ["schema_version", "change_profile", "validation"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "migration-proposal-v1"
    },
    "change_profile": {
      "type": "string",
      "enum": ["atomic", "transitional"]
    },
    "validation": {
      "type": "object",
      "required": ["plan_template_path"],
      "properties": {
        "plan_template_path": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
